// Native-width overloads for the current 32-bit STM32 target.
// Keep isize/usize formatting on native 32-bit division rather than routing
// these calls through the wider u64/i64 conversion path.
fn uart_print(v: isize) { uart_print_i32_core(v as i32); }
fn uart_print(v: usize) { uart_print_u32_core(v as u32); }
fn uart_println(v: isize) { uart_print(v); uart_puts("\r\n"); }
fn uart_println(v: usize) { uart_print(v); uart_puts("\r\n"); }
