// ICMP echo (ping) responder -- the IPv4 "echo server" step. Answers ICMP
// echo requests (type 8) addressed to OUR_IP with an echo reply (type 0),
// preserving identifier/sequence/data unchanged. Builds on
// examples/net_echo (driver plumbing), examples/arp_reply (protocol
// dispatch + in-place raw-offset header rewriting), and examples/ip_parse
// (field layout/validation logic) -- this is the first example that needs
// a *correct* checksum on the wire rather than just a validated one
// (examples/common/inet_checksum.tkb).
//
// Scope: IPv4 headers with no options only (IHL must be 5 / 20 bytes).
// ARP is not handled here (see examples/arp_reply) since the raw
// point-to-point test transport never needs ARP resolution to reach this
// responder -- frames are addressed directly by MAC.
//
// Single shared file for both targets -- see examples/net_echo/net_echo.tkb's
// header comment for why.
//
// SLICE MIGRATION (P4b): the direct template is
// examples/http_server/http_server.tkb. `ihl` is typed `{20..<21 as u16}`
// in build_echo_reply (this file's whole scope is "no IP options" -- IHL
// always exactly 20 -- and app_main()'s `ihl == 20` narrowing always produces
// exactly that range, so the exact-match refined-parameter call
// typechecks; see http_server's header comment for why this needs to be
// an EXACT match, not just a fit). --forbid-trap clean (registered as
// forbid_trap_icmp_echo in scripts/run_qemutest.sh). The device-reported
// length is clamped (`len <= 1514`) alongside the existing `len >= 42`
// check so total_len's upper bound narrows all the way down to the ICMP
// checksum span, matching http_server's total_len/tcp_len chain.
//
// WIRE-WIDTH TYPES (see CLAUDE.md's "Refinement Numerical Type" /
// "Explicit-Base {lo..<hi as base}" sections): ihl/total_len/
// ip_len_in_frame/icmp_len are all u16-based, not i32 -- `len` (from
// net_rx_len(), a deliberately-unconstrained i32 device-reported length)
// is bridged into the u16 world with ONE bridge cast (`len_n as u16`)
// right after the length is validated -- GitHub issue #72 lets this cast
// infer its range from len_n's own already-validated range, rather than
// restating it by hand as `len_n as {42..<1515 as u16}`. Everything
// downstream inherits u16-based refined ranges through ordinary
// Add/Sub/comparison propagation from there, with no further
// hardcoded-bounds casts needed. The VALIDATION bounds (`len >= 42 &&
// len <= 1514` just above it) still have to be kept in sync by hand --
// if they ever drift, --forbid-trap catches it immediately as a
// reintroduced trap site (a caught regression, not a silent one).
//
// Correctness is checked by scripts/icmp_echo_test.py (QEMU) /
// scripts/eth_icmp_echo_test.py (STM32 hardware), not UART output;
// uart_puts below is purely for interactive debugging.

use "examples/common/inet_checksum.tkb";
use "examples/common/netutil.tkb";

let mut our_mac: [u8; 6];

// Wire-VALUE constants compared/written directly against a byte field --
// u8, matching that field (unlike the OFFSET constants above, which are
// usize -- array/slice indexing is usize-only now).
let PROTO_ICMP:        u8 = 1;
let ICMP_ECHO_REQUEST: u8 = 8;
let ICMP_ECHO_REPLY:   u8 = 0;

// bytes_eq/bytes_copy/read_u16be/write_u16be/slice_copy/slice_eq/
// checksum_add/inet_checksum live in examples/common/netutil.tkb and
// examples/common/inet_checksum.tkb.

// Rewrites an ICMP echo request into a reply in place, and the enclosing
// IPv4/Ethernet headers to match. Only called after the caller has already
// verified this is a well-formed echo request addressed to OUR_IP.
// icmp_seg is the full ICMP message (header + data); its own runtime
// length (icmp_seg.len) is what the checksum walks, so it can never
// disagree with the segment it describes.
fn build_echo_reply(eth: [u8; 42..], ihl: {20..<21 as u16}, icmp_seg: [u8; 8..]) {
    // Ethernet: dst = old src, then src = our_mac (must read old src
    // before it's overwritten).
    slice_copy(eth[0..<6], eth[6..<12]);
    slice_copy(eth[6..<12], our_mac as []u8);

    let ip = eth[14..<34];

    // IPv4: dst = old src, src = OUR_IP, fresh TTL, recompute checksum
    // (source/dest/TTL all changed since the request).
    slice_copy(ip[IP_DST..<20],     ip[IP_SRC..<IP_DST]);
    slice_copy(ip[IP_SRC..<IP_DST], OUR_IP as []u8);
    ip[IP_TTL] = 64 as u8;
    write_u16be(ip[IP_CHECKSUM..<IP_SRC], 0);
    write_u16be(ip[IP_CHECKSUM..<IP_SRC],
                inet_checksum(ip[0..<ihl as usize]));

    // ICMP: type request -> reply, identifier/sequence/data unchanged,
    // recompute checksum (it covers the type byte, which just changed).
    icmp_seg[ICMP_TYPE] = ICMP_ECHO_REPLY;
    write_u16be(icmp_seg[ICMP_CHECKSUM..<4], 0);
    write_u16be(icmp_seg[ICMP_CHECKSUM..<4], inet_checksum(icmp_seg));
}

fn app_main() {
    uart_puts("icmp_echo: init\r\n");

    match net_init() {
        NetInitResult::Failed => {
            uart_puts("icmp_echo: device/link not found\r\n");
        }
        NetInitResult::Ready(mut ready) => {
            net_read_mac(our_mac as *u8);

            uart_puts("icmp_echo: ready\r\n");

            while (true) {
                net_rx_wait();
                match net_rx_acquire(ready) {
                    NetRxAcquire::None(next) => { ready = next; }
                    NetRxAcquire::Acquired(acquired) => {
                        let len: i32 = net_rx_len(acquired);
                        let mut should_tx: i32 = 0;
                        let mut tx_len: i32 = 0;

                        // 14 (eth) + 20 (min IPv4) + 8 (min ICMP) = 42
                        if (len >= 42 && len <= 1514) {
                            // Snapshot into an immutable local: the explicit refined
                            // cast below (len_n as u16) needs to see
                            // len's CURRENT narrowed range, but a function PARAMETER
                            // (always a Mut binding) only exposes its narrowed range
                            // through the separate narrowing_ctx side-table, which a
                            // bare Cast on a Mut variable does not consult (only
                            // specific Index/SliceOf sites do) -- an immutable
                            // snapshot's type inherits the narrowing directly (the
                            // same "B-plan" mechanism used elsewhere in this codebase
                            // for exactly this reason), so the cast proves clean
                            // instead of falling back to a runtime check.
                            let len_n: i32 = len;
                            let frame = net_rx_frame(acquired);
                            if (read_u16be(frame[12..<14]) == 0x0800) {
                                let ip = frame[14..<34];
                                // version is standalone (only ever compared to a
                                // literal) -- safely u8.
                                let version: u8 = ip[IP_VERSION_IHL] >> 4;
                                let ihl:     u16 = (ip[IP_VERSION_IHL] & 0x0f) * 4;

                                // No IP options supported -- IHL must be exactly 20.
                                if (version == 4 && ihl == 20) {
                                    // Bridge len_n's proven {42..<1515} range into
                                    // u16 -- see the header comment. A free coercion
                                    // (no runtime check): the source range already
                                    // implies the target range exactly.
                                    let len16: u16 = len_n as u16;
                                    let total_len:       u16 = read_u16be(ip[IP_TOTAL_LEN..<4]) as u16;
                                    let ip_len_in_frame: u16 = len16 - 14;

                                    // total_len must fit what the device actually
                                    // delivered, and must be large enough to contain
                                    // the IPv4 header itself, before it's used to
                                    // size the ICMP checksum read below.
                                    if (total_len <= ip_len_in_frame && total_len >= ihl) {
                                        if (ip[IP_PROTOCOL] == PROTO_ICMP &&
                                            inet_checksum(ip[0..<ihl as usize]) == 0) {
                                            if (slice_eq(ip[IP_DST..<20], OUR_IP as []u8)) {
                                                let icmp_len: u16 = total_len - ihl;

                                                // The upper bound restates icmp_len's
                                                // own already-established range (from
                                                // total_len's narrowing above) as an
                                                // explicit conjunct: if-narrowing only
                                                // upgrades a variable's range when BOTH
                                                // bounds appear in the condition, so
                                                // this is what lets icmp_seg's proven
                                                // subslice inherit a minimum >= 8
                                                // (matching build_echo_reply's
                                                // parameter) instead of falling back to
                                                // the LET declaration's unnarrowed floor
                                                // of 0.
                                                if (icmp_len >= 8 && icmp_len <= 1480) {
                                                    let icmp_len_idx: usize =
                                                        icmp_len as usize;
                                                    let icmp_seg = frame[34..<34 + icmp_len_idx];
                                                    if (icmp_seg[ICMP_TYPE] == ICMP_ECHO_REQUEST &&
                                                        icmp_seg[ICMP_CODE] == 0 &&
                                                        inet_checksum(icmp_seg) == 0) {

                                                        build_echo_reply(frame, ihl, icmp_seg);

                                                        let reply_len: i32 = 14 + total_len;
                                                        should_tx = 1;
                                                        tx_len = reply_len;
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        if (should_tx == 1) {
                            let in_flight = net_transmit(acquired, tx_len);
                            ready = net_tx_complete(in_flight);
                        } else {
                            ready = net_rx_release(acquired);
                        }
                    }
                }
            }
        }
    }
}
