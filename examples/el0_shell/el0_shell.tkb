// GitHub issue #156's own culmination: examples/el0_elf_load's real ELF/
// cpio loader (issue #153's original scope: a genuine Elf64_Ehdr/
// Elf64_Phdr parse, not a hardcoded offset/length copy) pointed at a
// REAL, unmodified, third-party binary instead of this repo's own
// hand-written test program -- Alpine Linux's busybox-static (aarch64,
// static-pie, GPL-2.0), downloaded fresh at build time (see the
// Makefile's own COMMON_RPI3_BUSYBOX_APK rule for why it is fetched, not
// vendored) and embedded via el0_shell_image.S's `.incbin`, the same
// mechanism el0_test_image.S already established. Otherwise an exact
// duplicate of examples/el0_elf_load/el0_elf_load.tkb -- the two files
// differ only in which image-accessor extern they `use` and in the
// literal argv[0] bytes app_main constructs ("sh\0" here, so busybox's
// own argv[0]-basename applet dispatch resolves to its `sh` applet,
// instead of "prog\0", which intentionally matches no real applet at
// all in el0_elf_load's own echo-test binary). Kept as a duplicate
// rather than a shared module for now, matching this repo's own stated
// "extract once a third needs the same policy" practice -- worth
// revisiting now that a third real consumer of this loader logic
// exists, but not attempted here to avoid destabilizing
// el0_elf_load.tkb's own already-verified echo-test regression coverage
// while landing this file.
//
// Fed "echo hi\nexit 0\n" over stdin (this file's own .stdin), proving
// GitHub issue #156's actual stated goal end to end on real hardware:
// self-relocation, musl startup, real BUILTIN command execution
// (echo), and a clean exit(0) reclaimed through this kernel's real
// hvc-based process teardown -- not just "the loader doesn't crash."
//
// RPi3-only, same reasons as examples/el0_smoke.

use "examples/vm_page_map/vm_page_map_core.tkb";
use "examples/common_rpi3/el0_asm_extern.tkb";
use "examples/common_rpi3/el1_asm_extern.tkb";
use "examples/common_rpi3/hvc_asm_extern.tkb";
use "examples/common_rpi3/el0_shell_image_extern.tkb";
// GitHub issue #157: pulls in examples/common/fat12.tkb (transitively,
// via this adapter's own `use`) and examples/common_rpi3/usb_msc.tkb --
// the same real USB-Mass-Storage-backed FAT12 driver
// examples/fatfs_sdcard/fatfs_sdcard.tkb already proved on this board
// (GitHub issue #145), reused as-is rather than rebuilt.
use "examples/common_rpi3/fat12_usbmsc.tkb";

const SYSCALL_ERROR: usize = 0xFFFFFFFFFFFFFFFF;
// -ENOTTY as usize (Linux errno 25), the real kernel ABI convention this
// loader already follows for SYSCALL_ERROR (-1) above: a syscall's error
// return is -errno reinterpreted as an unsigned 64-bit value.
const ERR_ENOTTY: usize = 0xFFFFFFFFFFFFFFE7;
// -ENOENT as usize (Linux errno 2), same convention -- this kernel has
// no VFS at all, so any REAL (non-empty) pathname genuinely does not
// exist.
const ERR_ENOENT: usize = 0xFFFFFFFFFFFFFFFE;
// -EBADF (errno 9) and -ENFILE (errno 23), same -errno-as-usize
// convention -- GitHub issue #157's own fd-table error paths (a real
// close()/read()/write() on an fd this process never opened, and the
// fd table's own fixed capacity being exhausted).
const ERR_EBADF: usize = 0xFFFFFFFFFFFFFFF7;
const ERR_ENFILE: usize = 0xFFFFFFFFFFFFFFE9;
// This process's fixed, single-process/single-"user" identity (GitHub
// issue #156's own suggested approach for a kernel with no real PID/UID
// concept yet: "can all return fixed values"). PID/TID 0 is reserved
// (kernel/swapper on a real Linux system), so 1 -- not 0 -- for anything
// PID/TID-shaped; UID/GID 0 (root) is fine since there is no privilege
// model to violate yet.
// 8 covers today's el0_test_prog.elf (6 phdrs, static-pie) with headroom;
// GitHub issue #156's real busybox-static target has 7 -- widened from
// the old fixed cap of 4 (which happened to work only because that
// binary's PT_LOAD entries were first) alongside the PIE loader rewrite,
// since a real ET_DYN binary's phdr count is no longer something this
// loader can assume much about.
const MAX_PHDRS: usize = 8;
const PT_LOAD: u32 = 1;
const ET_EXEC: u16 = 2;
const ET_DYN: u16 = 3;

// argv/envp/auxv initial stack layout (GitHub issue #156): reserved at
// the top of the stack page, see its construction in app_main for the
// exact byte-by-byte shape. Widened from the original 128 bytes to fit
// the PIE-specific auxv entries below (AT_PHDR/PHENT/PHNUM/BASE/ENTRY/
// RANDOM/SECURE) a real libc's own self-relocation and TLS setup needs,
// on top of the original AT_PAGESZ/AT_NULL pair -- every real target
// binary is PIE (see el0_test_prog.ld's own comment on why), so this is
// no longer optional scaffolding.
const ARGV_LAYOUT_SIZE: usize = 256;
const AT_PAGESZ: usize = 6;
const AT_PHDR: usize = 3;
const AT_PHENT: usize = 4;
const AT_PHNUM: usize = 5;
const AT_BASE: usize = 7;
const AT_ENTRY: usize = 9;
const AT_SECURE: usize = 23;
const AT_RANDOM: usize = 25;

// cpio (newc) fixed field byte offsets within the 110-byte header --
// verified against a real `cpio -o -H newc` archive's own raw bytes
// (od -A x -t x1z) rather than assumed from documentation alone: c_magic
// "070701" at offset 0, c_filesize's 8 ASCII hex digits at offset 54
// (confirmed reading back exactly the built ELF's real byte count,
// 4744 = 0x1288), c_namesize's at offset 94 (confirmed reading back 18,
// "el0_test_prog.elf\0"'s exact length).
const CPIO_HEADER_SIZE: usize = 110;
const CPIO_FILESIZE_OFFSET: usize = 54;
const CPIO_NAMESIZE_OFFSET: usize = 94;

fn hex_digit(c: u8) -> usize {
    if (c >= 0x30 && c <= 0x39) {
        return (c - 0x30) as usize;
    }
    if (c >= 0x41 && c <= 0x46) {
        return (c - 0x41 + 10) as usize;
    }
    if (c >= 0x61 && c <= 0x66) {
        return (c - 0x61 + 10) as usize;
    }
    // Not a hex digit -- GNU cpio always emits uppercase 0-9A-F, so this
    // only fires on a genuinely malformed header; treated as 0 rather
    // than threading a validity flag through every caller, acceptable
    // for this milestone's trusted embedded archive.
    return 0;
}

fn parse_hex8(base: *u8, offset: usize) -> usize {
    let mut v: usize = 0;
    for i: usize in 0..<8 {
        v = (v << 4) | hex_digit(base[(offset + i) as isize]);
    }
    return v;
}

struct packed Elf64Header {
    e_ident: [u8; 16];
    e_type: u16;
    e_machine: u16;
    e_version: u32;
    e_entry: u64;
    e_phoff: u64;
    e_shoff: u64;
    e_flags: u32;
    e_ehsize: u16;
    e_phentsize: u16;
    e_phnum: u16;
    e_shentsize: u16;
    e_shnum: u16;
    e_shstrndx: u16;
}

struct packed Elf64ProgramHeader {
    p_type: u32;
    p_flags: u32;
    p_offset: u64;
    p_vaddr: u64;
    p_paddr: u64;
    p_filesz: u64;
    p_memsz: u64;
    p_align: u64;
}

private let mut el1_stack: [u8; 4096] align(16);
private let mut el0_entry_va: usize;
private let mut el0_page_va: usize;
private let mut el0_region_size: usize;
private let mut el0_stack_top_va: usize;

// A real process needs real heap growth for malloc to work at all (every
// other builtin indirectly depends on it -- GitHub issue #156's own
// "needs real (if simple) implementation" list). Rather than support
// truly dynamic mapping (process_address_space_map only ever maps its
// whole contiguous region once, up front -- extending an already-live
// ProcessAddressSpace is not implemented), this loader reserves a fixed
// HEAP_PAGES-sized region as part of that SAME up-front mapping, right
// after the stack page, and serves both brk() and anonymous mmap()
// (empirically discovered also needed: musl's mallocng allocator uses
// mmap for some allocations, not just brk, a real hardware finding
// beyond issue #156's own original strace research) by bump-allocating
// within it. Never reclaimed (no munmap support) -- acceptable for this
// milestone's single, short-lived process, the same "prove the
// mechanism first" scope every other Stage 1/2 syscall here has had.
const HEAP_PAGES: usize = 128;
private let mut el0_heap_start: usize;
private let mut el0_heap_limit: usize;
private let mut el0_heap_break: usize;

// A first, minimal formalization of "process state" (GitHub issue #153):
// previously the exit syscall just printed a fixed string and parked,
// with the process's own real exit status (x0 at the exit() call, per
// the same convention Linux itself uses) discarded. Recording it as a
// typed outcome, instead of a bare printed string, is a first step
// toward a real process control block -- there is still only ever one
// process, no PID, no parent/child, and Exited is currently a dead end
// (see the note on process_outcome_report below for why resource
// reclamation cannot go further yet). Kept as a local value, not a
// persistent global: a bare global cannot hold a variant in this
// language's current Slice 3 (a real process TABLE queryable after the
// fact -- e.g. by a future parent's wait() -- will need the same stable
// owner slot protocol examples/copy_on_write's own CowStateStore already
// established, not a plain global).
variant ProcessOutcome {
    Running;
    Exited(usize);
}

fn process_outcome_report(outcome: ProcessOutcome) {
    match outcome {
        ProcessOutcome::Running => {
            uart_puts("process still running\n");
        }
        ProcessOutcome::Exited(status) => {
            uart_puts("process exited with status ");
            uart_print(status);
            uart_puts("\n");
        }
    }
}

// Still needed for the genuine load-FAILURE paths below (ELF/segment
// parsing rejected): no process will ever run at EL0 in those cases, so
// there is nothing for a later hvc-triggered teardown to reclaim --
// immediate abandonment (the same sink-and-discard idiom as
// vm_page_map_core.tkb's own cpu_owner_halt) is still the correct, final
// disposition there, not a use of the new process_vm_put/take slot below
// (which is reserved for the one bundle that actually becomes a running
// process).
fn el0_pas_abandon(pas: sink ProcessAddressSpace[asid]) {}
fn el0_active_abandon(active: sink ActiveAddressSpace[core, asid]) {}

// GitHub issue #154: a stable owner slot (same protocol as
// examples/copy_on_write's own CowStateStore/stable_replace) holding this
// process's VM resources across the EL2->EL1->EL0 drop, so exit() -- which
// only ever runs at EL1/EL0 -- can trigger their REAL reclamation at EL2
// via the new hvc call boundary (examples/common_rpi3/hvc_asm.S), instead
// of just abandoning them the way this file used to. Unlike CowStateStore,
// this deliberately skips COW's own vacancy-token/reentrancy protocol:
// process_vm_put is called exactly once (at load time, EL2, before the
// drop) and process_vm_take exactly once (at exit time, EL2, triggered by
// the hvc call below) -- strictly sequential, single core, no interrupt
// or concurrent access ever interleaves the two, so the extra ceremony
// COW needs for its own genuinely re-entrant exception-handler access
// would be unearned complexity here.
private linear view ProcessVmGuard[lock: addr];
fn process_vm_guard(lock: *i32 @ place) -> ProcessVmGuard[place] {
    return view ProcessVmGuard[place];
}
fn process_vm_guard_done(guard: sink ProcessVmGuard[place]) {}

// Discards a ProcessVmState wholesale, matching the same "sink parameter
// itself is the discharge" idiom as the old el0_*_abandon functions this
// replaces (see vm_page_map_core.tkb's own cpu_owner_halt for the
// original precedent). Only ever reached if process_vm_put ran while the
// slot was NOT already Empty, which the one-put-one-take sequencing above
// should make unreachable in practice -- a real bug there would silently
// leak the previous bundle rather than fail loudly, the same risk profile
// the old abandon functions already had.
fn process_vm_state_discard(state: sink ProcessVmState) {}

variant ProcessVmState {
    Empty;
    Loaded(exists core: usize. exists asid: usize.
           (ProcessAddressSpace[asid], ActiveAddressSpace[core, asid]));
    // GitHub issue #158's real fork(): the PARENT's own state while its
    // one child runs. fork()'s own hvc handling below switches TTBR0_EL2
    // to the child, which consumes the parent's ActiveAddressSpace (that
    // token specifically proves "this asid is the CURRENTLY installed
    // one", which becomes false the instant the switch happens) --
    // leaving only its ProcessAddressSpace, still fully valid and never
    // torn down, just not the hardware's active root right now.
    // process_address_space_switch (vm_page_map_core.tkb) re-activates
    // it once the child exits.
    Suspended(exists asid: usize. ProcessAddressSpace[asid]);
}

struct ProcessVmStateStore {
    private lock: i32;
    private state: ProcessVmState;
}
private let mut process_vm_store: ProcessVmStateStore;

fn process_vm_put(next: ProcessVmState) {
    let guard = process_vm_guard(&process_vm_store.lock);
    let previous: ProcessVmState = stable_replace(
        guard, &process_vm_store.lock, process_vm_store.state, next);
    process_vm_guard_done(guard);
    process_vm_state_discard(previous);
}

fn process_vm_take() -> ProcessVmState {
    let guard = process_vm_guard(&process_vm_store.lock);
    let state: ProcessVmState = stable_replace(
        guard, &process_vm_store.lock, process_vm_store.state, ProcessVmState::Empty);
    process_vm_guard_done(guard);
    return state;
}

// GitHub issue #158's real fork(): a SECOND ProcessVmStateStore, for the
// one child this milestone's own scope ever allows at a time. Distinct
// lifecycle from process_vm_store above (created at fork(), torn down at
// the child's own exit()/execve(), not the shell's own) -- a separate
// top-level global of the SAME type, the same "more than one instance of
// a stable owner struct, each its own independent global" idiom
// fat_fd_slot_stdin already uses alongside fat_fd_table.
private let mut child_vm_store: ProcessVmStateStore;

fn child_vm_put(next: ProcessVmState) {
    let guard = process_vm_guard(&child_vm_store.lock);
    let previous: ProcessVmState = stable_replace(
        guard, &child_vm_store.lock, child_vm_store.state, next);
    process_vm_guard_done(guard);
    process_vm_state_discard(previous);
}

fn child_vm_take() -> ProcessVmState {
    let guard = process_vm_guard(&child_vm_store.lock);
    let state: ProcessVmState = stable_replace(
        guard, &child_vm_store.lock, child_vm_store.state, ProcessVmState::Empty);
    process_vm_guard_done(guard);
    return state;
}

// The suspended parent's own full 272-byte register frame (x0-x30, ELR,
// SPSR), saved by hvc_dispatch_fork below (EL2, the only level allowed to
// touch TTBR0_EL2) at the moment of fork(), and restored via
// rpi3_el0_resume_frame (examples/common_rpi3/el0_asm.S) once the child
// exits. Plain bytes, not a stable owner slot -- nothing about this
// buffer's own content is linearly tracked, and this milestone's own
// single-child-at-a-time scope means at most one is ever live.
private let mut parent_saved_frame: [u8; 272] align(16);
// Set by el0_svc_dispatch's own clone(220) arm (EL1, which has the real
// frame_sp value from its own 7th argument) immediately before issuing
// rpi3_hvc_call, since ordinary global memory crosses the EL1->EL2 hvc
// boundary freely (unlike TTBR0_EL2 itself, plain data access needs no
// extra privilege) -- see hvc_asm.S's own comment for why the hvc ABI
// itself only ever carries one bare opcode in `arg`, not a real payload.
private let mut pending_frame_sp: usize;
// Whether the one child this milestone allows currently exists (fork()
// succeeded, its own exit()/execve()-teardown has not yet run). Checked
// by el0_svc_dispatch's own exit()/execve() arms to decide "am I the
// child (tear down + resume the suspended parent) or the original
// process (park/load as before)" -- a smaller fact EL1-side Takibi code
// needs directly, without re-deriving it from which asid TTBR0_EL2
// happens to hold right now.
private let mut fork_child_running: bool = false;
// The shell itself is always "PID" 1 (GitHub issue #156's own fixed-
// identity stance, no real allocation). This milestone's single child is
// always exactly PID 2 -- never allocated, since only one child ever
// exists at a time.
const FORK_CHILD_PID: usize = 2;
// The child's own real exit() status (x0 at its own exit call, Linux's
// own convention), recorded by exit()'s own child-branch below so
// wait4() (once the parent resumes) can report the real $? instead of a
// stub value.
private let mut child_exit_status: usize = 0;

// GitHub issue #158's real per-page copy-on-write table: exactly one
// linear token per page currently shared between the parent and its one
// child, an array of stable owner slots (OWNERSHIP_KERNEL.md #131/#132,
// implemented against this exact need -- fat_fd_table above is the
// smaller-scale proof this same compiler feature already works).
// Deliberately simpler than examples/copy_on_write's own
// ReadOnlyLease[p,0]/[p,1] split/join pair: THIS kernel resolves EITHER
// side's divergence -- a real write fault, or (far more commonly, per
// issue #156's own strace research showing execve() follows fork() with
// no intervening writes) the child's own teardown finding a page it
// never touched -- by directly rewriting BOTH sides' page tables in the
// SAME step, since this is kernel code with authority over both
// mappings at once, not two independent unprivileged processes that
// must each release their own half asynchronously. One linear token is
// therefore enough to prove "this page is still genuinely double-
// mapped"; ReadOnlyLease's own two-token split/join shape exists to
// support the asymmetric release ordering this milestone's own scope (a
// single child, always resolved by the SAME kernel operation) never
// needs.
private linear struct CowSharedPage[p: usize] {
    private index: {0..<PAGE_COUNT as usize};
    private p_witness: usize @ p;
}
fn cow_shared_page_new(index: {0..<PAGE_COUNT as usize}, p_witness: usize @ p)
        -> CowSharedPage[p] {
    let mut share: CowSharedPage[p] = { index, p_witness };
    return share;
}
fn cow_shared_page_index(share: borrow CowSharedPage[p]) -> {0..<PAGE_COUNT as usize} {
    return share.index;
}
fn cow_shared_page_discard(share: sink CowSharedPage[p]) {}

variant CowPageState {
    Private;
    Shared(exists p: usize. CowSharedPage[p]);
}
struct CowPageSlot {
    private lock: i32;
    private state: CowPageState;
}
private let mut cow_page_table: [CowPageSlot; MAX_PROCESS_PAGES];

private linear view CowPageGuard[lock: addr];
fn cow_page_guard(lock: *i32 @ place) -> CowPageGuard[place] {
    return view CowPageGuard[place];
}
fn cow_page_guard_done(guard: sink CowPageGuard[place]) {}
fn cow_page_state_discard(state: sink CowPageState) {}

fn cow_page_put(i: {0..<MAX_PROCESS_PAGES as usize}, next: CowPageState) {
    let guard = cow_page_guard(&cow_page_table[i].lock);
    let previous: CowPageState = stable_replace(
        guard, &cow_page_table[i].lock, cow_page_table[i].state, next);
    cow_page_guard_done(guard);
    cow_page_state_discard(previous);
}

fn cow_page_take(i: {0..<MAX_PROCESS_PAGES as usize}) -> CowPageState {
    let guard = cow_page_guard(&cow_page_table[i].lock);
    let state: CowPageState = stable_replace(
        guard, &cow_page_table[i].lock, cow_page_table[i].state, CowPageState::Private);
    cow_page_guard_done(guard);
    return state;
}

// Populates cow_page_table for every page process_address_space_cow_fork
// (vm_page_map_core.tkb) just double-mapped read-only -- that function's
// own job is the page-TABLE rewrite; tracking which pages are now shared
// is this file's own bookkeeping, matching that function's own comment.
fn cow_page_table_share_all(parent_slot: {0..<2 as usize}, page_count: usize) {
    for i: usize in 0..<MAX_PROCESS_PAGES {
        if (i >= page_count) { break; }
        let idx_raw: usize = process_phys_index_get(parent_slot, i);
        if (idx_raw < PAGE_COUNT) {
            let idx: {0..<PAGE_COUNT as usize} = idx_raw;
            let share = cow_shared_page_new(idx, idx);
            cow_page_put(i, CowPageState::Shared(share));
        }
    }
}

// Resolves cow_page_table[i]'s Shared state at CHILD teardown time,
// restoring the PARENT's own page back to normal read-write, since after
// this call neither side (the child's own mapping was already unmapped
// separately by the caller) still shares it. The common case -- per
// issue #156's own strace research, execve() follows fork() with no
// intervening writes -- needs no allocation or copy at all: the
// parent's own physical page never actually needed duplicating, only
// its permission bit flipped back.
fn cow_page_resolve_child_teardown(i: {0..<MAX_PROCESS_PAGES as usize},
                                   parent_slot: {0..<2 as usize},
                                   parent_base_va: usize) {
    let state: CowPageState = cow_page_take(i);
    match state {
        CowPageState::Private => {}
        CowPageState::Shared(share) => {
            let idx: {0..<PAGE_COUNT as usize} = cow_shared_page_index(share);
            cow_shared_page_discard(share);
            process_address_space_page_remap(parent_slot, parent_base_va, i, idx, true);
        }
    }
}

// Resolves a REAL write fault on a still-shared page: the faulting side
// gets a freshly allocated, copied private page; the other side (in this
// milestone's own single-child scope, always the suspended parent --
// fork()'s own comment on why the parent never runs concurrently with
// its child) keeps the ORIGINAL physical page, its own permission simply
// flipped back to read-write since it is no longer actually shared
// either. Returns false if `i` was not a currently-shared page at all (a
// genuine, unrelated fault this kernel still does not handle) or if
// allocation failed (put back unresolved for the caller to fail the
// fault).
fn cow_page_resolve_write_fault(i: {0..<MAX_PROCESS_PAGES as usize},
                                fault_slot: {0..<2 as usize}, fault_base_va: usize,
                                other_slot: {0..<2 as usize}, other_base_va: usize) -> bool {
    let state: CowPageState = cow_page_take(i);
    match state {
        CowPageState::Private => {
            return false;
        }
        CowPageState::Shared(share) => {
            let idx: {0..<PAGE_COUNT as usize} = cow_shared_page_index(share);
            cow_shared_page_discard(share);
            match page_alloc() {
                PageAllocResult::OutOfMemory => {
                    let idx2: {0..<PAGE_COUNT as usize} = idx;
                    let share2 = cow_shared_page_new(idx2, idx2);
                    cow_page_put(i, CowPageState::Shared(share2));
                    return false;
                }
                PageAllocResult::Allocated(page) => {
                    let new_idx: {0..<PAGE_COUNT as usize} = page_owner_into_index(page);
                    page_pool_copy(new_idx, idx);
                    process_address_space_page_remap(fault_slot, fault_base_va, i, new_idx, true);
                    process_address_space_page_remap(other_slot, other_base_va, i, idx, true);
                    return true;
                }
            }
        }
    }
}

// Strong override of examples/common_rpi3/hvc_asm.S's weak hvc_dispatch
// default. Runs AT EL2 (el1_hvc_entry calls this via `bl` before eret-ing
// back to EL1, exactly like examples/hvc_smoke's own proof of that
// mechanism) -- this is what finally lets exit()/fork() reach the
// TTBR0_EL2-only operations (unmap_page/address_space_deactivate/COW
// page-table rewrites) that EL1 cannot perform itself. `arg` now IS a
// real argument-decoded operation menu (GitHub issue #158's own second
// real operation, past the point issue #154's own comment here flagged
// as the moment a menu would stop being speculative): 0 = exit/teardown
// the currently running process (unchanged), 1 = fork, 2 = child
// teardown (the child's own exit(), or execve() discarding its whole
// image before loading a new one). Kept as three shallow top-level
// functions, not one deep match, for the same codegen-depth reason
// fat_fd_read/write/close above are their own functions instead of
// inlined into el0_svc_dispatch's own match arms.
fn hvc_dispatch(arg: usize) -> usize {
    if (arg == 1) {
        return hvc_dispatch_fork();
    }
    if (arg == 2) {
        return hvc_dispatch_child_teardown();
    }
    return hvc_dispatch_exit();
}

fn hvc_dispatch_exit() -> usize {
    let state = process_vm_take();
    match state {
        ProcessVmState::Empty => {
            uart_puts("hvc: no process VM state to reclaim\n");
        }
        ProcessVmState::Suspended(pas) => {
            // Unreachable in practice: opcode 0 (plain exit) is only ever
            // issued by the CURRENTLY RUNNING process's own exit()
            // syscall handler, and process_vm_store only holds Suspended
            // while the child (not the parent) is the one running -- see
            // ProcessVmState's own comment. Discharge rather than leak
            // the linear obligation if this is ever reached anyway.
            el0_pas_abandon(pas);
            uart_puts("hvc: unexpected suspended parent at exit\n");
        }
        ProcessVmState::Loaded(bundle) => {
            let (pas, active) = bundle;
            let empty = process_address_space_unmap(pas);
            let inactive = address_space_deactivate(active, empty);
            address_space_free(inactive);
            uart_puts("hvc: process VM reclaimed\n");
        }
    }
    return 0;
}

// GitHub issue #158's real fork(): creates the one child this milestone
// ever allows, COW-sharing every one of the parent's own pages, and
// suspends the parent (saving its full register frame from
// pending_frame_sp, patching its own eventual x0 to FORK_CHILD_PID).
// Reached only via el0_svc_dispatch's own clone(220) arm at EL1, which
// sets pending_frame_sp and issues rpi3_hvc_call(1) before this runs.
fn hvc_dispatch_fork() -> usize {
    let state = process_vm_take();
    match state {
        ProcessVmState::Empty => {
            uart_puts("hvc: fork with no parent VM state\n");
            return 0;
        }
        ProcessVmState::Suspended(pas) => {
            // Unreachable in this milestone's own single-child-at-a-time
            // scope: fork() cannot be issued while a child already
            // exists, since the PARENT (the only thing that could issue
            // another fork()) is not running whenever this state is set.
            process_vm_put(ProcessVmState::Suspended(pas));
            uart_puts("hvc: fork while a child is already suspended\n");
            return 0;
        }
        ProcessVmState::Loaded(bundle) => {
            let (pas, active) = bundle;
            // `active` (TTBR0_EL2 == parent) becomes false the instant
            // address_space_activate below installs the child's own root
            // -- discharge the now-stale token here rather than thread
            // it through unused; the real resource it proved (`pas`) is
            // preserved separately via ProcessVmState::Suspended below.
            el0_active_abandon(active);
            let seed: {0..<2 as usize} = 1;
            let child_inactive = address_space_new(seed);
            let core: usize = 0;
            let (child_empty, child_active0) = address_space_activate(child_inactive, core);
            let (child_pas, child_active) =
                process_address_space_cow_fork(pas, child_empty, child_active0);
            let page_count: usize = process_address_space_page_count(child_pas);
            cow_page_table_share_all(0, page_count);

            let frame_src: *u8 = pending_frame_sp as *u8;
            let frame_dst: *u8 = parent_saved_frame as *u8;
            for i: usize in 0..<272 {
                frame_dst[i as isize] = frame_src[i as isize];
            }
            let x0_ptr: *u64 = frame_dst as *u64;
            *x0_ptr = FORK_CHILD_PID as u64;

            process_vm_put(ProcessVmState::Suspended(pas));
            child_vm_put(ProcessVmState::Loaded((child_pas, child_active)));
            fork_child_running = true;
            uart_puts("hvc: fork ok\n");
        }
    }
    return 0;
}

// GitHub issue #158's real fork(): tears down the CHILD's own address
// space -- reached both by the child's own exit() and by execve()
// discarding its whole image before loading a new one, since both need
// the SAME "this address space's own mappings are done" disposition,
// just with a different next step for the CPU itself afterward (resume
// the parent for exit(); keep running as EL0 with a freshly loaded ELF
// for execve() -- see el0_svc_dispatch's own callers of this opcode).
// Resolves every one of the child's own COW-shared pages (restoring the
// parent's copy to normal read-write) before unmapping the child's own
// L3 entries, then switches TTBR0_EL2 straight back to the suspended
// parent and resumes it via rpi3_el0_resume_frame -- one hardware
// operation (process_address_space_deactivate_to), not deactivate-then-
// separately-reactivate, since the parent's own address space was never
// actually deactivated in the first place (see ProcessVmState::Suspended
// above).
fn hvc_dispatch_child_teardown() -> usize {
    let child_state = child_vm_take();
    match child_state {
        ProcessVmState::Empty => {
            uart_puts("hvc: child teardown with no child VM state\n");
            return 0;
        }
        ProcessVmState::Suspended(pas) => {
            // Unreachable: child_vm_store only ever holds Loaded (the
            // child is the one running whenever this opcode fires) or
            // Empty (already torn down).
            el0_pas_abandon(pas);
            uart_puts("hvc: unexpected suspended child\n");
            return 0;
        }
        ProcessVmState::Loaded(bundle) => {
            let (child_pas, child_active) = bundle;
            let page_count: usize = process_address_space_page_count(child_pas);
            // A guarding `if`, not `break` -- confirmed necessary the
            // hard way: with child_active/child_pas still pending
            // (consumed only after this loop, by
            // process_address_space_deactivate_to/
            // process_address_space_unmap_shared below), the compiler
            // rejected `break` here ("linear value 'child_active' is
            // still pending at this break") even though every actual
            // path still consumes it exactly once. Looping the full
            // MAX_PROCESS_PAGES regardless of page_count is a real but
            // small inefficiency (cow_page_resolve_child_teardown itself
            // is a cheap no-op for any slot never marked Shared), traded
            // for staying inside a flow shape the checker accepts
            // without dispute.
            for i: usize in 0..<MAX_PROCESS_PAGES {
                if (i < page_count) {
                    cow_page_resolve_child_teardown(i, 0, DYN_VA_BASE);
                }
            }
            let child_empty = process_address_space_unmap_shared(child_pas);

            let parent_state = process_vm_take();
            match parent_state {
                ProcessVmState::Suspended(parent_pas) => {
                    let (child_inactive, parent_active) =
                        process_address_space_deactivate_to(
                            child_active, child_empty, parent_pas);
                    address_space_free(child_inactive);
                    process_vm_put(ProcessVmState::Loaded((parent_pas, parent_active)));
                    fork_child_running = false;
                    uart_puts("hvc: child reclaimed\n");
                }
                ProcessVmState::Empty => {
                    // Unreachable alongside child_state's own Loaded arm
                    // above: process_vm_store only goes Empty at the
                    // shell's own final exit(), which cannot happen
                    // while a child is still running. Still a real,
                    // valid disposition if ever reached -- deactivate to
                    // the kernel root exactly like hvc_dispatch_exit's
                    // own normal case does, just with no parent to
                    // switch to instead.
                    let child_inactive2 = address_space_deactivate(child_active, child_empty);
                    address_space_free(child_inactive2);
                    uart_puts("hvc: child teardown with no suspended parent\n");
                }
                ProcessVmState::Loaded(unexpected) => {
                    // Unreachable alongside child_state's own Loaded arm:
                    // process_vm_store cannot ALSO be Loaded (the parent
                    // actively running) while child_vm_store is Loaded
                    // too (the child actively running) -- this
                    // milestone's own single-core cooperative scope never
                    // runs both at once. Put the unexpected bundle back
                    // untouched and dispose of the child's own resources
                    // the same way the other unreachable arm above does.
                    process_vm_put(ProcessVmState::Loaded(unexpected));
                    let child_inactive3 = address_space_deactivate(child_active, child_empty);
                    address_space_free(child_inactive3);
                    uart_puts("hvc: unexpected loaded parent at child teardown\n");
                }
            }
        }
    }
    return 0;
}

// GitHub issue #157: a small, fixed-size per-process file descriptor
// table -- a plain array of stable owner slots, the same shape
// process_vm_store above already established (lock + stable_replace,
// not a dynamic allocator), just generalized from one slot to
// MAX_OPEN_FILES so more than one real file can be open at once. fd
// numbers 0/1/2 stay the UART (unchanged, see el0_svc_dispatch below);
// fd FIRST_FILE_FD.. map onto this table by simple subtraction, no
// separate fd-to-slot indirection needed since this process never
// dup()s or closes-then-reopens a lower fd.
const MAX_OPEN_FILES: usize = 4;
const FIRST_FILE_FD: usize = 3;

variant FatFdState {
    Empty;
    Open(exists file: usize. FatFile[file]);
}

struct FatFdSlot {
    private lock: i32;
    private state: FatFdState;
}
// A REAL array of stable owner slots (OWNERSHIP_KERNEL.md #131/#132,
// implemented against this exact need): each element is its own
// independently stable_replace-able slot, addressed by a runtime index.
// This used to be four separate top-level globals (fat_fd_slot0..3) plus
// a hand-written if-chain, because the compiler did not yet support a
// stable owner slot living inside an array. Now that it does, this is
// what MAX_PROCESS_PAGES-scale COW tracking further down this file also
// relies on -- proven here first, at this file's own smaller, already-
// working 4-entry scale.
private let mut fat_fd_table: [FatFdSlot; MAX_OPEN_FILES];

private linear view FatFdGuard[lock: addr];
fn fat_fd_guard(lock: *i32 @ place) -> FatFdGuard[place] {
    return view FatFdGuard[place];
}
fn fat_fd_guard_done(guard: sink FatFdGuard[place]) {}

// Only ever reached with a genuinely Empty previous state -- every call
// site below only ever puts into a slot it (or fat_fd_take, right
// before it) just observed empty, same reasoning as
// process_vm_state_discard above.
fn fat_fd_state_discard(state: sink FatFdState) {}

fn fat_fd_put(slot: {0..<MAX_OPEN_FILES as usize}, next: FatFdState) {
    let guard = fat_fd_guard(&fat_fd_table[slot].lock);
    let previous: FatFdState = stable_replace(
        guard, &fat_fd_table[slot].lock, fat_fd_table[slot].state, next);
    fat_fd_guard_done(guard);
    fat_fd_state_discard(previous);
}

fn fat_fd_take(slot: {0..<MAX_OPEN_FILES as usize}) -> FatFdState {
    let guard = fat_fd_guard(&fat_fd_table[slot].lock);
    let state: FatFdState = stable_replace(
        guard, &fat_fd_table[slot].lock, fat_fd_table[slot].state, FatFdState::Empty);
    fat_fd_guard_done(guard);
    return state;
}

variant FatOpenFdResult {
    Fd(usize);
    Error(usize);
}

// Collapses FatOpenFdResult to the one usize el0_svc_dispatch actually
// returns either way (a real fd, or a real -errno -- Linux's own single-
// register convention already treats those the same way). Written as
// its own top-level function, NOT a `match` inlined directly inside
// another match arm that already bound an existential FatFile[file] --
// confirmed necessary the hard way: nesting a second `match` inside a
// match arm that binds an existential payload crashed this compiler's
// own codegen (an internal `Not_found` in its enum_variants_tbl lookup).
// examples/fatfs_sdcard/fatfs_sdcard.tkb's own `FatOpenResult::Opened(fp)
// => { ...fat_io_ok(fat_read(...))... }` already avoids this same shape
// by calling a boolean helper instead of matching inline -- this is the
// same fix, generalized to a value instead of a bool.
fn fat_open_fd_result_value(r: FatOpenFdResult) -> usize {
    match r {
        FatOpenFdResult::Fd(fd) => { return fd; }
        FatOpenFdResult::Error(err) => { return err; }
    }
}

// A local restatement of fat12.tkb's own fat_io_ok. Confirmed via
// real-hardware... rather, real-compiler trial: calling `fat_io_ok`
// (or this identically-shaped local copy) from FOUR levels deep inside
// el0_svc_dispatch's own `match syscall_num` arm (if fd >= .. { if slot
// < .. { match state { Open(file) => { ... here ... } } } }) crashed
// this compiler's own codegen either way (an invalid `zext { i32, i32 }
// to i64` trying to coerce FatIoResult's own struct representation into
// the callee's parameter type) -- so the actual trigger is nesting
// depth inside one giant function, not which function gets called. The
// real fix (see fat_fd_read/fat_fd_write/fat_fd_close below) is pulling
// that whole body out into its own top-level function, the same
// "coarsest thing that fixes it" response as this codebase's own
// %zext/match-in-existential-arm bugs found earlier in this same
// change. This helper stays -- it's genuinely useful once nesting is
// shallow again -- but is no longer the fix by itself.
fn fat_io_result_ok(r: FatIoResult) -> bool {
    match r {
        FatIoResult::Ok => { return true; }
        FatIoResult::Err(err) => { return false; }
    }
}

// GitHub issue #157: the actual fd>=3 read/write/close bodies, pulled
// out of el0_svc_dispatch's own match arms into their own top-level
// functions -- see fat_io_result_ok's comment above for why (a real
// compiler codegen limit on how deeply nested one function's control
// flow can get, discovered via this exact code). Each takes an already-
// narrowed `slot` so fat_fd_take/fat_fd_put's own {0..<MAX_OPEN_FILES}
// parameter stays satisfied without re-deriving the narrowing here.
fn fat_fd_read(slot: {0..<MAX_OPEN_FILES as usize}, buf: *u8, len: u32) -> usize {
    let state: FatFdState = fat_fd_take(slot);
    match state {
        FatFdState::Empty => {
            return ERR_EBADF;
        }
        FatFdState::Open(mut file) => {
            let mut br: u32 = 0;
            let result: FatIoResult = fat_read(file, buf, len, &br);
            fat_fd_put(slot, FatFdState::Open(file));
            if (fat_io_result_ok(result) == true) {
                return br as usize;
            }
            return SYSCALL_ERROR;
        }
    }
}

fn fat_fd_write(slot: {0..<MAX_OPEN_FILES as usize}, buf: *u8, len: u32) -> usize {
    let state: FatFdState = fat_fd_take(slot);
    match state {
        FatFdState::Empty => {
            return ERR_EBADF;
        }
        FatFdState::Open(mut file) => {
            let mut bw: u32 = 0;
            let result: FatIoResult = fat_write(file, buf, len, &bw);
            fat_fd_put(slot, FatFdState::Open(file));
            if (fat_io_result_ok(result) == true) {
                return bw as usize;
            }
            return SYSCALL_ERROR;
        }
    }
}

// close() on a slot that is already Empty returns success (0), not
// ERR_EBADF -- confirmed necessary via a real strace of this exact
// busybox binary running `read var < file` (see fat_dup3_stdin below):
// ash's own redirection machinery calls close() on an fd it just
// dup3()ed AWAY from (the slot's content already moved elsewhere, so
// the slot is legitimately, expectedly Empty at this point, not a
// double-close bug) and does not appear to check close()'s return
// value either way -- but reporting a spurious EBADF here for a
// perfectly ordinary redirection cleanup step is still wrong on its own
// terms, not just harmless.
fn fat_fd_close(slot: {0..<MAX_OPEN_FILES as usize}) -> usize {
    let state: FatFdState = fat_fd_take(slot);
    match state {
        FatFdState::Empty => {
            return 0;
        }
        FatFdState::Open(file) => {
            let close_result: FatIoResult = fat_close(file);
            if (fat_io_result_ok(close_result) == true) {
                return 0;
            }
            return SYSCALL_ERROR;
        }
    }
}

// GitHub issue #157's own follow-on, discovered necessary via a real
// strace of this exact busybox binary (not predicted by issue #156's
// own strace research, which never exercised file redirection): ash's
// `read var < file` does NOT read the newly openat()ed fd directly --
// it dup3()s it onto fd 0 first (after saving the real original stdin
// via fcntl(0, F_DUPFD_CLOEXEC, N) to restore later), then reads fd 0
// as usual. Without this, `read var < file` hung forever (this kernel's
// own genuinely-unhandled-syscall path -- see el0_svc_dispatch's `_`
// wildcard arm -- jumps to ELR 0, a silent fault with no further UART
// output, exactly what real-hardware testing showed before this was
// added). One dedicated stable slot (the same lock+stable_replace shape
// as fat_fd_table above, just a bare global instead of an array element
// since there is only ever one), not a 5th numbered fd slot: fd 0 itself
// is what gets redirected, not a new fd number.
private let mut fat_fd_slot_stdin: FatFdSlot;

fn fat_stdin_put(next: FatFdState) {
    let guard = fat_fd_guard(&fat_fd_slot_stdin.lock);
    let previous: FatFdState = stable_replace(
        guard, &fat_fd_slot_stdin.lock, fat_fd_slot_stdin.state, next);
    fat_fd_guard_done(guard);
    fat_fd_state_discard(previous);
}

fn fat_stdin_take() -> FatFdState {
    let guard = fat_fd_guard(&fat_fd_slot_stdin.lock);
    let state: FatFdState = stable_replace(
        guard, &fat_fd_slot_stdin.lock, fat_fd_slot_stdin.state, FatFdState::Empty);
    fat_fd_guard_done(guard);
    return state;
}

fn fat_stdin_is_open() -> bool {
    let state: FatFdState = fat_stdin_take();
    match state {
        FatFdState::Empty => {
            return false;
        }
        FatFdState::Open(file) => {
            fat_stdin_put(FatFdState::Open(file));
            return true;
        }
    }
}

// Returns >= 0 (the real byte count, matching read()'s own return
// value) when fd 0 is currently redirected to a real file, or -1 when
// it is not (the caller falls back to the ordinary UART path). -2 is a
// genuine fat_read() I/O error.
fn fat_stdin_read(buf: *u8, len: u32) -> i32 {
    let state: FatFdState = fat_stdin_take();
    match state {
        FatFdState::Empty => {
            return -1;
        }
        FatFdState::Open(mut file) => {
            let mut br: u32 = 0;
            let result: FatIoResult = fat_read(file, buf, len, &br);
            fat_stdin_put(FatFdState::Open(file));
            if (fat_io_result_ok(result) == true) {
                return br as i32;
            }
            return -2;
        }
    }
}

// dup3(oldfd, 0, flags)'s two real dispositions, each its own top-level
// function for the same reason fat_fd_read/write/close above are --
// keeping fat_dup3_stdin itself shallow (see its own comment).
fn fat_dup3_redirect_stdin(slot: {0..<MAX_OPEN_FILES as usize}) -> usize {
    let state: FatFdState = fat_fd_take(slot);
    match state {
        FatFdState::Empty => {
            return ERR_EBADF;
        }
        FatFdState::Open(file) => {
            fat_stdin_put(FatFdState::Open(file));
            return 0;
        }
    }
}

fn fat_dup3_restore_stdin() -> usize {
    let state: FatFdState = fat_stdin_take();
    match state {
        FatFdState::Empty => {
            return 0;
        }
        FatFdState::Open(file) => {
            fat_close(file);
            return 0;
        }
    }
}

// oldfd >= FIRST_FILE_FD and a live table slot: redirect stdin to that
// real file. Anything else (this shell's own saved-original-stdin
// pseudo-fd from fcntl(F_DUPFD_CLOEXEC) below, which this kernel never
// actually allocates real storage for -- see that syscall arm's own
// comment) restores stdin to the UART. Kept to two nested `if`s, not
// three -- the same shallow-function split fat_fd_read/write/close
// above already needed, confirmed necessary the same way (see
// fat_io_result_ok's own comment on the codegen limit this works
// around).
fn fat_dup3_stdin(oldfd: usize) -> usize {
    if (oldfd >= FIRST_FILE_FD) {
        let slot: usize = oldfd - FIRST_FILE_FD;
        if (slot < MAX_OPEN_FILES) {
            let s: {0..<MAX_OPEN_FILES as usize} = slot;
            return fat_dup3_redirect_stdin(s);
        }
    }
    return fat_dup3_restore_stdin();
}

// Finds the first empty slot at or after `slot`, recursing forward one
// slot at a time -- the same take/inspect/put-back-if-not-mine shape as
// cow_state_put's own retry recursion above, generalized from "retry the
// same cell" to "try the next cell", so `file`'s own linear ownership
// always has exactly one clear disposition at every step (stored, handed
// to the next call, or closed at the table-full base case) instead of a
// loop where whether `file` gets touched varies by iteration.
fn fat_fd_store(slot: usize, file: FatFile[file]) -> FatOpenFdResult {
    // Positive-branch narrowing, not a negated `if (slot >= MAX) {
    // return; }` early exit -- this codebase's own if-narrowing is
    // strictly scoped to the then-branch (see e.g. this file's own
    // total_pages/process_address_space_map comment above), so an
    // early-return guard would NOT leave `slot` narrowed for
    // fat_fd_take/fat_fd_put's own {0..<MAX_OPEN_FILES} parameter below.
    if (slot < MAX_OPEN_FILES) {
        let s: {0..<MAX_OPEN_FILES as usize} = slot;
        let state: FatFdState = fat_fd_take(s);
        match state {
            FatFdState::Empty => {
                fat_fd_put(s, FatFdState::Open(file));
                return FatOpenFdResult::Fd(FIRST_FILE_FD + slot);
            }
            FatFdState::Open(existing) => {
                fat_fd_put(s, FatFdState::Open(existing));
                return fat_fd_store(slot + 1, file);
            }
        }
    }
    fat_close(file);
    return FatOpenFdResult::Error(ERR_ENFILE);
}

fn to_upper_ascii(c: u8) -> u8 {
    if (c >= 0x61 && c <= 0x7A) { // 'a'..'z'
        return c - 0x20;
    }
    return c;
}

// Max pathname bytes el0_svc_dispatch will ever scan for openat/
// newfstatat -- generous for this root-directory-only FAT12 driver's own
// 8.3-name ceiling, and small enough to bound-check as one fixed window
// the same way writev/ppoll's own arrays are bounded above.
const PATH_MAX_CHECK: usize = 64;

// Converts a NUL-terminated EL0 pathname into fat12.tkb's own 11-byte
// 8.3 name83 form (space-padded, uppercased -- FAT is case-insensitive,
// real Unix filenames usually are not, so folding case here is what
// makes e.g. `cat cat.txt` actually find a name83 this driver stored as
// upper case). A single leading '/' is stripped (this shell's cwd is
// always '/', GitHub issue #156's own scope) but any FURTHER '/', a
// name or extension component longer than 8/3 bytes, or a completely
// empty name all report false rather than guessing -- fat12.tkb's own
// root-directory-only scope (its header comment) never supported
// subdirectories, so a path this driver cannot represent must be a
// real ENOENT, not a best-effort truncation.
fn path_to_name83(path: *u8, out: *u8) -> bool {
    let mut p: usize = 0;
    if (path[0] == 0x2F) { // '/'
        p = 1;
    }
    for i: usize in 0..<11 {
        out[i as isize] = 0x20; // ' '
    }
    let mut name_len: usize = 0;
    let mut ext_len: usize = 0;
    let mut in_ext: bool = false;
    let mut ok: bool = true;
    while (ok == true && p < PATH_MAX_CHECK && path[p as isize] != 0) {
        let c: u8 = path[p as isize];
        if (c == 0x2F) { // '/'
            ok = false;
        } else if (c == 0x2E) { // '.'
            if (in_ext == true) {
                ok = false;
            } else {
                in_ext = true;
            }
        } else if (in_ext == true) {
            if (ext_len >= 3) {
                ok = false;
            } else {
                out[(8 + ext_len) as isize] = to_upper_ascii(c);
                ext_len = ext_len + 1;
            }
        } else {
            if (name_len >= 8) {
                ok = false;
            } else {
                out[name_len as isize] = to_upper_ascii(c);
                name_len = name_len + 1;
            }
        }
        p = p + 1;
    }
    if (ok == false || name_len == 0) {
        return false;
    }
    return true;
}

// Same policy as examples/el0_smoke's own el0_svc_dispatch, validated
// against el0_page_va (the one page this loader ever maps) instead of
// el0_entry_va (this file's e_entry need not be the first byte of the
// first segment, even though today's test program happens to make them
// equal).
//
// exit()'s real status (x0) is now recorded and reported, AND its VM
// resources are now really reclaimed -- rpi3_hvc_call below traps up to
// EL2 and runs hvc_dispatch above, which is what el0_mapping_abandon and
// friends used to just silently discard.
// GitHub issue #157's own follow-on: a software RX ring, much deeper
// than PL011's own small hardware FIFO, drained opportunistically on
// EVERY syscall entry below (not just read()/ppoll() on fd 0).
// Confirmed necessary via real hardware testing: once a real file-
// redirect episode (openat/fcntl/dup3/read x11/dup3/close for
// `read var < CAT.TXT`, see fat_dup3_stdin above) started taking enough
// real EL0<->EL1 round trips, whatever stdin bytes had already arrived
// over the wire (this test harness sends the whole stdin script in one
// burst, see run_hw_test_rpi3_stdin) silently overran the hardware
// FIFO while nothing was polling it during that episode -- observed as
// a chunk of script bytes vanishing with no error at the point they
// were lost, instead surfacing much later as a `for` loop's own `do`
// token arriving with no matching `for` (GitHub issue #156's own
// PL011-FIFO fix already covers the SMALL, momentary gaps an
// interactive typist leaves; it was never sized for "a whole script's
// worth of bytes may arrive while this kernel is legitimately busy
// doing something else entirely"). uart_rx_ready()/uart_isr_getc()
//(examples/common_rpi3/uart.tkb) stay the only real hardware access
// point; everything else in this file goes through the ring below
// instead from here on.
const UART_RX_RING_SIZE: usize = 512;
private let mut uart_rx_ring: [u8; UART_RX_RING_SIZE];
private let mut uart_rx_ring_head: usize;
private let mut uart_rx_ring_tail: usize;
private let mut uart_rx_ring_count: usize;

fn uart_rx_ring_drain() {
    let ring: *u8 = uart_rx_ring as *u8;
    while (uart_rx_ready() == true && uart_rx_ring_count < UART_RX_RING_SIZE) {
        let c: u8 = uart_isr_getc();
        ring[uart_rx_ring_head as isize] = c;
        uart_rx_ring_head = uart_rx_ring_head + 1;
        if (uart_rx_ring_head >= UART_RX_RING_SIZE) {
            uart_rx_ring_head = 0;
        }
        uart_rx_ring_count = uart_rx_ring_count + 1;
    }
}

fn uart_rx_ring_ready() -> bool {
    return uart_rx_ring_count > 0;
}

fn uart_rx_ring_getc() -> u8 {
    let ring: *u8 = uart_rx_ring as *u8;
    let c: u8 = ring[uart_rx_ring_tail as isize];
    uart_rx_ring_tail = uart_rx_ring_tail + 1;
    if (uart_rx_ring_tail >= UART_RX_RING_SIZE) {
        uart_rx_ring_tail = 0;
    }
    uart_rx_ring_count = uart_rx_ring_count - 1;
    return c;
}

// frame_sp (GitHub issue #158): this trap's own 272-byte saved register
// frame base address, now passed by examples/common_rpi3/el0_asm.S's
// el0_sync_entry as a 7th argument (x6) -- see that file's own comment
// on why fork() needs it. Unused by any syscall arm below except 220
// (clone/fork).
fn el0_svc_dispatch(esr: usize, syscall_num: usize, x0: usize, x1: usize,
                    x2: usize, elr: usize, frame_sp: usize) -> (usize, usize) {
    let ec: usize = (esr >> 26) & 0x3F;
    if (ec != 0x15) {
        return (0, 0);
    }
    uart_rx_ring_drain();
    // A single match over syscall_num (GitHub issue #156), not a chain of
    // `if (syscall_num == N || syscall_num == M) {...}` checks: several
    // syscalls sharing one handler are written as one `N | M => {...}`
    // OR-pattern arm (this language's own newly-added match extension,
    // mirroring OCaml's/Rust's pattern alternation) instead of factoring
    // the shared body into a helper function -- deliberately, since a
    // shared helper tends to accumulate divergent per-caller variants
    // over time until it cannot really stay shared. The `_` wildcard
    // arm's `return (0, 0)` is what a genuinely unimplemented syscall
    // still falls into, matching a real kernel's own fatal-if-truly-
    // unhandled behavior (see el0_asm.S's rpi3_exception_unhandled).
    match syscall_num {
        63 => {
            // read(fd, buf, len) -- GitHub issue #153's third and last
            // Stage 1 syscall. Same buffer validation as write() below.
            // Real short-read semantics (GitHub issue #156): blocks
            // (spins on uart_rx_ready(), the same busy-wait idiom
            // uart_putc's own TX path already uses) until AT LEAST one
            // byte is ready, then drains whatever is CURRENTLY available
            // up to `len` and returns immediately -- matching POSIX
            // read()'s own "return as soon as any data is ready"
            // behavior, not waiting for the full request to fill. Needed
            // for a real interactive shell's own line-buffered read() (a
            // large requested length that would otherwise never be
            // satisfied by a short human-typed line) to ever return at
            // all -- confirmed empirically: busybox-static's own "sh"
            // applet reaches exactly this call and blocks correctly
            // waiting for real input (see this issue's own progress
            // notes).
            let fd: usize = x0;
            let buf: usize = x1;
            let len: usize = x2;
            if (buf < el0_page_va || len > el0_region_size) {
                return (elr, SYSCALL_ERROR);
            }
            if (buf - el0_page_va > el0_region_size - len) {
                return (elr, SYSCALL_ERROR);
            }
            // GitHub issue #157: fd >= FIRST_FILE_FD is a real fat_open()ed
            // file, dispatched through the fd table instead of the UART
            // path below. fat_read only ever borrows its FatFile (see
            // fat12.tkb's own signature), so `file` is still ours to put
            // back afterward, same take/use/put shape as fat_fd_store's
            // own slot lookups above.
            if (fd >= FIRST_FILE_FD) {
                let slot: usize = fd - FIRST_FILE_FD;
                if (slot < MAX_OPEN_FILES) {
                    let s: {0..<MAX_OPEN_FILES as usize} = slot;
                    let dst2: *u8 = buf as *u8;
                    return (elr, fat_fd_read(s, dst2, len as u32));
                }
                return (elr, SYSCALL_ERROR);
            }
            if (fd != 0) {
                return (elr, SYSCALL_ERROR);
            }
            let dst: *u8 = buf as *u8;
            // fd 0 may be dup3()ed onto a real file (fat_dup3_stdin
            // above) -- checked first, falling back to the ordinary UART
            // path below only when it is not, matching the same "no
            // real redirection state = UART" default this loader has
            // always had.
            let stdin_result: i32 = fat_stdin_read(dst, len as u32);
            if (stdin_result >= 0) {
                return (elr, stdin_result as usize);
            }
            // Through the software RX ring (see its own comment above),
            // not uart_rx_ready()/uart_isr_getc() directly -- the ring
            // is what actually survives a burst of stdin bytes arriving
            // while this process was busy elsewhere (e.g. a file-
            // redirect episode).
            while (uart_rx_ring_ready() == false) {
                uart_rx_ring_drain();
            }
            let mut n: usize = 0;
            while (n < len && uart_rx_ring_ready() == true) {
                dst[n as isize] = uart_rx_ring_getc();
                n = n + 1;
            }
            return (elr, n);
        }
        64 | 68 => {
            // write(fd,buf,len) and pwrite64(fd,buf,len,offset) -- the
            // same first three arguments, so the same handler; the
            // offset (a 4th arg this loader's el0_svc_dispatch signature
            // does not even receive) is simply ignored, matching this
            // UART "file"'s own non-seekable reality. Empirically
            // discovered necessary (GitHub issue #156's own strace
            // research didn't predict this): once ioctl's TCGETS
            // response (-ENOTTY) tells musl's stdio fd 1 is not a tty,
            // its buffered-write path uses pwrite64 instead of write.
            let fd: usize = x0;
            let buf: usize = x1;
            let len: usize = x2;
            if (buf < el0_page_va || len > el0_region_size) {
                return (elr, SYSCALL_ERROR);
            }
            if (buf - el0_page_va > el0_region_size - len) {
                return (elr, SYSCALL_ERROR);
            }
            // GitHub issue #157: same fd-table dispatch as read() above.
            // pwrite64's own offset (x3, not even in this function's
            // signature) is ignored here exactly like the UART path
            // below already ignores it -- fat_write only ever appends at
            // the FatFile's own sequential fptr (fat12.tkb's own scope,
            // see its header comment), matching this loader's existing
            // "no real seek support" stance rather than adding one just
            // for this one call shape.
            if (fd >= FIRST_FILE_FD) {
                let slot: usize = fd - FIRST_FILE_FD;
                if (slot < MAX_OPEN_FILES) {
                    let s: {0..<MAX_OPEN_FILES as usize} = slot;
                    let src2: *u8 = buf as *u8;
                    return (elr, fat_fd_write(s, src2, len as u32));
                }
                return (elr, SYSCALL_ERROR);
            }
            if (fd != 1 && fd != 2) {
                return (elr, SYSCALL_ERROR);
            }
            let src: *u8 = buf as *u8;
            for i: usize in 0..<len {
                uart_putc(src[i as isize]);
            }
            return (elr, len);
        }
        66 => {
            // writev(fd, iov, iovcnt) -- an array of `iovcnt` {base:
            // *u8, len: usize} pairs (16 bytes each: an 8-byte pointer
            // then an 8-byte length, the real Linux struct iovec ABI
            // shape). Empirically discovered necessary (GitHub issue
            // #156's own strace research didn't predict this): real
            // shell builtins' own buffered stdio (busybox's `pwd`/`cd`
            // among them) flush multiple pending buffer segments in one
            // writev call rather than several separate write calls.
            // iovcnt is capped defensively (matching this file's own
            // MAX_PHDRS-style loader hygiene elsewhere), not because
            // more would fail to compile -- for loops accept a runtime
            // bound -- but to bound how much work one syscall can force.
            let fd: usize = x0;
            let iov: usize = x1;
            let iovcnt: usize = x2;
            if (fd != 1 && fd != 2) {
                return (elr, SYSCALL_ERROR);
            }
            if (iov < el0_page_va || iovcnt > 64 || iovcnt * 16 > el0_region_size) {
                return (elr, SYSCALL_ERROR);
            }
            if (iov - el0_page_va > el0_region_size - iovcnt * 16) {
                return (elr, SYSCALL_ERROR);
            }
            let mut total: usize = 0;
            let mut ok: i32 = 1;
            for i: usize in 0..<iovcnt {
                let entry_addr: usize = iov + i * 16;
                let base_ptr: *u64 = entry_addr as *u64;
                let len_ptr: *u64 = (entry_addr + 8) as *u64;
                let base: usize = *base_ptr as usize;
                let len: usize = *len_ptr as usize;
                if (base < el0_page_va || len > el0_region_size) {
                    ok = 0;
                } else if (base - el0_page_va > el0_region_size - len) {
                    ok = 0;
                } else {
                    let src: *u8 = base as *u8;
                    for j: usize in 0..<len {
                        uart_putc(src[j as isize]);
                    }
                    total = total + len;
                }
            }
            if (ok == 0) {
                return (elr, SYSCALL_ERROR);
            }
            return (elr, total);
        }
        73 => {
            // ppoll(fds, nfds, timeout_ts, sigmask) -- only fds/nfds/
            // timeout_ts are visible via el0_svc_dispatch's own x0/x1/x2.
            // Empirically discovered necessary (GitHub issue #156's own
            // strace research didn't predict this): busybox's own `read`
            // builtin polls stdin before actually reading it. This
            // kernel only ever has one real input stream (fd 0, the
            // UART), so this blocks (matching read()'s own busy-wait)
            // until it is ready, reports exactly that one fd as ready
            // (POLLIN, struct pollfd's `revents` field at byte offset 6
            // -- {fd: i32, events: i16, revents: i16}), and reports
            // every OTHER fd in the array as not ready -- the same
            // "deliberately narrow, single real stream" scope every
            // other syscall here has.
            let fds: usize = x0;
            let nfds: usize = x1;
            if (nfds == 0) {
                return (elr, 0);
            }
            if (fds < el0_page_va || nfds > 64 || nfds * 8 > el0_region_size) {
                return (elr, SYSCALL_ERROR);
            }
            if (fds - el0_page_va > el0_region_size - nfds * 8) {
                return (elr, SYSCALL_ERROR);
            }
            // GitHub issue #157: when fd 0 is dup3()ed onto a real file
            // (fat_dup3_stdin above), a fat12.tkb read is always
            // synchronously ready -- skip the UART busy-wait below
            // entirely in that case, matching real ppoll()'s own
            // "regular files are always POLLIN-ready" behavior.
            if (fat_stdin_is_open() == false) {
                while (uart_rx_ring_ready() == false) {
                    uart_rx_ring_drain();
                }
            }
            let revents0: *u16 = (fds + 6) as *u16;
            *revents0 = 1; // POLLIN
            for i: usize in 1..<nfds {
                let revents_i: *u16 = (fds + i * 8 + 6) as *u16;
                *revents_i = 0;
            }
            return (elr, 1);
        }
        79 => {
            // newfstatat(dirfd, pathname, statbuf, flags) -- only
            // dirfd/pathname/statbuf are visible via el0_svc_dispatch's
            // own x0/x1/x2. Two genuinely different call shapes share
            // this one syscall number and need genuinely different
            // answers, discovered the hard way:
            //   - fstatat(fd, "", &buf, AT_EMPTY_PATH) -- pathname is an
            //     empty string, the standard portable idiom for "stat
            //     this fd itself" (confirmed empirically: busybox's own
            //     `read` builtin uses exactly this to check whether
            //     stdin is a regular file). Answered with a plausible
            //     character-device stat (S_IFCHR | 0620, the closest
            //     real analogue to this kernel's own UART-backed
            //     stdin/stdout) -- an all-zero stub buffer left `read`
            //     retrying the identical call four times before giving
            //     up and mis-parsing later stdin content as a command.
            //   - any REAL (non-empty) pathname (e.g. busybox's own
            //     shell doing a $PATH search for an external command,
            //     or GitHub issue #157's own `cat somefile`) -- GitHub
            //     issue #157 replaces the old unconditional -ENOENT with
            //     a real fat_file_exists/fat_file_size lookup against
            //     examples/common/fat12.tkb's own root directory (the
            //     same driver openat() below now opens files through).
            //     Still -ENOENT for anything path_to_name83 itself
            //     cannot represent (a subdirectory path, an over-length
            //     component) or that genuinely is not in the root
            //     directory -- answering "yes, exists" unconditionally
            //     was the first version of this fix (GitHub issue #156)
            //     and was wrong for the same reason it would be wrong
            //     here: a genuinely absent command/file must report
            //     "not found", not a confusing later failure.
            let pathname: usize = x1;
            let statbuf: usize = x2;
            if (pathname < el0_page_va || PATH_MAX_CHECK > el0_region_size) {
                return (elr, SYSCALL_ERROR);
            }
            if (pathname - el0_page_va > el0_region_size - PATH_MAX_CHECK) {
                return (elr, SYSCALL_ERROR);
            }
            let path_ptr: *u8 = pathname as *u8;
            if (statbuf < el0_page_va || 128 > el0_region_size) {
                return (elr, SYSCALL_ERROR);
            }
            if (statbuf - el0_page_va > el0_region_size - 128) {
                return (elr, SYSCALL_ERROR);
            }
            let dst: *u8 = statbuf as *u8;
            for i: usize in 0..<128 {
                dst[i as isize] = 0;
            }
            if (path_ptr[0 as isize] == 0) {
                let mode_ptr: *u32 = (statbuf + 16) as *u32;
                *mode_ptr = 0x2190; // S_IFCHR (0o020000) | 0o620
                let nlink_ptr: *u32 = (statbuf + 20) as *u32;
                *nlink_ptr = 1;
                return (elr, 0);
            }
            let mut name83_buf: [u8; 11];
            if (path_to_name83(path_ptr, name83_buf as *u8) == false) {
                return (elr, ERR_ENOENT);
            }
            if (fat_file_exists(name83_buf as *u8) == false) {
                return (elr, ERR_ENOENT);
            }
            let mode_ptr2: *u32 = (statbuf + 16) as *u32;
            *mode_ptr2 = 0x81A4; // S_IFREG (0o100000) | 0o644
            let nlink_ptr2: *u32 = (statbuf + 20) as *u32;
            *nlink_ptr2 = 1;
            let size_ptr: *u64 = (statbuf + 48) as *u64;
            *size_ptr = fat_file_size(name83_buf as *u8) as u64;
            return (elr, 0);
        }
        56 => {
            // openat(dirfd, pathname, flags, mode) -- GitHub issue #157.
            // dirfd is ignored (this shell's cwd is always '/', GitHub
            // issue #156's own scope -- path_to_name83 strips exactly
            // one leading '/' and rejects anything with a further '/',
            // so a relative-vs-absolute dirfd distinction never actually
            // matters here). mode (x3, not visible via this function's
            // own x0/x1/x2 signature) is ignored too -- fat12.tkb has no
            // permission model (GitHub issue #157's own explicit scope).
            // flags: only O_CREAT (0x40) is inspected, matching
            // fat_open's own only two supported mode combinations --
            // anything else defaults to FA_READ, so a plain O_RDONLY
            // open (busybox's own `cat` call shape) is the common case.
            let pathname: usize = x1;
            let flags: usize = x2;
            if (pathname < el0_page_va || PATH_MAX_CHECK > el0_region_size) {
                return (elr, SYSCALL_ERROR);
            }
            if (pathname - el0_page_va > el0_region_size - PATH_MAX_CHECK) {
                return (elr, SYSCALL_ERROR);
            }
            let path_ptr: *u8 = pathname as *u8;
            let mut name83_buf: [u8; 11];
            if (path_to_name83(path_ptr, name83_buf as *u8) == false) {
                return (elr, ERR_ENOENT);
            }
            let mut mode: i32 = FA_READ;
            if ((flags & 0x40) != 0) { // O_CREAT
                mode = FA_WRITE | FA_CREATE_ALWAYS;
            }
            match fat_open(name83_buf as *u8, mode) {
                FatOpenResult::Error(err) => {
                    return (elr, ERR_ENOENT);
                }
                FatOpenResult::Opened(file) => {
                    let store_result: FatOpenFdResult = fat_fd_store(0, file);
                    return (elr, fat_open_fd_result_value(store_result));
                }
            }
        }
        57 => {
            // close(fd) -- GitHub issue #157. fd < FIRST_FILE_FD (the
            // UART-backed 0/1/2) has no real per-fd state to reclaim, so
            // closing one of those trivially succeeds, matching a real
            // kernel's own close() on those descriptors.
            let fd: usize = x0;
            if (fd < FIRST_FILE_FD) {
                return (elr, 0);
            }
            let slot: usize = fd - FIRST_FILE_FD;
            // Positive-branch narrowing (see fat_fd_store's own comment
            // above) -- a negated `if (slot >= MAX_OPEN_FILES) { return;
            // }` guard would not leave `slot` narrowed below.
            if (slot < MAX_OPEN_FILES) {
                let s: {0..<MAX_OPEN_FILES as usize} = slot;
                return (elr, fat_fd_close(s));
            }
            // A real fd this kernel never tracks in the real file table
            // (e.g. the saved-original-stdin pseudo-fd fcntl(F_DUPFD_
            // CLOEXEC) below hands back) -- success, not ERR_EBADF, same
            // reasoning as fat_fd_close's own Empty-slot case above.
            return (elr, 0);
        }
        24 => {
            // dup3(oldfd, newfd, flags) -- see fat_dup3_stdin's own
            // comment for why this exists at all (GitHub issue #157).
            // Only newfd == 0 is supported -- the only shape this
            // shell's own redirection ever produces.
            let oldfd: usize = x0;
            let newfd: usize = x1;
            if (newfd != 0) {
                return (elr, SYSCALL_ERROR);
            }
            return (elr, fat_dup3_stdin(oldfd));
        }
        25 => {
            // fcntl(fd, cmd, arg) -- GitHub issue #157's own follow-on,
            // discovered via the same real strace as dup3 above: ash's
            // `read var < file` saves the real original stdin via
            // fcntl(0, F_DUPFD_CLOEXEC, N) before redirecting it, then
            // marks that saved copy close-on-exec via
            // fcntl(N, F_SETFD, FD_CLOEXEC). Neither needs real
            // bookkeeping in this kernel: F_DUPFD/F_DUPFD_CLOEXEC just
            // hands back the requested fd number itself -- nothing else
            // in this kernel ever allocates an fd in that range, so it
            // is trivially "free" -- and fat_dup3_stdin above already
            // treats ANY fd outside the real file table as "restore the
            // UART" when it is later dup3()ed back onto fd 0, which is
            // this pseudo-fd's only real later use. F_SETFD is a
            // genuine no-op here: nothing in this kernel ever execs, so
            // close-on-exec has no real effect to honor.
            let cmd: usize = x1;
            let arg: usize = x2;
            if (cmd == 0 || cmd == 1030) { // F_DUPFD, F_DUPFD_CLOEXEC
                return (elr, arg);
            }
            return (elr, 0);
        }
        // Trivial stub syscalls (GitHub issue #156's own effort-estimate
        // list): libc thread-runtime init boilerplate and single-process/
        // single-"user" identity queries that a non-interactive, single-
        // threaded script never exercises meaningfully, so a fixed
        // plausible value is the whole implementation. Discovered
        // load-bearing via real hardware testing against Alpine's
        // busybox-static aarch64 binary (not from the strace research
        // alone): returning 0 (this process's own real TID/PID being 0,
        // an impossible value on a real kernel -- PID/TID 0 is reserved
        // for kernel/swapper) instead of a sane positive TID from
        // set_tid_address was traced to a later NULL-pointer write crash
        // inside musl's own startup, confirmed via a live OpenOCD
        // halt+register read (ESR_EL1 EC 0x07 permission fault at a
        // `mov x0,#0; strb wzr,[x0]` instruction pair -- musl's own
        // internal `a_crash()` abort primitive).
        96 | 178 => {
            // set_tid_address(tidptr), gettid() -- both return this
            // process's own TID.
            return (elr, 1);
        }
        172 => {
            return (elr, 1); // getpid()
        }
        173 => {
            return (elr, 0); // getppid() -- no parent process exists
        }
        174 | 175 | 176 | 177 => {
            return (elr, 0); // getuid/geteuid/getgid/getegid() -- root
        }
        99 | 134 | 135 | 167 | 293 => {
            // set_robust_list, rt_sigaction, rt_sigprocmask, prctl, rseq
            // -- accept and remember nothing, always succeed (see this
            // file's own header comment on why: none of these have
            // observable effects for a single-threaded, non-interactive,
            // single-process script that never receives a real signal or
            // spawns a thread).
            return (elr, 0);
        }
        49 => {
            // chdir(path) -- always succeeds, but genuinely does nothing:
            // this kernel has no real filesystem/VFS layer (GitHub issue
            // #156's own explicit scope), so there is no real "current
            // directory" concept to change. Not the same "no observable
            // effects" story as the trivial-success group above --
            // real shell builtins (busybox's `cd`) track their own
            // $PWD purely in userspace once chdir() reports success,
            // so a script's own `cd X; pwd` still shows X, even though
            // this kernel's own getcwd() stub always answers "/"
            // regardless (confirmed empirically: exactly this happens).
            return (elr, 0);
        }
        29 => {
            // ioctl(fd, request, arg) -- always -ENOTTY. Real shells
            // handle this gracefully (confirmed by GitHub issue #156's
            // own strace research: both traced shells fall back to
            // script/pipe mode cleanly on ENOTTY), and this kernel has
            // no real tty/ioctl model to implement yet.
            return (elr, ERR_ENOTTY);
        }
        278 => {
            // getrandom(buf, len, flags) -- a deliberate low-quality
            // fixed stub (real entropy quality is a separate, later
            // concern, same as every other Stage 1 syscall's own "prove
            // the mechanism first" pattern), but a REAL implementation
            // in the sense that it actually writes `len` validated
            // bytes, unlike the no-op-and-succeed stubs above: whatever
            // calls this expects to read the result (e.g. stack-
            // protector canary seeding), not just check a return code.
            let buf: usize = x0;
            let len: usize = x1;
            if (buf < el0_page_va || len > el0_region_size) {
                return (elr, SYSCALL_ERROR);
            }
            if (buf - el0_page_va > el0_region_size - len) {
                return (elr, SYSCALL_ERROR);
            }
            let dst: *u8 = buf as *u8;
            for i: usize in 0..<len {
                dst[i as isize] = (0x5A ^ i) as u8;
            }
            return (elr, len);
        }
        214 => {
            // brk(addr) -- real heap growth within the fixed HEAP_PAGES
            // region reserved at load time (see that constant's own
            // comment). addr==0 queries the current break (always
            // succeeds); a valid in-range addr moves it; anything else
            // fails by real brk() semantics -- returning the UNCHANGED
            // break, not an error code (brk(2) has no error-signaling
            // return value, unlike sbrk).
            let addr: usize = x0;
            if (addr == 0) {
                return (elr, el0_heap_break);
            }
            if (addr >= el0_heap_start && addr <= el0_heap_limit) {
                el0_heap_break = addr;
            }
            return (elr, el0_heap_break);
        }
        222 => {
            // mmap(addr_hint, length, prot, flags, fd, offset) -- a
            // deliberately narrow stub: every request is served as
            // anonymous memory (prot/flags/fd/offset in x2 onward are
            // not even read, since el0_svc_dispatch's own signature only
            // carries x0/x1/x2 through from el0_asm.S -- this loader has
            // no file-backed mapping support to offer regardless of what
            // a real caller asked for), bump-allocated from the SAME
            // heap headroom brk() above uses. Empirically discovered
            // necessary (GitHub issue #156's own "New loader/process
            // requirements" section didn't predict this): musl's
            // mallocng allocator calls this directly for some
            // allocations, not only brk. Rounds the request up to a
            // whole page, matching real mmap's own page granularity.
            // Never reclaimed (no munmap support) -- same "single
            // short-lived process" scope as brk's own heap.
            let length: usize = x1;
            let rounded: usize = ((length + PAGE_SIZE - 1) / PAGE_SIZE) * PAGE_SIZE;
            if (rounded == 0 || el0_heap_limit - el0_heap_break < rounded) {
                return (elr, SYSCALL_ERROR); // MAP_FAILED == (void *)-1
            }
            let result: usize = el0_heap_break;
            el0_heap_break = el0_heap_break + rounded;
            return (elr, result);
        }
        226 => {
            // mprotect(addr, len, prot) -- a no-op-but-report-success
            // stub: this kernel has no fine-grained EL0 page permission
            // model yet (every mapped page gets the same uniform AP
            // encoding, see examples/vm_page_map/vm_page_map_core.tkb's
            // own process_address_space_map), so a real GNU_RELRO-style
            // post-relocation hardening request cannot actually be
            // enforced -- a real, documented weakening (GitHub issue
            // #156's own explicit flag on this exact syscall), not
            // silently done.
            return (elr, 0);
        }
        17 => {
            // getcwd(buf, size) -- always reports "/", the only
            // filesystem concept this kernel has (GitHub issue #156's
            // own "no real filesystem/VFS layer" scope). Real getcwd(2)
            // returns the byte count written INCLUDING the NUL
            // terminator on success, not a pointer.
            let buf: usize = x0;
            let size: usize = x1;
            if (size < 2) {
                return (elr, SYSCALL_ERROR); // ERANGE-shaped: buffer too small
            }
            if (buf < el0_page_va || 2 > el0_region_size) {
                return (elr, SYSCALL_ERROR);
            }
            if (buf - el0_page_va > el0_region_size - 2) {
                return (elr, SYSCALL_ERROR);
            }
            let dst: *u8 = buf as *u8;
            dst[0 as isize] = 0x2f; // '/'
            dst[1 as isize] = 0x00; // NUL
            return (elr, 2);
        }
        160 => {
            // uname(struct utsname *buf) -- writes the 6 fixed-size,
            // NUL-padded 65-byte fields the real Linux ABI shape
            // requires (sysname/nodename/release/version/machine/
            // domainname). "Linux" as sysname is not a lie about what
            // this kernel really is -- it is the smallest true statement
            // a real libc/coreutils toolchain can actually consume: many
            // real programs (including ones this milestone wants to
            // eventually run) branch on this exact string, and there is
            // no separate "syscall-ABI-compatible but not Linux"
            // convention to report instead.
            let buf: usize = x0;
            if (buf < el0_page_va || 390 > el0_region_size) {
                return (elr, SYSCALL_ERROR);
            }
            if (buf - el0_page_va > el0_region_size - 390) {
                return (elr, SYSCALL_ERROR);
            }
            let dst: *u8 = buf as *u8;
            for i: usize in 0..<390 {
                dst[i as isize] = 0;
            }
            let sysname: []u8 = "Linux" as []u8;
            let nodename: []u8 = "takibi" as []u8;
            let release: []u8 = "6.1.0" as []u8;
            let version: []u8 = "#1" as []u8;
            let machine: []u8 = "aarch64" as []u8;
            slice_copy(unsafe { dst[0 as isize..<65 as isize] }, sysname);
            slice_copy(unsafe { dst[65 as isize..<130 as isize] }, nodename);
            slice_copy(unsafe { dst[130 as isize..<195 as isize] }, release);
            slice_copy(unsafe { dst[195 as isize..<260 as isize] }, version);
            slice_copy(unsafe { dst[260 as isize..<325 as isize] }, machine);
            // domainname field [325..390) stays all-zero ("" / unset).
            return (elr, 0);
        }
        220 => {
            // clone(flags, child_stack, ...) -- GitHub issue #158's real
            // fork(). A real strace of this exact busybox binary (the
            // same "measure, don't guess" method issue #156's own
            // research used) confirmed ash's own external-command
            // execution uses plain clone(child_stack=NULL, flags=
            // CLONE_CHILD_CLEARTID|CLONE_CHILD_SETTID|SIGCHLD) -- real
            // fork() semantics (a genuinely separate address space, not
            // vfork()'s shared one), not vfork(). Only x0 (flags) is
            // meaningful to real fork()-shaped clone; child_stack (x1)
            // is NULL for this call shape and unused. Delegates the
            // actual page-table/TTBR0_EL2 work to hvc_dispatch_fork
            // above (EL2-only operations, unreachable from here) via the
            // same EL1->EL2 hvc boundary exit() already uses --
            // pending_frame_sp carries this trap's own frame_sp across
            // that boundary since the hvc ABI itself only ever carries
            // one bare opcode (see pending_frame_sp's own comment).
            // Resuming afterward reuses el0_sync_entry's own existing
            // "same frame, patched x0" path: by the time this returns,
            // hvc_dispatch_fork has already switched TTBR0_EL2 to the
            // child, so THIS resume runs the child (x0=0) using the
            // exact registers the parent had -- exactly fork()'s real
            // semantics for the child, and the parent's own eventual
            // resume (x0=FORK_CHILD_PID) happens later, via
            // rpi3_el0_resume_frame, not through this return at all.
            pending_frame_sp = frame_sp;
            rpi3_hvc_call(1);
            return (elr, 0);
        }
        93 | 94 => {
            let outcome = ProcessOutcome::Exited(x0);
            process_outcome_report(outcome);
            // GitHub issue #158: the CHILD's own exit() cannot use the
            // same "terminate, park forever" disposition the original
            // process's exit() below does -- there is a suspended PARENT
            // waiting to resume. fork_child_running is only ever true
            // while the child is the one actually running (the parent
            // is suspended for as long as it is, see ProcessVmState's
            // own comment), so it doubles as "am I the child" here.
            if (fork_child_running == true) {
                child_exit_status = x0;
                rpi3_hvc_call(2);
                let frame: *u8 = parent_saved_frame as *u8;
                rpi3_el0_resume_frame(frame as usize);
            }
            // Issued FROM EL1 (this whole function runs inside
            // el0_sync_entry's own EL1-side SVC handling): traps up to
            // EL2 via el1_hvc_entry, runs hvc_dispatch there (real
            // unmap_page/address_space_deactivate teardown), then
            // resumes right here once EL2 erets back.
            rpi3_hvc_call(0);
            return (1, 0);
        }
        _ => {
            return (0, 0);
        }
    }
}

fn el1_main() {
    rpi3_el0_enter(el0_entry_va, el0_stack_top_va);
}

fn app_main() {
    // GitHub issue #157: mounts a real FAT12 filesystem over the same
    // real USB Mass Storage device examples/fatfs_sdcard/fatfs_sdcard.tkb
    // already proves on this board, and seeds it with one small, known
    // file -- the "prove the mechanism with a small, controlled real
    // file first" staged approach the issue itself suggests, before
    // el0_svc_dispatch's openat/read/close (below) ever try to open it
    // from EL0. Formats unconditionally (fat_format(), not fat_mount())
    // rather than trusting whatever was left on the media by a previous
    // run or a different fatfs-family test sharing the same drive --
    // this keeps CAT.TXT's own content deterministic regardless of test
    // order or prior media state, matching fatfs_sdcard.tkb's own
    // create-fresh-then-verify pattern. Deliberately silent on success
    // (no new line in el0_shell.expected's own boot preamble) -- only a
    // real failure here is worth a line, so a hardware run that DOES
    // succeed produces byte-identical boot output to before this issue.
    //
    // "el0_shell\n" itself is deliberately printed AFTER this block, not
    // before it as it used to be -- confirmed necessary via real
    // hardware testing: scripts/run_hwtest_rpi3.sh's own
    // run_hw_test_rpi3_stdin sends el0_shell.stdin the moment it sees
    // the FIRST byte of UART output, on the (previously true) assumption
    // that "kernel printed something" means "about to be ready to read
    // stdin very soon". USB Mass Storage bring-up + a real FAT format
    // now take several real seconds between boot and that readiness;
    // sending the whole stdin script into the PL011's own small hardware
    // RX FIFO that early, with nothing draining it while this block
    // runs, silently dropped/corrupted its EARLIEST bytes by the time
    // the shell actually started reading (observed on real hardware as
    // later commands -- well past where the drop happened -- failing
    // with "syntax error: unexpected \"do\"", not as any error near the
    // actual dropped bytes) -- moving this print to AFTER the point
    // where the real work is done keeps "first byte of output" true to
    // "about to actually read stdin" again, the invariant this test
    // harness's own timing already relies on for every other stdin-fed
    // example.
    if (disk_io_ok(disk_initialize()) == false || fat_io_ok(fat_format()) == false) {
        uart_puts("fat12 setup failed\n");
    } else {
        let cat_name: *u8 = "CAT     TXT";
        let cat_content: *u8 = "fat12 file\n";
        if (fat_io_ok(create_demo_file(cat_name, cat_content)) == false) {
            uart_puts("fat12 setup failed\n");
        }
    }
    uart_puts("el0_shell\n");

    page_pool_init();

    let archive_addr: usize = el0_shell_image_addr();
    let archive_len: usize = el0_shell_image_len();

    if (archive_len < CPIO_HEADER_SIZE) {
        uart_puts("cpio image too small\n");
        return;
    }
    let hdr_base: *u8 = archive_addr as *u8;
    if (hdr_base[0] != 0x30 || hdr_base[1] != 0x37 || hdr_base[2] != 0x30
            || hdr_base[3] != 0x37 || hdr_base[4] != 0x30 || hdr_base[5] != 0x31) {
        uart_puts("bad cpio magic\n");
        return;
    }
    let namesize: usize = parse_hex8(hdr_base, CPIO_NAMESIZE_OFFSET);
    let filesize: usize = parse_hex8(hdr_base, CPIO_FILESIZE_OFFSET);
    // Both the name and the header+name run are individually rounded up
    // to a 4-byte boundary in the newc format; only the second rounding
    // matters here since nothing after the header is read except via
    // data_start below. 0xFFFFFFFFFFFFFFFC clears the low 2 bits (round
    // DOWN after adding 3 -- the standard round-up-to-4 idiom).
    let name_end: usize = CPIO_HEADER_SIZE + namesize;
    let data_start: usize = (name_end + 3) & 0xFFFFFFFFFFFFFFFC;
    if (data_start < name_end || data_start > archive_len
            || filesize > archive_len - data_start) {
        uart_puts("cpio entry out of range\n");
        return;
    }
    let image_addr: usize = archive_addr + data_start;
    let image_len: usize = filesize;

    if (image_len < 64) {
        uart_puts("image too small\n");
        return;
    }
    let hdr_ptr: *Elf64Header = image_addr as *Elf64Header;
    let magic: *u8 = hdr_ptr.e_ident as *u8;
    if (magic[0] != 0x7F || magic[1] != 0x45 || magic[2] != 0x4C || magic[3] != 0x46) {
        uart_puts("bad ELF magic\n");
        return;
    }
    if (magic[4] != 2 || magic[5] != 1) {
        uart_puts("not ELF64 little-endian\n");
        return;
    }
    if (hdr_ptr.e_type != ET_EXEC && hdr_ptr.e_type != ET_DYN) {
        uart_puts("unsupported ELF type\n");
        return;
    }

    let entry_link: usize = hdr_ptr.e_entry as usize;
    let phoff: usize = hdr_ptr.e_phoff as usize;
    let phentsize: usize = hdr_ptr.e_phentsize as usize;
    let phnum: usize = hdr_ptr.e_phnum as usize;

    let page_va: {0x80000000..<0x80200000 as usize} = 0x80000000;
    let mut phdr_cap: usize = MAX_PHDRS;
    if (phnum < MAX_PHDRS) {
        phdr_cap = phnum;
    }

    // First pass (GitHub issue #156's multi-page loader generalization,
    // now also PIE-aware): scan every PT_LOAD segment to find the lowest
    // p_vaddr among them and the overall extent, BEFORE mapping anything.
    // load_bias = page_va - min_vaddr places that lowest segment exactly
    // at page_va, and every other address (other segments, e_entry, the
    // AT_PHDR auxv value) is offset by the same bias -- this is the same
    // mechanism Linux's own kernel ELF loader uses (binfmt_elf.c), and it
    // unifies both ELF kinds this loader accepts: a well-formed ET_EXEC
    // binary already links its lowest PT_LOAD at page_va, so min_vaddr
    // == page_va and load_bias comes out to 0 (a no-op) automatically; a
    // static-pie ET_DYN binary (GitHub issue #156's own empirical
    // finding: every real target shell binary is one) links its lowest
    // PT_LOAD at 0, so load_bias becomes exactly page_va. Segment space
    // is reserved by p_memsz, not p_filesz -- filesz-to-memsz bytes are
    // BSS, correctly left zeroed by this loader's fresh page pool, not
    // copied from the file (the segment-copy loop below still only
    // copies p_filesz bytes, unchanged). One extra page is reserved for
    // the stack, so code_pages is capped at MAX_PROCESS_PAGES - 1.
    let mut min_vaddr: usize = 0xFFFFFFFFFFFFFFFF;
    let mut max_vaddr_end: usize = 0;
    let mut any_load: i32 = 0;
    for i: usize in 0..<phdr_cap {
        let ph_addr: usize = image_addr + phoff + i * phentsize;
        let ph_ptr: *Elf64ProgramHeader = ph_addr as *Elf64ProgramHeader;
        if (ph_ptr.p_type == PT_LOAD) {
            any_load = 1;
            let seg_vaddr: usize = ph_ptr.p_vaddr as usize;
            let seg_memsz: usize = ph_ptr.p_memsz as usize;
            if (seg_vaddr < min_vaddr) {
                min_vaddr = seg_vaddr;
            }
            let seg_end: usize = seg_vaddr + seg_memsz;
            if (seg_end > max_vaddr_end) {
                max_vaddr_end = seg_end;
            }
        }
    }
    if (any_load == 0 || min_vaddr > page_va) {
        uart_puts("load failed\n");
        return;
    }
    let load_bias: usize = page_va - min_vaddr;
    let entry: usize = entry_link + load_bias;
    let at_phdr: usize = load_bias + phoff;
    let max_extent: usize = max_vaddr_end - min_vaddr;

    let mut code_pages: usize = (max_extent + PAGE_SIZE - 1) / PAGE_SIZE;
    if (code_pages < 1) {
        code_pages = 1;
    }
    if (code_pages > MAX_PROCESS_PAGES - 1 - HEAP_PAGES) {
        uart_puts("elf too large\n");
        return;
    }
    let code_region_size: usize = code_pages * PAGE_SIZE;
    if (entry < page_va || entry - page_va >= code_region_size) {
        uart_puts("load failed\n");
        return;
    }
    let total_pages: usize = code_pages + 1 + HEAP_PAGES;

    // total_pages is already guaranteed in [2, MAX_PROCESS_PAGES] by the
    // code_pages guard above, but that guard's narrowing does not survive
    // past its own `if` (SPEC.md's flow-sensitive narrowing is strictly
    // scoped to the then-branch, not anything after an early return) --
    // so process_address_space_map's refined page_count parameter still
    // needs its own explicit if-narrow here, matching
    // examples/narrow/narrow.tkb's own established idiom. Nothing has
    // been allocated yet at this point, so the (unreachable in practice)
    // else arm has nothing to unwind.
    if (total_pages < 513) {
        let seed: {0..<2 as usize} = 0;
        let inactive = address_space_new(seed);
        let core: usize = 0;
        let (space, active) = address_space_activate(inactive, core);

        match process_address_space_map(space, active, page_va, total_pages) {
        ProcessMapResult::Failed(inactive2) => {
            uart_puts("allocation failed\n");
            address_space_free(inactive2);
        }
        ProcessMapResult::Mapped(pair) => {
            let (pas, active2) = pair;
            let dst: *u8 = page_va as *u8;

            let mut ok: i32 = 1;
            for i: usize in 0..<phdr_cap {
                let ph_addr: usize = image_addr + phoff + i * phentsize;
                let ph_ptr: *Elf64ProgramHeader = ph_addr as *Elf64ProgramHeader;
                if (ph_ptr.p_type == PT_LOAD) {
                    let seg_vaddr: usize = (ph_ptr.p_vaddr as usize) + load_bias;
                    let seg_offset: usize = ph_ptr.p_offset as usize;
                    let seg_filesz: usize = ph_ptr.p_filesz as usize;
                    if (seg_vaddr < page_va || seg_filesz > code_region_size
                            || seg_vaddr - page_va > code_region_size - seg_filesz
                            || seg_offset > image_len
                            || seg_filesz > image_len - seg_offset) {
                        uart_puts("segment out of range\n");
                        ok = 0;
                    } else {
                        // dst_base + seg_filesz <= code_region_size is
                        // already proven by the guard above, but as a
                        // relationship between two runtime values
                        // (seg_vaddr/page_va and seg_filesz), not a plain
                        // interval on one of them alone -- exactly the
                        // "correlated bounds" case SPEC.md's Known
                        // Limitations section documents as unsafe's
                        // sanctioned escape (same shape as
                        // examples/tcp_echo/tcp_echo.tkb's own "sole
                        // executable unsafe site", `frame[data_off_idx
                        // ..<data_off_idx+data_len_idx]`). Both subslices
                        // stay unproven-length ([]u8, minimum 0) rather
                        // than fighting for a stronger static minimum;
                        // slice_copy's own runtime min(dst.len, src.len)
                        // is what's actually safe here, matching that same
                        // file's own `slice_copy(eth[...], data)` pattern
                        // -- no per-element index to prove at all, so no
                        // remaining --forbid-trap site either.
                        let src: *u8 = image_addr as *u8;
                        let dst_base: usize = seg_vaddr - page_va;
                        let seg_dst = unsafe {
                            dst[dst_base as isize..<(dst_base + seg_filesz) as isize]
                        };
                        let seg_src = unsafe {
                            src[seg_offset as isize..<(seg_offset + seg_filesz) as isize]
                        };
                        slice_copy(seg_dst, seg_src);
                    }
                }
            }

            if (ok == 0) {
                uart_puts("load failed\n");
                el0_pas_abandon(pas);
                el0_active_abandon(active2);
                return;
            }

            // The stack is simply the LAST page of the same contiguous
            // ProcessAddressSpace region, right after the code pages --
            // no longer a separately-mapped MappingOwner (GitHub issue
            // #156's generalization folds it into the one coarse-grained
            // owner alongside the code pages).
            let stack_va: usize = page_va + code_region_size;

            // Real argv/envp/auxv initial stack layout (GitHub issue
            // #156): every libc-linked binary's own startup code reads
            // this off SP unconditionally, so this is a hard prerequisite
            // for anything beyond a hand-written, no-memory-access test
            // payload. Reserved in the TOP ARGV_LAYOUT_SIZE bytes of the
            // stack page; everything below el0_entry_sp remains the
            // process's own usable stack, growing down from there exactly
            // like a real kernel's layout.
            //
            // Layout (matches the Linux ELF ABI exactly, with the PIE
            // auxv entries a real libc's own self-relocation/TLS setup
            // needs -- see examples/common_rpi3/el0_test_prog.S's own
            // matching validation for the exact byte offsets this must
            // agree with):
            //   [argc=1][argv[0]=ptr]["prog\0" pointed to by
            //   argv[0]][argv NULL][envp NULL (0 entries)]
            //   [auxv: AT_PAGESZ, AT_PHDR, AT_PHENT, AT_PHNUM, AT_BASE,
            //    AT_ENTRY, AT_RANDOM, AT_SECURE][auxv: AT_NULL, 0]
            //   [AT_RANDOM's 16-byte pointee][argv[0]'s "prog\0" string]
            let layout_base: usize = stack_va + (PAGE_SIZE - ARGV_LAYOUT_SIZE);
            let random_addr: usize = layout_base + 176;
            let string_addr: usize = layout_base + 192;

            let argc_ptr: *u64 = layout_base as *u64;
            *argc_ptr = 1;
            let argv0_ptr: *u64 = (layout_base + 8) as *u64;
            *argv0_ptr = string_addr as u64;
            let argv_null_ptr: *u64 = (layout_base + 16) as *u64;
            *argv_null_ptr = 0;
            let envp_null_ptr: *u64 = (layout_base + 24) as *u64;
            *envp_null_ptr = 0;

            let auxv0_type_ptr: *u64 = (layout_base + 32) as *u64;
            *auxv0_type_ptr = AT_PAGESZ as u64;
            let auxv0_val_ptr: *u64 = (layout_base + 40) as *u64;
            *auxv0_val_ptr = PAGE_SIZE as u64;

            let auxv1_type_ptr: *u64 = (layout_base + 48) as *u64;
            *auxv1_type_ptr = AT_PHDR as u64;
            let auxv1_val_ptr: *u64 = (layout_base + 56) as *u64;
            *auxv1_val_ptr = at_phdr as u64;

            let auxv2_type_ptr: *u64 = (layout_base + 64) as *u64;
            *auxv2_type_ptr = AT_PHENT as u64;
            let auxv2_val_ptr: *u64 = (layout_base + 72) as *u64;
            *auxv2_val_ptr = phentsize as u64;

            let auxv3_type_ptr: *u64 = (layout_base + 80) as *u64;
            *auxv3_type_ptr = AT_PHNUM as u64;
            let auxv3_val_ptr: *u64 = (layout_base + 88) as *u64;
            *auxv3_val_ptr = phnum as u64;

            let auxv4_type_ptr: *u64 = (layout_base + 96) as *u64;
            *auxv4_type_ptr = AT_BASE as u64;
            let auxv4_val_ptr: *u64 = (layout_base + 104) as *u64;
            *auxv4_val_ptr = 0;

            let auxv5_type_ptr: *u64 = (layout_base + 112) as *u64;
            *auxv5_type_ptr = AT_ENTRY as u64;
            let auxv5_val_ptr: *u64 = (layout_base + 120) as *u64;
            *auxv5_val_ptr = entry as u64;

            let auxv6_type_ptr: *u64 = (layout_base + 128) as *u64;
            *auxv6_type_ptr = AT_RANDOM as u64;
            let auxv6_val_ptr: *u64 = (layout_base + 136) as *u64;
            *auxv6_val_ptr = random_addr as u64;

            let auxv7_type_ptr: *u64 = (layout_base + 144) as *u64;
            *auxv7_type_ptr = AT_SECURE as u64;
            let auxv7_val_ptr: *u64 = (layout_base + 152) as *u64;
            *auxv7_val_ptr = 0;

            let auxv_null_type_ptr: *u64 = (layout_base + 160) as *u64;
            *auxv_null_type_ptr = 0;
            let auxv_null_val_ptr: *u64 = (layout_base + 168) as *u64;
            *auxv_null_val_ptr = 0;

            // AT_RANDOM's 16-byte pointee -- a deliberate low-quality
            // fixed stub (GitHub issue #156's own hedge: real entropy
            // quality is a separate, later concern), not all-zero so a
            // real libc's stack-protector guard isn't a predictable
            // constant either.
            let random_ptr: *u8 = random_addr as *u8;
            for i: usize in 0..<16 {
                random_ptr[i as isize] = (0xA5 ^ i) as u8;
            }

            // "prog\0" -- argv[0]'s own string data, placed above the
            // array (higher address), matching real kernel layout
            // convention.
            let string_ptr: *u8 = string_addr as *u8;
            // "sh\0" -- not "prog\0" (examples/el0_elf_load's own value):
            // busybox is a multi-call binary that dispatches to an
            // applet by argv[0]'s own basename, so this specific string
            // is what makes it actually run its `sh` applet instead of
            // printing "applet not found" (both were verified on real
            // hardware while developing this, see this file's own header
            // comment).
            string_ptr[0 as isize] = 0x73; // 's'
            string_ptr[1 as isize] = 0x68; // 'h'
            string_ptr[2 as isize] = 0x00; // NUL

            el0_entry_va = entry;
            el0_page_va = page_va;
            el0_region_size = total_pages * PAGE_SIZE;
            el0_stack_top_va = layout_base;
            // Heap region: HEAP_PAGES right after the stack page (the
            // last of the total_pages this ProcessAddressSpace call
            // mapped) -- see HEAP_PAGES's own comment on why this is a
            // fixed up-front reservation, not real dynamic mapping.
            el0_heap_start = stack_va + PAGE_SIZE;
            el0_heap_limit = el0_heap_start + HEAP_PAGES * PAGE_SIZE;
            el0_heap_break = el0_heap_start;
            // This bundle IS about to become a running process -- stash it
            // in the stable slot instead of abandoning it, so exit()'s hvc
            // call can reclaim it for real later (see hvc_dispatch above).
            process_vm_put(ProcessVmState::Loaded((pas, active2)));

            let el1_sp_base: usize = (el1_stack as *u8) as usize;
            let el1_sp: usize = el1_sp_base + 4096;
            rpi3_el1_enter(el1_sp);
        }
        }
    } else {
        uart_puts("elf too large\n");
    }
}
