// RTOS variant of examples/http_server_sdcard.
//
// The HTTP/TCP state machine is intentionally kept in app_main's task, while
// SD/FAT initialization and per-request file reads live in sd_worker and are
// reached through a synchronous typed request RPC. This is the smallest useful step from
// the flat http_server_sdcard baseline toward an RTOS-shaped HTTP+SD server:
// the protocol state machine remains unchanged, but the storage subsystem is
// now behind a task boundary.
//
// STAGE 2 SCOPE: GET / maps to INDEX.HTM, and simple single-component
// 8.3 paths such as /ABOUT.HTM map to their corresponding FAT12 names.
// Directory listings, long filenames, and nested paths remain out of
// scope. Larger files are sent as multiple TCP segments, one chunk per
// client ACK, still with one connection at a time and Connection: close.
//
// Multi-segment scope: still one TCP connection at a time and still
// HTTP/1.1 Connection: close, but a response body may span multiple TCP
// segments. The server sends headers plus the first chunk immediately,
// then sends each later chunk only after the previous segment is ACKed.
// FIN is attached to the final chunk.
//
// SD card provisioning is fully automated, no human touches the card:
// examples/http_server_sdcard_install/http_server_sdcard_install.tkb
// writes a real mtools-built FAT12 image onto the card via disk_write,
// run by scripts/provision_http_server_sdcard.sh -- shared by both
// `make hwcheck-net` (scripts/run_hwtest_net_ram.sh) and
// `make stm32-http-server-sdcard` (Makefile), see that script's header
// comment. This file's own app_main() only ever fat_mount()s -- it
// deliberately does NOT fat_format() the card (unlike fatfs_sdcard.tkb),
// since the whole point is showing the card's real, externally
// -provisioned content.
//
// --forbid-trap clean: this file was first written and verified against
// real hardware WITHOUT --forbid-trap, per CLAUDE.md's Development
// Process section (new milestone work -- combining fatfs_sdcard's
// real-SD access with http_server's proven TCP/HTTP layer in a genuinely
// new way, reading file bytes into the reply instead of the static
// response-body buffer). Once the whole milestone (this file + the installer) was
// demonstrated working end to end -- verified over real HTTP via a real
// browser, and by physically removing the card and confirming INDEX.HTM
// with a normal PC file manager -- --forbid-trap was turned on in one
// pass; no sites needed fixing here (every new access is either a fixed-
// size fat_read into the caller-owned response buffer, matching its own
// declared size, or reuses the shared HTTP/TCP and SD-card response
// helpers). See http_server_sdcard_install.tkb, part of the same
// milestone, for the one file that DID need a fix during the original
// issue #97 work.
//
// STM32-only: there is no virtual SD controller in this project's QEMU
// setup (matches examples/fatfs_sdcard and examples/sdcard's own
// no-QEMU status).

use "examples/common/inet_checksum.tkb";
use "examples/common/netutil.tkb";
use "examples/common/http_sdcard_server.tkb";
use "examples/common/rtos.tkb";
use "examples/common_stm32/fat12_sdmmc.tkb";

let mut our_mac: [u8; 6];
let mut our_ip:  [u8; 4];

// ARP/IPv4/TCP field offsets (ARP_HTYPE, ..., ARP_TPA, IP_TOTAL_LEN, ...,
// TCP_URGENT) come from examples/common/netutil.tkb's `use` above --
// offsetof(ArpHdr/Ipv4Hdr/TcpHdr, field)-based, matching http_server.tkb.

struct SdReadChunkRequest {
    private name83: *u8;
    private off: u32;
    private want: u32;
}

variant SdRequest {
    Init;
    ReadChunk(SdReadChunkRequest);
    FileSize(*u8);
}

// The private slot is the complete channel invariant: full == 0 means value
// is ignored; full == 1 means value holds one complete typed request. Both
// transitions happen while mutex is held, and send waits for recv to copy the
// value out before returning.
struct SdRequestChan {
    private mutex:      i32;
    private slot_full:  io i32;
    private slot_taken: io i32;
    private full:       i32;
    private value:      SdRequest;
}

let mut sd_request_ch: SdRequestChan;
let mut sd_response_ch: Chan;
let mut sd_chunk_buf: [u8; HTTP_SEGMENT_PAYLOAD_MAX];
let mut sd_stack: [u8; 8192];

fn sd_request_chan_init(ch: *SdRequestChan) {
    ch.mutex = 1;
    ch.slot_full = 0;
    ch.slot_taken = 0;
    ch.full = 0;
    ch.value = SdRequest::Init;
}

fn sd_request_send(ch: *SdRequestChan, request: SdRequest) !{may_block} {
    let mut g = mutex_lock(&ch.mutex);
    while (ch.full != 0) {
        g = cond_wait(&ch.slot_taken, g, &ch.mutex);
    }
    ch.value = request;
    ch.full = 1;
    cond_signal(&ch.slot_full);
    while (ch.full != 0) {
        g = cond_wait(&ch.slot_taken, g, &ch.mutex);
    }
    mutex_unlock(g, &ch.mutex);
}

fn sd_request_recv(ch: *SdRequestChan) -> SdRequest !{may_block} {
    let mut g = mutex_lock(&ch.mutex);
    while (ch.full == 0) {
        g = cond_wait(&ch.slot_full, g, &ch.mutex);
    }
    let request: SdRequest = ch.value;
    ch.full = 0;
    cond_signal(&ch.slot_taken);
    mutex_unlock(g, &ch.mutex);
    return request;
}

fn sd_read_file_chunk(name83: *u8, off: u32, dst: *u8, want: u32) -> u32 {
    let mut got: u32 = 0;
    fat_read_at(name83, off, dst, want, &got);
    return got;
}

fn sd_worker() {
    while (true) {
        let request: SdRequest = sd_request_recv(&sd_request_ch);
        match request {
            SdRequest::Init => {
                let mut ok: i32 = 0;
                if (disk_initialize() != 0) {
                    uart_puts("http_server_sdcard_rtos: disk_initialize FAIL\r\n");
                    ok = -1;
                } else {
                    fat_mount();
                }
                chan_send(&sd_response_ch, ok);
            }
            SdRequest::ReadChunk(read) => {
                // Do not retain the caller task's frame pointer in the request.
                // The rendezvous response makes this bounce buffer ready to copy.
                chan_send(&sd_response_ch,
                          sd_read_file_chunk(read.name83, read.off,
                                             sd_chunk_buf, read.want) as i32);
            }
            SdRequest::FileSize(name83) => {
                if (fat_file_exists(name83)) {
                    chan_send(&sd_response_ch, fat_file_size(name83) as i32);
                } else {
                    chan_send(&sd_response_ch, -1);
                }
            }
        }
    }
}

fn sd_file_size_rpc(name83: *u8) -> i32 {
    sd_request_send(&sd_request_ch, SdRequest::FileSize(name83));
    return chan_recv(&sd_response_ch);
}

fn sd_read_chunk_rpc(name83: *u8, off: u32, dst: borrow *u8,
        want: u32) -> u32 {
    let mut request: SdReadChunkRequest = { name83, off, want };
    sd_request_send(&sd_request_ch, SdRequest::ReadChunk(request));
    let got: u32 = chan_recv(&sd_response_ch) as u32;
    bytes_copy(dst, sd_chunk_buf, got as isize);
    return got;
}

fn http_file_size(name83: *u8) -> i32 {
    return sd_file_size_rpc(name83);
}

fn http_read_chunk(name83: *u8, off: u32, dst: borrow *u8,
        want: u32) -> u32 {
    return sd_read_chunk_rpc(name83, off, dst, want);
}

fn app_main() {
    sd_request_chan_init(&sd_request_ch);
    chan_init(&sd_response_ch);

    uart_puts("http_server_sdcard_rtos: init\r\n");

    match net_init() {
        NetInitResult::Failed => {
            uart_puts("http_server_sdcard_rtos: device/link not found\r\n");
        }
        NetInitResult::Ready(mut ready) => {
            net_read_mac(our_mac as *u8);
            slice_copy(our_ip as []u8, HTTP_SERVER_IP as []u8);

            rtos_task_add(1, setup_task_stack(sd_stack + 8192, sd_worker));
            rtos_start();

            sd_request_send(&sd_request_ch, SdRequest::Init);
            let sd_init_result: i32 = chan_recv(&sd_response_ch);

            if (sd_init_result == 0) {
                uart_puts("http_server_sdcard_rtos: ready\r\n");
            } else {
                uart_puts("http_server_sdcard_rtos: ready without SD\r\n");
            }

            while (true) {
                ready = http_server_poll_once(ready);
            }
        }
    }
}
