// IPv4 header parsing and validation -- parse only, no reply. Deliberately
// operates on canned buffers baked into the binary rather than real
// virtio-net RX: the goal of this step is proving the *parsing logic*
// (field extraction, checksum validation via examples/common/inet_checksum.tkb)
// is correct in isolation, not re-proving the virtqueue/IRQ plumbing that
// examples/net_echo and examples/arp_reply already established. Real
// network I/O (RX/TX over virtio-net) is exercised by examples/icmp_echo,
// which reuses this parsing logic against live packets.

use "examples/common/inet_checksum.tkb";
use "examples/common/netutil.tkb";

fn print_protocol_name(proto: u8) {
    if (proto == 1) {
        uart_puts("ICMP");
    } else if (proto == 6) {
        uart_puts("TCP");
    } else if (proto == 17) {
        uart_puts("UDP");
    } else {
        uart_puts("unknown");
    }
}

fn parse_ipv4(pkt: borrow [u8; 20..], len: i32) {
    // version/ihl/ttl/protocol are all single-byte wire fields -- u8 is
    // their natural type now that Refinement Numerical Type supports any
    // base (see CLAUDE.md). total_len is a 16-bit field, so u16.
    let version: u8 = pkt[0] >> 4;
    // ihl is read from the wire and never otherwise validated here (this
    // demo's whole point is field extraction, not enforcing IHL == 20 the
    // way icmp_echo/tcp_echo/http_server do). P4c-2: `& 0x0f` alone
    // already carries ihl to {0..<16} (a non-negative-literal mask is
    // ALWAYS in [0, mask] regardless of the byte's own value), and `* 4`
    // carries that to {0..<61} -- but pkt is only 20 bytes, so
    // pkt[0..<ihl] on ITS OWN would still need a runtime check. min(ihl,
    // 20) clamps the upper bound to what pkt can actually satisfy,
    // provably, no matter what garbage byte 0 turns out to hold --
    // closing the gap a plain runtime bounds check used to be the only
    // answer for (this file is --forbid-trap clean; see
    // scripts/run_qemutest.sh's forbid_trap_ip_parse). The demo's own
    // packets always have the real IHL == 20 (no options), so clamping to
    // 20 (pkt's full size) never actually truncates anything here.
    let ihl: u8 = min((pkt[0] & 0x0f) * 4, 20);
    let ihl_idx: usize = ihl as usize;
    let total_len: u16 = ((pkt[2] as u16) << 8) | (pkt[3] as u16);
    let ttl:      u8 = pkt[8];
    let protocol: u8 = pkt[9];
    let checksum: i32 = inet_checksum(pkt[0..<ihl_idx]);

    uart_puts("IPv4 packet:\r\n");
    uart_puts("  version:   "); uart_println(version);
    uart_puts("  ihl:       "); uart_println(ihl);
    uart_puts("  total_len: "); uart_println(total_len);
    uart_puts("  ttl:       "); uart_println(ttl);
    uart_puts("  protocol:  "); uart_print(protocol);
    uart_puts(" (");           print_protocol_name(protocol); uart_puts(")\r\n");
    uart_puts("  src:       "); print_ip(pkt[12..<16]); uart_puts("\r\n");
    uart_puts("  dst:       "); print_ip(pkt[16..<20]); uart_puts("\r\n");
    uart_puts("  checksum:  ");
    if (checksum == 0) {
        uart_puts("OK\r\n");
    } else {
        uart_puts("BAD\r\n");
    }
}

fn test_ip_parse() {
    // version/IHL, DSCP/ECN, total length, id, flags/fragoffset, TTL,
    // protocol, checksum, src IP, dst IP. Same bytes as
    // examples/inet_checksum/inet_checksum.tkb (already verified valid).
    let mut pkt: [u8; 20];
    pkt[0]  = 0x45 as u8; pkt[1]  = 0x00 as u8; pkt[2]  = 0x00 as u8; pkt[3]  = 0x3c as u8;
    pkt[4]  = 0x1c as u8; pkt[5]  = 0x46 as u8; pkt[6]  = 0x40 as u8; pkt[7]  = 0x00 as u8;
    pkt[8]  = 0x40 as u8; pkt[9]  = 0x06 as u8; pkt[10] = 0xb1 as u8; pkt[11] = 0xe6 as u8;
    pkt[12] = 0xac as u8; pkt[13] = 0x10 as u8; pkt[14] = 0x0a as u8; pkt[15] = 0x63 as u8;
    pkt[16] = 0xac as u8; pkt[17] = 0x10 as u8; pkt[18] = 0x0a as u8; pkt[19] = 0x0c as u8;

    uart_puts("=== valid packet ===\r\n");
    parse_ipv4(pkt as []u8, 20);

    // Corrupt TTL after the checksum was computed for the original bytes,
    // so the checksum field no longer matches the header -- demonstrates
    // detecting a corrupted/tampered header.
    pkt[8] = 1 as u8;
    uart_puts("=== corrupted packet (TTL changed after checksum) ===\r\n");
    parse_ipv4(pkt as []u8, 20);
}
