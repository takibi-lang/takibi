// Demo of printing a pointer address.
// The pointer is first cast to usize (full 64-bit address), then truncated
// to i32 for uart_print_hex (which prints 32 bits).
// On QEMU all addresses are below 4 GB so no bits are lost.

fn main() {
    uart_puts("=== print_ptr test ===\r\n");

    let uart: *io u8 = 0x09000000;
    uart_puts("uart: ");
    uart_print_hex((uart as usize) as i32);
    uart_puts("\r\n");

    uart_puts("done\r\n");
}
