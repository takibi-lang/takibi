// Demo of a 1-second polling delay using the PL031 RTC.

fn delay_seconds(n: i32) {
    let rtc: *io i32 = 0x09010000; // PL031 RTC DR: 1-second resolution counter
    let start: i32 = *rtc;
    while (*rtc - start < n) {}
}

fn main() {
    uart_puts("waiting 1s...\r\n");
    delay_seconds(1);
    uart_puts("done\r\n");
}

