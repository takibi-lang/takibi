// PL031 RTC でポーリング 1 秒 delay のデモ。
fn uart_putc(c: char) {
    let dr: *char = 0x09000000;
    *dr = c;
}

fn uart_puts(s: *char) {
    while (*s != '\0') {
        uart_putc(*s);
        s = s + 1;
    }
}

fn delay_seconds(n: int) {
    let rtc: *int = 0x09010000; // PL031 RTC DR: 1 秒粒度のカウンタ
    let start: int = *rtc;
    while (*rtc - start < n) {}
}

fn main() {
    uart_puts("waiting 1s...\r\n");
    delay_seconds(1);
    uart_puts("done\r\n");
}
