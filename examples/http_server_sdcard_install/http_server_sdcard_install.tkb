// GitHub issue #97: test/provisioning-only firmware that writes a real
// FAT12 image onto examples/http_server_sdcard's actual SD card via
// sdmmc.tkb's disk_write -- so both `make hwcheck-net` and
// `make stm32-http-server-sdcard` can provision known file content on the
// card with no human ever touching it. See scripts/
// provision_http_server_sdcard.sh for the harness side (used by both of
// those Makefile targets, not duplicated between them).
//
// Mirrors scripts/run_hwtest_ram.sh's existing ram_load_and_run_seeded
// technique (which injects a host-built seed image directly into
// examples/fatfs's in-memory `disk` array over the debug port), but
// relays the injected bytes onward through the real SDMMC1 driver instead
// of just leaving them in RAM for the CPU to read: the harness injects the
// image into `staging` below (timed at a breakpoint on app_main, after
// BSS-clear but before anything reads it), then this program copies it
// sector-by-sector onto the real card. install_done() is called as the
// very last statement, giving the harness a second breakpoint address that
// is only ever reached once every disk_write has genuinely completed --
// `wait_halt` on that breakpoint is a hard synchronization point, not a
// UART-quietness guess. install_result is read back at that same halt
// (via OpenOCD's mrw, not UART) so the harness can tell a genuine write
// failure or "no card inserted" apart from a successful provisioning run
// -- see that variable's own comment.
//
// No QEMU build (no virtual SD/USB controller). Never run interactively;
// exists solely as provisioning infrastructure for http_server_sdcard.tkb,
// part of the same milestone. Shared across STM32 and Raspberry Pi 3B
// (GitHub issue #145): the storage driver (sdmmc.tkb's real SDMMC1, or
// usb_msc.tkb's USB Mass Storage) comes from the compile command line
// per target, same pattern as fatfs_sdcard.tkb -- on RPi3 the harness
// side is scripts/rpi3_provision_http_server_sdcard.sh (JTAG-breakpoint
// flavor of the same two-breakpoint sequence, see below).
//
// --forbid-trap clean: first written and verified against real hardware
// without --forbid-trap, per CLAUDE.md's Development Process section,
// then hardened in one pass together with http_server_sdcard.tkb once
// the whole milestone worked end to end. The one site --forbid-trap
// flagged here: `staging[off + i]` inside the sector-copy loop, where
// `off = s * SECTOR_SIZE` and s came from a `while (s < TOTAL_SECTORS as
// u32)` loop -- a plain runtime u32 with no provable range, unlike a
// `for` loop counter. Fixed by turning that into `for s: usize in
// 0..<TOTAL_SECTORS` (matching TOTAL_SECTORS's own declared type; a `for
// s: u32 in 0..<TOTAL_SECTORS` loop fails to typecheck instead, since
// TOTAL_SECTORS is usize-typed from its own declaration and takibi has
// no implicit int-width coercion -- the same "cannot unify usize with
// u32" error `let s: u32 = TOTAL_SECTORS;` without a cast would give;
// nothing for-loop-specific about it), with disk_write's own u32
// parameter satisfied by a single `s as u32` at its call site. Same
// if-narrowed-multiplier-times-for-loop-offset shape examples/common/
// fat12.tkb's own mem_block_read/mem_block_write already use for the
// identical "byte i of sector s in a flat buffer" proof.
//
use "examples/common/fat12_geometry.tkb";

// The test harness injects a real mtools-built FAT12 image here via
// OpenOCD's load_image, timed at a breakpoint on app_main -- same
// technique scripts/run_hwtest_ram.sh's ram_load_and_run_seeded already
// uses for examples/fatfs's `disk` array.
let mut staging: [u8; SECTOR_SIZE * TOTAL_SECTORS] align(32);

// Result code the harness reads back with OpenOCD's `mrw` once execution
// halts at install_done() -- a precise, deterministic status instead of
// scraping UART text. 0 = never set (should not be observable -- means
// the harness read this before install_done() ran); 1 = every disk_write
// succeeded; 2 = disk_initialize() failed (most likely: no card in the
// slot); 3 = disk_initialize() succeeded but at least one disk_write
// failed (card present but a write genuinely failed).
let mut install_result: u32 = 0;

fn install_done() {
    uart_puts("install: done\r\n");
}

fn app_main() {
    uart_puts("install: start\r\n");

    if (disk_initialize() == 0) {
        // The harness wrote `staging` directly over the debug port,
        // bypassing the D-cache -- invalidate before this CPU reads it
        // back (same reasoning as examples/fatfs/fatfs.tkb's Phase 1
        // dma_finish_rx call).
        dma_finish_rx(staging, SECTOR_SIZE * TOTAL_SECTORS);

        // align(32): RPi3's disk_write (usb_msc.tkb) requires a proven
        // *align(32) u8 (its dwc2_bulk_out path's own dma_prepare_tx
        // contract); STM32's disk_write takes plain *u8, which a
        // stricter-aligned pointer trivially satisfies.
        let mut sector_buf: [u8; SECTOR_SIZE] align(32);
        let mut all_ok: bool = true;
        // Loop counter is usize, matching TOTAL_SECTORS's own declared
        // type (needed for `staging`'s array size above) -- takibi has no
        // implicit int-width coercion, so a `for s: u32 in 0..<
        // TOTAL_SECTORS` loop would conflict with TOTAL_SECTORS's own
        // usize type at unification time (same error `let s: u32 =
        // TOTAL_SECTORS;` without a cast would give). Casting only the
        // one value disk_write actually needs as u32, right at its call
        // site, keeps TOTAL_SECTORS as the single source of truth instead
        // of duplicating its value as a second literal to keep in sync.
        for s: usize in 0..<TOTAL_SECTORS {
            let off: usize = s * SECTOR_SIZE;
            for i: usize in 0..<SECTOR_SIZE {
                sector_buf[i] = staging[off + i];
            }
            if (disk_write(s as u32, sector_buf) != 0) {
                all_ok = false;
            }
        }

        if (all_ok) {
            install_result = 1;
            uart_puts("install: OK\r\n");
        } else {
            install_result = 3;
            uart_puts("install: FAIL\r\n");
        }
    } else {
        install_result = 2;
        uart_puts("install: disk_initialize FAIL\r\n");
    }
    install_done();
}
