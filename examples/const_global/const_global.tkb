// Demo of global `let` (compile-time constant) vs `let mut` (variable), and
// of using a named constant as an array size.
//
// A plain global `let` is now an immutable compile-time constant, matching
// local variable semantics (`let` = immutable, `let mut` = variable).
// Reassigning it or taking its address is a compile error -- see
// examples/const_global_wrong/ for that case.
//
// QUEUE_SIZE must be declared with a literal integer initializer, and it
// must appear (textually, in the concatenated source) before its use as an
// array size below. No forward references, no constant folding -- only a
// bare literal initializer is recognized.

// usize, not i32: the for-loop below indexes `ring` with this bound
// directly, and array/slice indexing is usize-only (see CLAUDE.md's
// "Array/Slice Indices Must Be usize") -- the bound's own declared type is
// what the loop counter's base gets unified against, before any `for i:
// usize in ...` annotation would even get a chance to apply, so the
// constant itself must already be usize. Array-size resolution ([i32;
// QUEUE_SIZE] below) is unaffected: it works purely by VALUE, not type.
let QUEUE_SIZE: usize = 4;

// [i32; QUEUE_SIZE] -- resolved to [i32; 4] at parse time.
let mut ring: [i32; QUEUE_SIZE];

fn fill() {
    for i in 0..<QUEUE_SIZE {
        ring[i] = i * 10;
    }
}

fn main() {
    fill();
    uart_puts("QUEUE_SIZE = ");
    uart_print_uint(QUEUE_SIZE as i32);
    uart_puts("\r\n");
    for i in 0..<QUEUE_SIZE {
        uart_print_uint(ring[i]);
        uart_puts(" ");
    }
    uart_puts("\r\n");
    uart_puts("done\r\n");
}
