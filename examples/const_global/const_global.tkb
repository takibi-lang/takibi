// Demo of `const` (compile-time integer constant), global `let` (immutable
// runtime global), and `let mut` (variable), using a named constant as an
// array size and for-loop bound.
//
// `const` is the only declaration form recorded in Const_env for type-level
// integer positions. A plain global `let` is still immutable runtime storage,
// but it is deliberately not usable as an array-size/refinement constant.
// Reassigning a `const` is a compile error -- see
// examples/const_global_wrong/ for that case.
//
// QUEUE_SIZE must have a bare literal integer initializer, and it must appear
// (textually, in the concatenated source) before its use below. No forward
// references or constant folding are supported for Const_env.

// usize, not i32: the for-loop below indexes `ring` with this bound
// directly, and array/slice indexing is usize-only (see CLAUDE.md's
// "Array/Slice Indices Must Be usize") -- the bound's own declared type is
// what the loop counter's base gets unified against, before any `for i:
// usize in ...` annotation would even get a chance to apply, so the
// constant itself must already be usize. Array-size resolution ([i32;
// QUEUE_SIZE] below) is unaffected: it works purely by VALUE, not type.
const QUEUE_SIZE: usize = 4;

// [i32; QUEUE_SIZE] -- resolved to [i32; 4] at parse time.
let mut ring: [i32; QUEUE_SIZE];

fn fill() {
    for i in 0..<QUEUE_SIZE {
        ring[i] = i * 10;
    }
}

fn app_main() {
    fill();
    uart_puts("QUEUE_SIZE = ");
    uart_print(QUEUE_SIZE);
    uart_puts("\r\n");
    for i in 0..<QUEUE_SIZE {
        uart_print(ring[i]);
        uart_puts(" ");
    }
    uart_puts("\r\n");
    uart_puts("done\r\n");
}
