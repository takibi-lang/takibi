// TCP echo server -- grown incrementally across several sessions rather
// than split into separate examples (see CLAUDE.md's TCP section for why):
// unlike ARP/ICMP, TCP's stages (handshake -> data echo -> close) share
// one connection's state and can't be tested independently as separate
// binaries. Regression granularity instead comes from accumulating
// independent test functions in scripts/tcp_echo_test.py, one per stage,
// all run against this same kernel.
//
// Session 1: three-way handshake (LISTEN -> SYN_RCVD -> ESTABLISHED).
// Session 2: data echo once ESTABLISHED -- a received segment carrying
// data from the recorded connection, with the expected next sequence
// number, gets ACKed and echoed back verbatim in a single PSH|ACK reply.
// Session 3 (this one): connection close. A FIN from ESTABLISHED is
// answered with a combined FIN|ACK (ACKing the client's FIN and sending
// our own FIN in the same segment, since we never have unsent data of our
// own queued up -- real stacks do this too when there's nothing left to
// send), moving to LAST_ACK. The client's ACK of that FIN moves back to
// LISTEN, freeing the connection for a new client -- there is no
// CLOSE_WAIT/FIN_WAIT distinction here because both sides' FINs are
// combined into one segment instead of being independent events.
//
// Listens on TCP port 7 (the "Echo Protocol", RFC 862 -- a fitting choice
// for what this will become). Single connection only: while a handshake
// is in progress or a connection is established, SYNs from other clients
// are ignored rather than queued. Out-of-order data (seq != conn_rcv_nxt)
// is silently dropped rather than buffered or explicitly NAKed -- no
// retransmission timer exists on the sender side of this test harness, so
// reordering never actually happens in practice here. A FIN arriving
// together with its own data in the same segment is not supported -- the
// data is simply not echoed, only the FIN is processed -- since nothing
// in this test suite sends that combination.
//
// Single shared file for both targets -- see examples/net_echo/net_echo.tkb's
// header comment for why.
//
// SLICE MIGRATION (P4b): the handshake/close paths (build_syn_ack,
// build_fin_ack, fix_tcp_checksum, the request-checksum span, the TCP
// options skip) follow examples/http_server/http_server.tkb's fully-proven
// template exactly (see its header comment for the technique). The
// DATA-ECHO path is the one genuinely relational case this migration
// leaves as a runtime-checked (gradual) subslice rather than forcing a
// proof: `data_off` (where the payload starts, past any options) and
// `data_len` (how much payload there is) are two INDEPENDENTLY-derived
// quantities whose combination (`data_off + data_len <= frame's capacity`)
// is exactly the kind of two-variable fact plain interval arithmetic
// cannot carry, even with the same-base rule (which only handles a
// variable plus a COMPILE-TIME CONSTANT offset, not two runtime variables
// together) -- see CLAUDE.md's P4b section for the full accounting of why
// this is the honest boundary, not an oversight. Both the source view
// (`data`) and the reply's payload-inclusive span end up as recorded
// --forbid-trap sites; tcp_echo is NOT registered as a forbid_trap test
// (unlike http_server), and that is a deliberate, documented distinction,
// not a regression.

let mut our_mac: [u8; 6];

// IPv4 field offsets, relative to the start of the IP header.
let IP_TOTAL_LEN: i32 = 2;
let IP_TTL:       i32 = 8;
let IP_PROTOCOL:  i32 = 9;
let IP_CHECKSUM:  i32 = 10;
let IP_SRC:       i32 = 12;
let IP_DST:       i32 = 16;

// TCP field offsets, relative to the start of the TCP header.
let TCP_SRC_PORT:    i32 = 0;
let TCP_DST_PORT:    i32 = 2;
let TCP_SEQ:         i32 = 4;
let TCP_ACK:         i32 = 8;
let TCP_DATA_OFFSET: i32 = 12;
let TCP_FLAGS:       i32 = 13;
let TCP_WINDOW:      i32 = 14;
let TCP_CHECKSUM:    i32 = 16;
let TCP_URGENT:      i32 = 18;

let TCP_FLAG_FIN: i32 = 0x01;
let TCP_FLAG_SYN: i32 = 0x02;
let TCP_FLAG_RST: i32 = 0x04;
let TCP_FLAG_PSH: i32 = 0x08;
let TCP_FLAG_ACK: i32 = 0x10;

let PROTO_TCP:    i32 = 6;
let TCP_ECHO_PORT: i32 = 7;

// Fixed initial sequence number: no real security need for randomness in
// a bare-metal, single-connection, test-only responder.
let OUR_ISN: i32 = 0x00001000;

// Safe upper bound on the echoed payload: 1514 (frame capacity) - 14
// (eth) - 20 (IP) - 20 (TCP, no options in OUR reply) = 1460. Checked
// explicitly in build_data_echo before constructing the reply segment --
// see that function's comment.
let TCP_MAX_PAYLOAD: i32 = 1460;

let TCP_LISTEN:      i32 = 0;
let TCP_SYN_RCVD:    i32 = 1;
let TCP_ESTABLISHED: i32 = 2;
let TCP_LAST_ACK:    i32 = 3;

let mut conn_state:       i32 = 0; // TCP_LISTEN
let mut conn_remote_mac:  [u8; 6];
let mut conn_remote_ip:   [u8; 4];
let mut conn_remote_port: i32 = 0;
let mut conn_snd_nxt:     i32 = 0; // our next unacknowledged sequence number
let mut conn_rcv_nxt:     i32 = 0; // next sequence number we expect from remote

// Recomputes the TCP checksum over the pseudo-header implied by `ip` and
// the full segment `tcp_seg` (header + data -- ITS OWN LENGTH, read back
// via tcp_seg.len, is what goes in the pseudo-header's length field, so
// this can never disagree with the segment it's actually checksumming).
// Must be called last, after every other TCP field has its final value.
fn fix_tcp_checksum(ip: [u8; 20..], tcp_seg: [u8; 20..]) {
    write_u16be(tcp_seg[TCP_CHECKSUM..<TCP_URGENT], 0);
    let mut pseudo: [u8; 12];
    slice_copy(pseudo[0..<4], ip[IP_SRC..<IP_DST]);
    slice_copy(pseudo[4..<8], ip[IP_DST..<20]);
    pseudo[8] = 0 as u8;
    pseudo[9] = PROTO_TCP as u8;
    write_u16be(pseudo[10..<12], tcp_seg.len as i32);
    let sum: i32 = checksum_add(pseudo as []u8, 0);
    write_u16be(tcp_seg[TCP_CHECKSUM..<TCP_URGENT],
                checksum_fold(checksum_add(tcp_seg, sum)));
}

// Rewrites a SYN request into a SYN-ACK reply in place. Only called from
// TCP_LISTEN after the caller has already validated the request (IP/TCP
// checksums, dst port, SYN flag set).
fn build_syn_ack(eth: [u8; 54..], ihl: {20..<21}) {
    slice_copy(eth[0..<6], eth[6..<12]);
    slice_copy(eth[6..<12], our_mac as []u8);

    let ip  = eth[14..<34];
    let tcp = eth[34..<54];

    slice_copy(ip[IP_DST..<20],     ip[IP_SRC..<IP_DST]);
    slice_copy(ip[IP_SRC..<IP_DST], OUR_IP as []u8);
    ip[IP_TTL] = 64 as u8;
    write_u16be(ip[IP_TOTAL_LEN..<4], ihl + 20);
    write_u16be(ip[IP_CHECKSUM..<IP_SRC], 0);
    write_u16be(ip[IP_CHECKSUM..<IP_SRC], inet_checksum(ip[0..<ihl]));

    let client_port: i32 = read_u16be(tcp[TCP_SRC_PORT..<TCP_DST_PORT]);
    write_u16be(tcp[TCP_SRC_PORT..<TCP_DST_PORT], TCP_ECHO_PORT);
    write_u16be(tcp[TCP_DST_PORT..<TCP_SEQ], client_port);
    write_u32be(tcp[TCP_SEQ..<TCP_ACK], OUR_ISN);
    write_u32be(tcp[TCP_ACK..<TCP_DATA_OFFSET], conn_rcv_nxt);
    tcp[TCP_DATA_OFFSET] = (5 << 4) as u8; // 20-byte header, no options
    tcp[TCP_FLAGS] = (TCP_FLAG_SYN | TCP_FLAG_ACK) as u8;
    write_u16be(tcp[TCP_WINDOW..<TCP_CHECKSUM], 65535);
    write_u16be(tcp[TCP_URGENT..<20], 0);

    fix_tcp_checksum(ip, tcp);
}

// Rewrites a received data segment into an ACK|PSH reply carrying the
// same payload verbatim. `data` is a runtime-checked view of where the
// payload actually starts in the received segment (see the file header
// comment for why data_off/data_len can't be jointly proven); our own
// reply always uses a clean 20-byte header with no options, so the
// payload is copied down to eth+54 (tcp+20). slice_copy's forward loop is
// safe here even when the ranges overlap: the destination never leads the
// source (data_off is always >= 34+20, since the received header is at
// least 20 bytes), so by the time a byte is overwritten its original
// value has already been read -- unconditionally, so no `data != tcp+20`
// guard is needed (a same-address copy is just a harmless no-op).
// Only called from TCP_ESTABLISHED after the caller has already validated
// the request and confirmed seq == conn_rcv_nxt. Returns 1 on success, 0
// if data_len somehow exceeded TCP_MAX_PAYLOAD (never actually happens
// given the caller's own tcp_len bound, but see the explicit check below
// for why this needs to be enforced, not assumed, to construct tcp_seg
// with a proven minimum).
fn build_data_echo(eth: [u8; 1514..], ihl: {20..<21}, data: []u8, data_len: i32) -> i32 {
    // Snapshot into an immutable local after an explicit bound check: a
    // PLAIN i32 PARAMETER carries no range at all (unlike a refined local,
    // parameters can't cross a function boundary with a refined type
    // except by exact match -- see http_server.tkb's `ihl: {20..<21}`
    // comment for why). This mirrors http_server's HTTP_MAX_PAYLOAD
    // pattern: the check both PROVES tcp_seg's minimum (>= 20, needed by
    // fix_tcp_checksum) and fails safe if data_len is ever larger than
    // this responder's single-segment design supports.
    if (data_len >= 0 && data_len <= TCP_MAX_PAYLOAD) {
        let n: i32 = data_len;
        let tcp_seg = eth[34..<54 + n];

        // tcp_seg[20..<20+n]: tcp_seg's declared/proven minimum is only 20
        // (the worst case n=0), but its ACTUAL runtime length is exactly
        // 20+n by construction just above -- the type system only
        // remembers the conservative minimum, not that exact construction
        // history, so this specific subslice can't reuse the n>=0 fact
        // already established (same-base needs lo_e to be a bare
        // variable; here lo_e is the literal 20, not tcp_seg's own base).
        // unsafe is appropriate: n was ALREADY bounds-checked above (the
        // `if` this is nested in), so this is a real assertion backed by
        // evidence one line up, not a guess -- see CLAUDE.md's P4c
        // section (this is one of tcp_echo's two documented unsafe sites).
        slice_copy(unsafe { tcp_seg[20..<20 + n] }, data);

        slice_copy(eth[0..<6], eth[6..<12]);
        slice_copy(eth[6..<12], our_mac as []u8);

        let ip = eth[14..<34];

        slice_copy(ip[IP_DST..<20],     ip[IP_SRC..<IP_DST]);
        slice_copy(ip[IP_SRC..<IP_DST], OUR_IP as []u8);
        ip[IP_TTL] = 64 as u8;
        write_u16be(ip[IP_TOTAL_LEN..<4], ihl + 20 + n);
        write_u16be(ip[IP_CHECKSUM..<IP_SRC], 0);
        write_u16be(ip[IP_CHECKSUM..<IP_SRC], inet_checksum(ip[0..<ihl]));

        let client_port: i32 = read_u16be(tcp_seg[TCP_SRC_PORT..<TCP_DST_PORT]);
        write_u16be(tcp_seg[TCP_SRC_PORT..<TCP_DST_PORT], TCP_ECHO_PORT);
        write_u16be(tcp_seg[TCP_DST_PORT..<TCP_SEQ], client_port);
        write_u32be(tcp_seg[TCP_SEQ..<TCP_ACK], conn_snd_nxt);
        write_u32be(tcp_seg[TCP_ACK..<TCP_DATA_OFFSET], conn_rcv_nxt + n);
        tcp_seg[TCP_DATA_OFFSET] = (5 << 4) as u8;
        tcp_seg[TCP_FLAGS] = (TCP_FLAG_ACK | TCP_FLAG_PSH) as u8;
        write_u16be(tcp_seg[TCP_WINDOW..<TCP_CHECKSUM], 65535);
        write_u16be(tcp_seg[TCP_URGENT..<20], 0);

        fix_tcp_checksum(ip, tcp_seg);
        return 1;
    }
    return 0;
}

// Rewrites a received FIN into a combined FIN|ACK reply: ACKs the
// client's FIN (which consumes one sequence number, already folded into
// conn_rcv_nxt by the caller) and sends our own FIN in the same segment.
// Only called from TCP_ESTABLISHED after the caller has already validated
// the request and confirmed seq == conn_rcv_nxt (before incrementing it).
fn build_fin_ack(eth: [u8; 54..], ihl: {20..<21}) {
    slice_copy(eth[0..<6], eth[6..<12]);
    slice_copy(eth[6..<12], our_mac as []u8);

    let ip  = eth[14..<34];
    let tcp = eth[34..<54];

    slice_copy(ip[IP_DST..<20],     ip[IP_SRC..<IP_DST]);
    slice_copy(ip[IP_SRC..<IP_DST], OUR_IP as []u8);
    ip[IP_TTL] = 64 as u8;
    write_u16be(ip[IP_TOTAL_LEN..<4], ihl + 20);
    write_u16be(ip[IP_CHECKSUM..<IP_SRC], 0);
    write_u16be(ip[IP_CHECKSUM..<IP_SRC], inet_checksum(ip[0..<ihl]));

    let client_port: i32 = read_u16be(tcp[TCP_SRC_PORT..<TCP_DST_PORT]);
    write_u16be(tcp[TCP_SRC_PORT..<TCP_DST_PORT], TCP_ECHO_PORT);
    write_u16be(tcp[TCP_DST_PORT..<TCP_SEQ], client_port);
    write_u32be(tcp[TCP_SEQ..<TCP_ACK], conn_snd_nxt);
    write_u32be(tcp[TCP_ACK..<TCP_DATA_OFFSET], conn_rcv_nxt);
    tcp[TCP_DATA_OFFSET] = (5 << 4) as u8;
    tcp[TCP_FLAGS] = (TCP_FLAG_FIN | TCP_FLAG_ACK) as u8;
    write_u16be(tcp[TCP_WINDOW..<TCP_CHECKSUM], 65535);
    write_u16be(tcp[TCP_URGENT..<20], 0);

    fix_tcp_checksum(ip, tcp);
}

fn main() {
    uart_puts("tcp_echo: init\r\n");

    if (net_init() == 0) {
        uart_puts("tcp_echo: device/link not found\r\n");
    } else {
        net_read_mac(our_mac as *u8);

        uart_puts("tcp_echo: ready\r\n");

        while (1) {
            let len: i32 = net_poll_rx();
            let mut should_tx: i32 = 0;
            let mut tx_len: i32 = 0;
            let frame = net_rx_frame();   // [u8; 1514..] capacity view

            // 14 (eth) + 20 (min IPv4) + 20 (min TCP) = 54
            if (len >= 54 && len <= 1514) {
                if (read_u16be(frame[12..<14]) == 0x0800) {
                    let ip = frame[14..<34];
                    let version: i32 = (ip[0] as i32) >> 4;
                    let ihl:     i32 = ((ip[0] as i32) & 0x0f) * 4;

                    if (version == 4 && ihl == 20) {
                        let total_len:       i32 = read_u16be(ip[IP_TOTAL_LEN..<4]);
                        let ip_len_in_frame: i32 = len - 14;

                        if (total_len <= ip_len_in_frame && total_len >= ihl &&
                            (ip[IP_PROTOCOL] as i32) == PROTO_TCP &&
                            inet_checksum(ip[0..<ihl]) == 0) {
                            if (slice_eq(ip[IP_DST..<20], OUR_IP as []u8)) {
                                let tcp:     [u8; 20..] = frame[34..<54];
                                let tcp_len: i32 = total_len - ihl;

                                let doff: i32 = (tcp[TCP_DATA_OFFSET] as i32) >> 4;

                                // doff must be narrowed to {5..<16} BEFORE
                                // tcp_hdr_len = doff * 4 is computed, so
                                // Mul propagation gives tcp_hdr_len (and
                                // later data_off) a real range -- see
                                // http_server.tkb's identical comment.
                                if (tcp_len >= 20 && doff >= 5 && doff <= 15) {
                                let tcp_hdr_len: i32 = doff * 4;  // {20..<61}

                                if (tcp_len >= tcp_hdr_len) {
                                    let mut pseudo: [u8; 12];
                                    slice_copy(pseudo[0..<4], ip[IP_SRC..<IP_DST]);
                                    slice_copy(pseudo[4..<8], ip[IP_DST..<20]);
                                    pseudo[8] = 0 as u8;
                                    pseudo[9] = PROTO_TCP as u8;
                                    write_u16be(pseudo[10..<12], tcp_len);
                                    let sum: i32 = checksum_add(pseudo as []u8, 0);
                                    let tcp_seg = frame[34..<34 + tcp_len];

                                    if (checksum_fold(checksum_add(tcp_seg, sum)) == 0) {
                                        let dst_port: i32 = read_u16be(tcp[TCP_DST_PORT..<TCP_SEQ]);
                                        let src_port: i32 = read_u16be(tcp[TCP_SRC_PORT..<TCP_DST_PORT]);
                                        let flags:    i32 = tcp[TCP_FLAGS] as i32;
                                        let seq:      i32 = read_u32be(tcp[TCP_SEQ..<TCP_ACK]);
                                        let ack:      i32 = read_u32be(tcp[TCP_ACK..<TCP_DATA_OFFSET]);

                                        if (dst_port == TCP_ECHO_PORT) {
                                            if (conn_state == TCP_LISTEN) {
                                                if ((flags & TCP_FLAG_SYN) != 0) {
                                                    slice_copy(conn_remote_mac as []u8, frame[6..<12]);
                                                    slice_copy(conn_remote_ip as []u8, ip[IP_SRC..<IP_DST]);
                                                    conn_remote_port = src_port;
                                                    conn_rcv_nxt = seq + 1;
                                                    conn_snd_nxt = OUR_ISN + 1;

                                                    build_syn_ack(frame, ihl);
                                                    should_tx = 1;
                                                    tx_len = 14 + ihl + 20;
                                                    conn_state = TCP_SYN_RCVD;
                                                }
                                            } else {
                                                // SYN_RCVD, ESTABLISHED, or LAST_ACK: only the
                                                // recorded connection's segments matter.
                                                if (slice_eq(ip[IP_SRC..<IP_DST], conn_remote_ip as []u8) &&
                                                    src_port == conn_remote_port) {
                                                    if ((flags & TCP_FLAG_RST) != 0) {
                                                        // Abrupt close from the client: drop the
                                                        // connection with no reply and free the slot.
                                                        conn_state = TCP_LISTEN;
                                                    } else if (conn_state == TCP_SYN_RCVD) {
                                                        if ((flags & TCP_FLAG_ACK) != 0 &&
                                                            (flags & TCP_FLAG_SYN) == 0 &&
                                                            ack == conn_snd_nxt && seq == conn_rcv_nxt) {
                                                            conn_state = TCP_ESTABLISHED;
                                                        }
                                                    } else if (conn_state == TCP_ESTABLISHED) {
                                                        if ((flags & TCP_FLAG_FIN) != 0 && seq == conn_rcv_nxt) {
                                                            conn_rcv_nxt = conn_rcv_nxt + 1; // FIN consumes one seq number
                                                            build_fin_ack(frame, ihl);
                                                            should_tx = 1;
                                                            tx_len = 14 + ihl + 20;
                                                            conn_snd_nxt = conn_snd_nxt + 1; // our FIN too
                                                            conn_state = TCP_LAST_ACK;
                                                        } else {
                                                            let data_len: i32 = tcp_len - tcp_hdr_len;
                                                            let data_off: i32 = 34 + tcp_hdr_len;
                                                            if (data_len > 0 &&
                                                                (flags & TCP_FLAG_ACK) != 0 &&
                                                                seq == conn_rcv_nxt) {
                                                                // data_off + data_len == 34 + tcp_len always
                                                                // (algebraic identity: data_off = 34 +
                                                                // tcp_hdr_len, data_len = tcp_len -
                                                                // tcp_hdr_len), which fits frame's capacity --
                                                                // but data_off and data_len are tracked as two
                                                                // INDEPENDENT ranges, so combining them loses
                                                                // that correlation (data_len's own Sub-derived
                                                                // range even has a spuriously negative lower
                                                                // bound, since it can't see the
                                                                // tcp_len>=tcp_hdr_len guard that makes it
                                                                // real). The `data_len > 0` check just above
                                                                // is the actual runtime evidence; unsafe here
                                                                // is a documented assertion backed by it, not
                                                                // a guess -- see CLAUDE.md's P4c section (the
                                                                // other of tcp_echo's two documented unsafe
                                                                // sites; this is exactly the pattern that
                                                                // would need a genuine relational/
                                                                // difference-constraint domain to prove
                                                                // outright, deliberately deferred).
                                                                let data = unsafe { frame[data_off..<data_off + data_len] };
                                                                if (build_data_echo(frame, ihl, data, data_len) == 1) {
                                                                    should_tx = 1;
                                                                    tx_len = 14 + ihl + 20 + data_len;
                                                                    conn_rcv_nxt = conn_rcv_nxt + data_len;
                                                                    conn_snd_nxt = conn_snd_nxt + data_len;
                                                                }
                                                            }
                                                        }
                                                    } else if (conn_state == TCP_LAST_ACK) {
                                                        if ((flags & TCP_FLAG_ACK) != 0 && ack == conn_snd_nxt) {
                                                            // Close complete; ready for a new client.
                                                            conn_state = TCP_LISTEN;
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                                }
                            }
                        }
                    }
                }
            }

            if (should_tx == 1) {
                net_transmit(frame as *u8, tx_len);
            }
            if (len > 0) {
                net_rx_release();
            }
        }
    }
}
