// Basic demo of global variables, if/else/while, function calls, and UART output.
// uart_print_int recursively prints a signed integer in decimal.
let g_int = 1;
let g_char: u8 = 0;

fn uart_putc(c: u8) {
    let dr: *io u8 = 0x09000000; // PL011 UART DR: write to transmit
    *dr = c;
}

fn uart_puts(s: *u8) {
    while (*s != 0) {
        uart_putc(*s);
        s = s + 1;
    }
}

fn print_uint(n: i32) {
    if (n >= 10) {
        print_uint(n / 10);
    }
    uart_putc((n - (n / 10) * 10 + '0') as u8);
}

fn uart_print_int(n: i32) {
    if (n < 0) {
        uart_putc('-');
        print_uint(-n);
    } else {
        print_uint(n);
    }
}

fn foo(c: i32) i32 {
    return 1;
}

fn bar(a: i32, b: i32) i32 {
    let mut r = 0;

    if (2 * a + 1 > b) {
        while (r != 0) {
            r = foo(a);
        }
        return r;
    } else {
        r = g_int;
    }

    return r;
}

fn main() {
    uart_puts("foo(5)=");
    uart_print_int(foo(5));
    uart_putc('\r');
    uart_putc('\n');
    uart_puts("bar(3,4)=");
    uart_print_int(bar(3, 4));
    uart_putc('\r');
    uart_putc('\n');
    uart_puts("bar(1,10)=");
    uart_print_int(bar(1, 10));
    uart_putc('\r');
    uart_putc('\n');
}
