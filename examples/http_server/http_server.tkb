// HTTP server -- the payoff of the whole
// net_echo -> arp_reply -> icmp_echo -> tcp_echo progression. Serves a
// single styled HTML page with a live request counter on port 80.
//
// Combines two things no earlier example needed together in the same
// kernel:
//   - ARP response (reused from examples/arp_reply's approach). A real
//     client's TCP/IP stack always ARPs before sending IP packets, unlike
//     the point-to-point test transports the other four examples are
//     verified with -- see git history / CLAUDE.md's HTTP Server section.
//   - TCP's active-close variant: after answering we initiate the close
//     ourselves, combining the response data with our own FIN in one
//     segment (build_http_response_fin). TCP_LAST_ACK is entered from both
//     paths (passive FIN-ACK reply or active response+FIN) and handles
//     both identically: wait for the final ACK, then return to LISTEN.
//
// SLICE MIGRATION (P3/P4): this is a fully slice-based protocol kernel,
// with --forbid-trap clean end to end (locked in by forbid_trap_http_server
// in run_qemutest.sh). The layering of proof:
//   - net_rx_frame() returns a [u8; 1514..] capacity view; the single
//     unsafe length assertion lives inside the driver, next to its
//     evidence (see virtio_mmio.tkb / eth.tkb).
//   - Every header field read/write goes through constant-offset subslice
//     views (frame[14..<34] -> ip, frame[34..<54] -> tcp) and the
//     slice-based read/write_u16be/u32be helpers -- all compile-time
//     proven, zero runtime checks. Named offset constants double as
//     subslice bounds (arp[ARP_SHA..<ARP_SPA]) and as proven indices
//     (tcp[TCP_FLAGS]); adjacent protocol offsets line up exactly.
//   - The device-reported length is clamped ONCE (`len <= 1514` in the
//     IPv4 branch condition) before anything trusts it.
//   - `ihl` is typed `{20..<21}` in every function that receives it: this
//     file's scope is "no IP options" (IHL always exactly 20), and an
//     EXACT-match refined parameter type turns that existing runtime
//     precondition (previously just an `if`) into something the checksum
//     span proofs below can build on. The two sites narrowing ihl to
//     exactly {20..<21} (main()'s `ihl == 20` check) always match this
//     exactly, so every call typechecks.
//   - Checksum spans are constructed as SLICES, not pointer+length pairs
//     (fix_tcp_checksum takes tcp_seg: [u8; 20..] directly, and reads its
//     own length back via tcp_seg.len for the pseudo-header -- no integer
//     length parameter can disagree with the segment it describes). The
//     variable-length span in the request path (`frame[34..<34+tcp_len]`)
//     and in the reply path (`eth[34..<54+len]`) are both proven by P4a's
//     interval-propagation chain (total_len/tcp_len/len all carry a
//     {lo..<hi} range from their narrowing all the way to the subslice),
//     not by any relational solver.
//   - The TCP-options skip (`frame[data_off..<data_off+3]`, the "GET"
//     sniff) is proven by P4a's same-base subslice rule: data_off's exact
//     value is unconstrained, but the length (3) and the lo<=hi obligation
//     are both syntactic facts about `data_off + 0 .. data_off + 3`.
//   - The response length is explicitly bounded (`len <= HTTP_MAX_PAYLOAD`)
//     before it is trusted for the reply's checksum span, IP total_len
//     field, and tx_len -- this both PROVES the checksum span (turns an
//     undocumented "the page happens to be small" assumption into an
//     enforced precondition) and fails safe (drops the reply rather than
//     ever constructing an oversized segment) if the page is ever edited
//     to grow past the margin. See HTTP_MAX_PAYLOAD's comment for the
//     exact worst-case computation this margin is checked against.
//
// Remaining POINTER ISLAND: building the response body/headers themselves
// (copy_str/write_udec appends into a raw pointer -- see build_html_body /
// build_http_response_fin). This is deliberately NOT migrated to bounded
// slice appends here: copy_str/write_udec are recursive/incremental over
// an unbounded destination with no way to know at compile time how much
// room is left, and proving that needs new bounded-append primitives
// (a capacity-aware writer that returns how much space remains), not
// just the subslice/interval machinery this file already uses elsewhere.
// The margin is enforced (see HTTP_MAX_PAYLOAD above) but the WRITES
// themselves are not individually bounds-checked -- safe today only
// because html_body (512 bytes) and the payload area (up to 1460 bytes)
// both comfortably exceed the computed 525-byte worst case. This is the
// one item still deferred past P4b.
//
// Single shared file for both targets; our_ip comes from HTTP_SERVER_IP
// (see netconfig.tkb comments for why it differs from OUR_IP on QEMU).
//
// Request parsing is minimal: any ESTABLISHED-state segment whose payload
// starts with "GET" is answered with the same fixed page.

let mut our_mac: [u8; 6];
let mut our_ip:  [u8; 4];

// ARP-over-Ethernet/IPv4 field offsets, relative to the start of the ARP
// payload (right after the 14-byte Ethernet header). Adjacent constants
// double as subslice bounds: arp[ARP_SHA..<ARP_SPA] is exactly the 6-byte
// sender MAC field.
let ARP_HTYPE: usize = 0;
let ARP_PTYPE: usize = 2;
let ARP_HLEN:  usize = 4;
let ARP_PLEN:  usize = 5;
let ARP_OPER:  usize = 6;
let ARP_SHA:   usize = 8;
let ARP_SPA:   usize = 14;
let ARP_THA:   usize = 18;
let ARP_TPA:   usize = 24;

// IPv4 field offsets, relative to the start of the IP header.
let IP_TOTAL_LEN: usize = 2;
let IP_TTL:       usize = 8;
let IP_PROTOCOL:  usize = 9;
let IP_CHECKSUM:  usize = 10;
let IP_SRC:       usize = 12;
let IP_DST:       usize = 16;

// TCP field offsets, relative to the start of the TCP header.
let TCP_SRC_PORT:    usize = 0;
let TCP_DST_PORT:    usize = 2;
let TCP_SEQ:         usize = 4;
let TCP_ACK:         usize = 8;
let TCP_DATA_OFFSET: usize = 12;
let TCP_FLAGS:       usize = 13;
let TCP_WINDOW:      usize = 14;
let TCP_CHECKSUM:    usize = 16;
let TCP_URGENT:      usize = 18;

// TCP_FLAG_*/PROTO_TCP/HTTP_PORT are wire-VALUE constants compared
// directly against a byte/half-word field, so they take that field's
// natural width -- unlike the pure offset constants above, which are
// usize (array/slice indices are usize-only, see CLAUDE.md's "Array/Slice
// Indices Must Be usize" section). ihl/total_len/tcp_len/tcp_hdr_len/data_len/data_off
// below are ALSO u16-based: `len` (net_poll_rx()'s deliberately
// -unconstrained i32 device-reported length) is bridged into u16 with
// ONE explicit refined cast right after its own range is established,
// and everything downstream inherits u16-based refined ranges through
// ordinary Add/Sub/comparison propagation from there (same technique as
// tcp_echo.tkb).
let TCP_FLAG_FIN: u8 = 0x01;
let TCP_FLAG_SYN: u8 = 0x02;
let TCP_FLAG_RST: u8 = 0x04;
let TCP_FLAG_PSH: u8 = 0x08;
let TCP_FLAG_ACK: u8 = 0x10;

let PROTO_TCP: u8 = 6;
let HTTP_PORT: u16 = 80;

let OUR_ISN: u32 = 0x00001000;

enum ConnState: u8 {
    Listen;
    SynRcvd;
    Established;
    LastAck;
}

let mut conn_state:       ConnState = ConnState::Listen;
let mut conn_remote_ip:   [u8; 4];
let mut conn_remote_port: u16 = 0;
let mut conn_snd_nxt:     u32 = 0;
let mut conn_rcv_nxt:     u32 = 0;

let mut request_count: i32 = 0;

// Staging buffer for the HTML body (built once per request, then copied
// after the headers into the reply segment -- see build_http_response_fin).
let mut html_body: [u8; 512];

// Safe upper bound on the total reply payload (headers + body), checked
// explicitly in build_http_response_fin before anything downstream trusts
// it. Exact worst case with the current fixed page and a 10-digit (i32
// max) request counter: 76 ("HTTP/1.1 200 OK...Content-Length: ") + 10
// (digits of body_len) + 23 ("\r\nConnection: close\r\n\r\n") + 369 (HTML
// prefix) + 10 (digits of request_count) + 37 (HTML suffix) = 525 bytes.
// 700 leaves a comfortable margin for editing the page without silently
// reopening the overflow this check exists to prevent.
let HTTP_MAX_PAYLOAD: i32 = 700;

fn build_html_body() -> isize {
    let mut len: isize = 0;
    len = len + copy_str(html_body + len,
        "<!DOCTYPE html><html><head><title>Takibi</title><style>body{background:#111;color:#eee;font-family:monospace;text-align:center;padding-top:8%}h1{color:#ff9944}p{color:#999}.count{color:#6cf}</style></head><body><h1>Hello from Takibi!</h1><p>Served by a TCP/IP stack written from scratch<br>in the takibi language, running bare-metal.</p><p>Request <span class='count'>#");
    len = len + write_udec(html_body + len, request_count);
    len = len + copy_str(html_body + len, "</span> since boot.</p></body></html>");
    return len;
}

// Rewrites a received ARP request into a reply in place. Only called
// after the caller has already verified this is a "who-has our_ip"
// request. Every access below is a compile-time-proven subslice of the
// >= 42-byte view the caller narrowed.
fn build_arp_reply(eth: [u8; 42..]) {
    let arp = eth[14..<42];

    slice_copy(eth[0..<6], eth[6..<12]);
    slice_copy(eth[6..<12], our_mac as []u8);

    slice_copy(arp[ARP_THA..<ARP_TPA], arp[ARP_SHA..<ARP_SPA]);
    slice_copy(arp[ARP_TPA..<28],      arp[ARP_SPA..<ARP_THA]);
    slice_copy(arp[ARP_SHA..<ARP_SPA], our_mac as []u8);
    slice_copy(arp[ARP_SPA..<ARP_THA], our_ip as []u8);
    write_u16be(arp[ARP_OPER..<ARP_SHA], 2);
}

// Recomputes the TCP checksum over the pseudo-header implied by `ip` and
// the full segment `tcp_seg` (header + data -- ITS OWN LENGTH, read back
// via tcp_seg.len, is what goes in the pseudo-header's length field, so
// this can never disagree with the segment it's actually checksumming).
// Must be called last, after every other TCP field has its final value.
// tcp_seg's declared minimum (20) only needs to cover the fixed header
// fields written below; checksum_add's `for b in tcp_seg` walks the
// segment's REAL runtime length regardless of that static minimum.
fn fix_tcp_checksum(ip: [u8; 20..], tcp_seg: [u8; 20..]) {
    write_u16be(tcp_seg[TCP_CHECKSUM..<TCP_URGENT], 0);
    let mut pseudo: [u8; 12];
    slice_copy(pseudo[0..<4], ip[IP_SRC..<IP_DST]);
    slice_copy(pseudo[4..<8], ip[IP_DST..<20]);
    pseudo[8] = 0 as u8;
    pseudo[9] = PROTO_TCP;
    write_u16be(pseudo[10..<12], tcp_seg.len as i32);
    let sum: i32 = checksum_add(pseudo as []u8, 0);
    write_u16be(tcp_seg[TCP_CHECKSUM..<TCP_URGENT],
                checksum_fold(checksum_add(tcp_seg, sum)));
}

fn build_syn_ack(eth: [u8; 54..], ihl: {20..<21 as u16}) {
    slice_copy(eth[0..<6], eth[6..<12]);
    slice_copy(eth[6..<12], our_mac as []u8);

    let ip  = eth[14..<34];
    let tcp = eth[34..<54];

    slice_copy(ip[IP_DST..<20],      ip[IP_SRC..<IP_DST]);
    slice_copy(ip[IP_SRC..<IP_DST],  our_ip as []u8);
    ip[IP_TTL] = 64 as u8;
    write_u16be(ip[IP_TOTAL_LEN..<4], ihl + 20);
    write_u16be(ip[IP_CHECKSUM..<IP_SRC], 0);
    write_u16be(ip[IP_CHECKSUM..<IP_SRC],
                inet_checksum(ip[0..<ihl as {20..<21 as usize}]));

    let client_port: u16 = read_u16be(tcp[TCP_SRC_PORT..<TCP_DST_PORT]) as u16;
    write_u16be(tcp[TCP_SRC_PORT..<TCP_DST_PORT], HTTP_PORT as i32);
    write_u16be(tcp[TCP_DST_PORT..<TCP_SEQ], client_port as i32);
    write_u32be(tcp[TCP_SEQ..<TCP_ACK], OUR_ISN as i32);
    write_u32be(tcp[TCP_ACK..<TCP_DATA_OFFSET], conn_rcv_nxt as i32);
    tcp[TCP_DATA_OFFSET] = (5 << 4) as u8;
    tcp[TCP_FLAGS] = TCP_FLAG_SYN | TCP_FLAG_ACK;
    write_u16be(tcp[TCP_WINDOW..<TCP_CHECKSUM], 65535);
    write_u16be(tcp[TCP_URGENT..<20], 0);

    fix_tcp_checksum(ip, tcp);
}

fn build_fin_ack(eth: [u8; 54..], ihl: {20..<21 as u16}) {
    slice_copy(eth[0..<6], eth[6..<12]);
    slice_copy(eth[6..<12], our_mac as []u8);

    let ip  = eth[14..<34];
    let tcp = eth[34..<54];

    slice_copy(ip[IP_DST..<20],     ip[IP_SRC..<IP_DST]);
    slice_copy(ip[IP_SRC..<IP_DST], our_ip as []u8);
    ip[IP_TTL] = 64 as u8;
    write_u16be(ip[IP_TOTAL_LEN..<4], ihl + 20);
    write_u16be(ip[IP_CHECKSUM..<IP_SRC], 0);
    write_u16be(ip[IP_CHECKSUM..<IP_SRC],
                inet_checksum(ip[0..<ihl as {20..<21 as usize}]));

    let client_port: u16 = read_u16be(tcp[TCP_SRC_PORT..<TCP_DST_PORT]) as u16;
    write_u16be(tcp[TCP_SRC_PORT..<TCP_DST_PORT], HTTP_PORT as i32);
    write_u16be(tcp[TCP_DST_PORT..<TCP_SEQ], client_port as i32);
    write_u32be(tcp[TCP_SEQ..<TCP_ACK], conn_snd_nxt as i32);
    write_u32be(tcp[TCP_ACK..<TCP_DATA_OFFSET], conn_rcv_nxt as i32);
    tcp[TCP_DATA_OFFSET] = (5 << 4) as u8;
    tcp[TCP_FLAGS] = TCP_FLAG_FIN | TCP_FLAG_ACK;
    write_u16be(tcp[TCP_WINDOW..<TCP_CHECKSUM], 65535);
    write_u16be(tcp[TCP_URGENT..<20], 0);

    fix_tcp_checksum(ip, tcp);
}

// Builds "HTTP/1.1 200 OK ... <html>...</html>" into the payload area
// (overwriting the request that was there), combined with our own FIN.
// Returns the total payload length (headers + body) on success, or -1 if
// it would have exceeded HTTP_MAX_PAYLOAD (never actually happens with
// the current fixed page; the caller must check for this and drop the
// reply rather than transmit, see main()'s use of the return value).
fn build_http_response_fin(eth: [u8; 1514..], ihl: {20..<21 as u16}) -> i32 {
    let body_len: isize = build_html_body();

    let payload: *u8 = (eth as *u8) + 54;
    let mut len: isize = 0;
    len = len + copy_str(payload + len,
        "HTTP/1.1 200 OK\r\nContent-Type: text/html; charset=us-ascii\r\nContent-Length: ");
    len = len + write_udec(payload + len, body_len as i32);
    len = len + copy_str(payload + len, "\r\nConnection: close\r\n\r\n");
    bytes_copy(payload + len, html_body as *u8, body_len);
    len = len + body_len;

    let wire_len: i32 = len as i32;
    if (len >= 0 && len <= (HTTP_MAX_PAYLOAD as isize)
        && wire_len >= 0 && wire_len <= HTTP_MAX_PAYLOAD) {
        // Snapshot the narrowed range into an IMMUTABLE local: codegen's
        // if-narrowing for a MUTABLE variable (narrowing_ctx) is only
        // consulted when the variable is used directly as an index/bound,
        // not when it's buried inside an arithmetic expression like
        // `54 + len` -- see CLAUDE.md's P4a "known conservative gap".
        // An immutable `let` carries its narrowed type directly (the same
        // B-plan mechanism that makes `let x: i32 = refined_v;` keep
        // refined_v's range), so plain arithmetic on `n` below is fully
        // visible to codegen with no gap.
        let n: i32 = wire_len;
        let n_idx: usize = n as {0..<701 as usize};

        slice_copy(eth[0..<6], eth[6..<12]);
        slice_copy(eth[6..<12], our_mac as []u8);

        let ip      = eth[14..<34];
        let tcp_seg = eth[34..<54 + n_idx];

        slice_copy(ip[IP_DST..<20],     ip[IP_SRC..<IP_DST]);
        slice_copy(ip[IP_SRC..<IP_DST], our_ip as []u8);
        ip[IP_TTL] = 64 as u8;
        // n here is the HTTP response length (app-level byte count,
        // bounded by HTTP_MAX_PAYLOAD, unrelated to the wire ihl/tcp_len
        // chain -- stays i32, matching body_len/payload_len elsewhere in
        // this file), so ihl (u16) needs an explicit upcast to combine
        // with it; ihl's own refined-ness isn't needed for this VALUE
        // computation, only for the `ip[0..<ihl]` slice bound below.
        write_u16be(ip[IP_TOTAL_LEN..<4], (ihl as i32) + 20 + n);
        write_u16be(ip[IP_CHECKSUM..<IP_SRC], 0);
        write_u16be(ip[IP_CHECKSUM..<IP_SRC],
                    inet_checksum(ip[0..<ihl as {20..<21 as usize}]));

        let client_port: u16 = read_u16be(tcp_seg[TCP_SRC_PORT..<TCP_DST_PORT]) as u16;
        write_u16be(tcp_seg[TCP_SRC_PORT..<TCP_DST_PORT], HTTP_PORT as i32);
        write_u16be(tcp_seg[TCP_DST_PORT..<TCP_SEQ], client_port as i32);
        write_u32be(tcp_seg[TCP_SEQ..<TCP_ACK], conn_snd_nxt as i32);
        write_u32be(tcp_seg[TCP_ACK..<TCP_DATA_OFFSET], conn_rcv_nxt as i32);
        tcp_seg[TCP_DATA_OFFSET] = (5 << 4) as u8;
        tcp_seg[TCP_FLAGS] = TCP_FLAG_ACK | TCP_FLAG_PSH | TCP_FLAG_FIN;
        write_u16be(tcp_seg[TCP_WINDOW..<TCP_CHECKSUM], 65535);
        write_u16be(tcp_seg[TCP_URGENT..<20], 0);

        fix_tcp_checksum(ip, tcp_seg);
        return n;
    }
    return -1;
}

fn main() {
    uart_puts("http_server: init\r\n");

    if (net_init() == 0) {
        uart_puts("http_server: device/link not found\r\n");
    } else {
        net_read_mac(our_mac as *u8);
        slice_copy(our_ip as []u8, HTTP_SERVER_IP as []u8);

        uart_puts("http_server: ready\r\n");

        while (1) {
            let len: i32 = net_poll_rx();
            let mut should_tx: i32 = 0;
            let mut tx_len: i32 = 0;
            let frame = net_rx_frame();   // [u8; 1514..] capacity view
            let ethertype: i32 = read_u16be(frame[12..<14]);

            if (len >= 42 && ethertype == 0x0806) {
                let arp = frame[14..<42];
                if (read_u16be(arp[ARP_HTYPE..<ARP_PTYPE]) == 1 &&
                    read_u16be(arp[ARP_PTYPE..<ARP_HLEN]) == 0x0800 &&
                    arp[ARP_HLEN] == 6 as u8 && arp[ARP_PLEN] == 4 as u8 &&
                    read_u16be(arp[ARP_OPER..<ARP_SHA]) == 1) {
                    if (slice_eq(arp[ARP_TPA..<28], our_ip as []u8)) {
                        build_arp_reply(frame);
                        should_tx = 1;
                        tx_len = 14 + 28;
                    }
                }
            } else if (len >= 54 && len <= 1514 && ethertype == 0x0800) {
                // len <= 1514 clamps the DEVICE-reported length to the RX
                // view's capacity before total_len (and through it every
                // checksum span) is allowed to trust it.
                //
                // Snapshot into an immutable local: the explicit refined
                // cast below (len_n as {54..<1515 as u16}) needs to see
                // len's CURRENT narrowed range, but a function PARAMETER
                // (always Mut) only exposes its narrowed range through
                // the separate narrowing_ctx side-table, which a bare
                // Cast does not consult -- an immutable snapshot's type
                // inherits the narrowing directly (same "B-plan"
                // mechanism used elsewhere), so the cast proves clean.
                let len_n: i32 = len;
                let ip = frame[14..<34];
                // version is standalone (compared only to a literal) --
                // safely u8.
                let version: u8 = ip[0] >> 4;
                let ihl:     u16 = (ip[0] & 0x0f) * 4;

                if (version == 4 && ihl == 20) {
                    // Bridge len_n's proven {54..<1515} range into u16
                    // (a free coercion: the source range already implies
                    // the target range exactly). This bound must be kept
                    // in sync with the `len >= 54 && len <= 1514` check
                    // above.
                    let len16: u16 = len_n as {54..<1515 as u16};
                    let total_len:       u16 = read_u16be(ip[IP_TOTAL_LEN..<4]) as u16;
                    let ip_len_in_frame: u16 = len16 - 14;

                    if (total_len <= ip_len_in_frame && total_len >= ihl &&
                        ip[IP_PROTOCOL] == PROTO_TCP &&
                        inet_checksum(ip[0..<ihl as {20..<21 as usize}]) == 0) {
                        if (slice_eq(ip[IP_DST..<20], our_ip as []u8)) {
                            let tcp:     [u8; 20..] = frame[34..<54];
                            let tcp_len: u16 = total_len - ihl;
                            // Data offset in 32-bit words (5..15 -- 20..60
                            // byte header). Real TCP stacks always include
                            // at least an MSS option on the SYN; options
                            // are never parsed, just skipped over. doff is
                            // TCP's own byte-scale field, never combined
                            // with the ihl/tcp_len chain directly --
                            // genuinely u8 (tcp_hdr_len carries its proven
                            // range across an explicit refined cast to
                            // u16 below to match tcp_len).
                            let doff: u8 = tcp[TCP_DATA_OFFSET] >> 4;

                            // doff must be narrowed to {5..<16} BEFORE
                            // tcp_hdr_len = doff * 4 is computed, so that
                            // Mul propagation gives tcp_hdr_len (and later
                            // data_off) a real range -- computing
                            // tcp_hdr_len first (matching the original
                            // pointer-based code's order) would leave it
                            // unrefined and fall back to a runtime check.
                            // `doff * 4` on the narrowed (u8-based) doff
                            // proves {20..<61 as u8}; the explicit refined
                            // cast to {20..<61 as u16} carries that EXACT
                            // proven range across the width change (a free
                            // coercion, not a runtime check, since the
                            // bounds match exactly) -- a plain `as u16`
                            // would have discarded the range entirely
                            // (Cast to a non-refined-syntax target always
                            // does), which silently reintroduces a trap
                            // site at data_off's subslice below (found via
                            // --forbid-trap while first doing this
                            // rewrite -- see CLAUDE.md).
                            if (tcp_len >= 20 && doff >= 5 && doff <= 15) {
                            let tcp_hdr_len: u16 = (doff * 4) as {20..<61 as u16};

                            if (tcp_len >= tcp_hdr_len) {
                                let mut pseudo: [u8; 12];
                                slice_copy(pseudo[0..<4], ip[IP_SRC..<IP_DST]);
                                slice_copy(pseudo[4..<8], ip[IP_DST..<20]);
                                pseudo[8] = 0 as u8;
                                pseudo[9] = PROTO_TCP;
                                write_u16be(pseudo[10..<12], tcp_len);
                                let sum: i32 = checksum_add(pseudo as []u8, 0);
                                let tcp_len_idx: usize =
                                    tcp_len as {0..<1481 as usize};
                                let tcp_seg = frame[34..<34 + tcp_len_idx];

                                if (checksum_fold(checksum_add(tcp_seg, sum)) == 0) {
                                    let dst_port: u16 = read_u16be(tcp[TCP_DST_PORT..<TCP_SEQ]) as u16;
                                    let src_port: u16 = read_u16be(tcp[TCP_SRC_PORT..<TCP_DST_PORT]) as u16;
                                    let flags:    u8  = tcp[TCP_FLAGS];
                                    let seq:      u32 = read_u32be(tcp[TCP_SEQ..<TCP_ACK]) as u32;
                                    let ack:      u32 = read_u32be(tcp[TCP_ACK..<TCP_DATA_OFFSET]) as u32;

                                    if (dst_port == HTTP_PORT) {
                                        if (conn_state == ConnState::Listen) {
                                            if ((flags & TCP_FLAG_SYN) != 0) {
                                                slice_copy(conn_remote_ip as []u8, ip[IP_SRC..<IP_DST]);
                                                conn_remote_port = src_port;
                                                conn_rcv_nxt = seq + 1;
                                                conn_snd_nxt = OUR_ISN + 1;

                                                build_syn_ack(frame, ihl);
                                                should_tx = 1;
                                                tx_len = 14 + ihl + 20;
                                                conn_state = ConnState::SynRcvd;
                                            }
                                        } else {
                                            if (slice_eq(ip[IP_SRC..<IP_DST], conn_remote_ip as []u8) &&
                                                src_port == conn_remote_port) {
                                                if ((flags & TCP_FLAG_RST) != 0) {
                                                    conn_state = ConnState::Listen;
                                                } else if (conn_state == ConnState::SynRcvd) {
                                                    if ((flags & TCP_FLAG_ACK) != 0 &&
                                                        (flags & TCP_FLAG_SYN) == 0 &&
                                                        ack == conn_snd_nxt && seq == conn_rcv_nxt) {
                                                        conn_state = ConnState::Established;
                                                    }
                                                } else if (conn_state == ConnState::Established) {
                                                    // data_len/data_off are u16 (matching tcp_len/
                                                    // tcp_hdr_len's base), needed for the `data_off + 3`
                                                    // same-base subslice below to type-check.
                                                    // max(.., 0): tcp_len - tcp_hdr_len's raw Sub-derived
                                                    // range has a spuriously negative lower bound (the
                                                    // type system can't see the tcp_len >= tcp_hdr_len
                                                    // guard above that makes a genuinely negative result
                                                    // impossible) -- harmless when data_len targeted i32
                                                    // (unconditional subtyping), but u16's subtyping
                                                    // requires lo >= 0, so the clamp is now required, not
                                                    // just documentation (found via this rewrite; see
                                                    // tcp_echo.tkb's identical, already-existing clamp and
                                                    // comment for why this doesn't change behavior).
                                                    let data_len: u16 = max(tcp_len - tcp_hdr_len, 0);
                                                    let data_off: u16 = 34 + tcp_hdr_len;
                                                    let data_off_idx: usize =
                                                        data_off as {54..<95 as usize};
                                                    if ((flags & TCP_FLAG_FIN) != 0 && seq == conn_rcv_nxt) {
                                                        conn_rcv_nxt = conn_rcv_nxt + 1;
                                                        build_fin_ack(frame, ihl);
                                                        should_tx = 1;
                                                        tx_len = 14 + ihl + 20;
                                                        conn_snd_nxt = conn_snd_nxt + 1;
                                                        conn_state = ConnState::LastAck;
                                                    } else if (data_len >= 3 &&
                                                               (flags & TCP_FLAG_ACK) != 0 &&
                                                               seq == conn_rcv_nxt) {
                                                        // Proven via the same-base subslice
                                                        // rule: data_off's exact value is
                                                        // unconstrained, but the length (3)
                                                        // and lo<=hi are syntactic facts.
                                                        let data3 = frame[data_off_idx..<data_off_idx + 3];
                                                        if (data3[0] == 'G' as u8 &&
                                                            data3[1] == 'E' as u8 &&
                                                            data3[2] == 'T' as u8) {
                                                            // data_len is u16 (matches tcp_len/tcp_hdr_len);
                                                            // payload_len stays i32 (an app-level byte
                                                            // count, not a wire-width field, matching
                                                            // request_count/body_len elsewhere in this
                                                            // file); conn_rcv_nxt/conn_snd_nxt are u32
                                                            // (sequence numbers). Casting here is harmless
                                                            // -- neither counter is ever used as a slice
                                                            // bound/index, so no proof depends on their
                                                            // refined-ness.
                                                            conn_rcv_nxt = conn_rcv_nxt + (data_len as u32);
                                                            request_count = request_count + 1;
                                                            let payload_len: i32 =
                                                                build_http_response_fin(frame, ihl);
                                                            if (payload_len >= 0) {
                                                                should_tx = 1;
                                                                // ihl (u16) needs an explicit upcast to
                                                                // combine with payload_len (i32) here --
                                                                // ihl's refined-ness isn't needed for this
                                                                // VALUE computation.
                                                                tx_len = 14 + (ihl as i32) + 20 + payload_len;
                                                                conn_snd_nxt = conn_snd_nxt + (payload_len as u32) + 1;
                                                                conn_state = ConnState::LastAck;
                                                            }
                                                            // else: page unexpectedly exceeded
                                                            // HTTP_MAX_PAYLOAD (never happens
                                                            // with the current fixed page) --
                                                            // drop the reply and stay
                                                            // ESTABLISHED so the client's TCP
                                                            // stack can retry.
                                                        }
                                                    }
                                                } else if (conn_state == ConnState::LastAck) {
                                                    if ((flags & TCP_FLAG_ACK) != 0 && ack == conn_snd_nxt) {
                                                        conn_state = ConnState::Listen;
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                            }
                        }
                    }
                }
            }

            if (should_tx == 1) {
                net_transmit(frame as *u8, tx_len);
            }
            if (len > 0) {
                net_rx_release();
            }
        }
    }
}
