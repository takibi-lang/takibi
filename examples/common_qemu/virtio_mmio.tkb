// Minimal legacy virtio-mmio transport driver (QEMU "virt" machine only).
//
// Register offsets and the vring layout follow the virtio 1.x spec's
// "legacy interface" (Version register reads 1, no FEATURES_OK handshake --
// that round-trip is a virtio 1.0/"modern" addition; a legacy device only
// expects ACKNOWLEDGE -> DRIVER -> (features) -> queue setup -> DRIVER_OK).
// We deliberately force legacy mode on the QEMU command line
// (-global virtio-mmio.force-legacy=on) because it avoids the split
// 64-bit feature-select / queue-address registers of modern (v2)
// virtio-mmio, at the cost of depending on a QEMU compatibility knob that
// could be removed in a future release -- see CLAUDE.md's virtio-net
// section for the tradeoff.
//
// Exposes the same net_init/net_rx_acquire/net_rx_frame/net_transmit/
// net_rx_release/net_read_mac API as examples/common_stm32/eth.tkb, so
// application-level examples (net_echo.tkb, etc.) are a single shared
// .tkb file for both the QEMU/virtio-net and STM32/real-MAC targets --
// mirroring how uart.tkb/print.tkb already share identical signatures
// across examples/common/ and examples/common_stm32/. Descriptor rings,
// RX/TX buffers, and the virtio_net_hdr framing detail are all internal to
// this file; the app only ever sees a plain Ethernet frame.
//
// Interrupt-driven: the shared GIC entry only acknowledges the virtio-mmio
// interrupt and records queue-work flags. Descriptor ownership and packet
// processing remain in normal context inside the API below.

use "examples/common_qemu/gic.tkb";

const VIRTIO_DEVICE_ID:        i32 = 0x08;
const VIRTIO_HOST_FEATURES:    i32 = 0x10;
const VIRTIO_GUEST_FEATURES:   i32 = 0x20;
const VIRTIO_GUEST_PAGE_SIZE:  i32 = 0x28;
const VIRTIO_QUEUE_SEL:        i32 = 0x30;
const VIRTIO_QUEUE_NUM_MAX:    i32 = 0x34;
const VIRTIO_QUEUE_NUM:        i32 = 0x38;
const VIRTIO_QUEUE_ALIGN:      i32 = 0x3c;
const VIRTIO_QUEUE_PFN:        i32 = 0x40;
const VIRTIO_QUEUE_NOTIFY:     i32 = 0x50;
const VIRTIO_INTERRUPT_STATUS: i32 = 0x60;
const VIRTIO_INTERRUPT_ACK:    i32 = 0x64;
const VIRTIO_STATUS:           i32 = 0x70;

const VIRTIO_MAGIC_VALUE:   u32 = 0x74726976;
const VIRTIO_DEVICE_ID_NET: u32 = 1;

const STATUS_ACKNOWLEDGE: i32 = 1;
const STATUS_DRIVER:      i32 = 2;
const STATUS_DRIVER_OK:   i32 = 4;

const PAGE_SIZE: isize = 4096;

const VIRTIO_MMIO_FIRST_SLOT: i32 = 0x0a000000;
const VIRTIO_MMIO_SLOT_STRIDE: i32 = 0x200;
const VIRTIO_MMIO_SLOT_COUNT: i32 = 32;
const VIRTIO_MMIO_FIRST_SPI: i32 = 48;

const QNUM: isize = 8; // virtqueue depth for both the RX and TX queues

private linear struct NetRxCpuOwned[desc: usize] {
    private index: {0..<8 as usize} @ desc;
    private len: i32;
}

// The device owns both the in-place frame and fixed TX descriptor zero between
// net_transmit and net_tx_complete. The indexed RX descriptor is the only
// runtime state the completion path needs to retain.
private linear struct NetTxInFlight[desc: usize] {
    private index: {0..<8 as usize} @ desc;
}

// Exactly one permit exists while no RX descriptor is CPU-owned. It is erased
// at runtime; consuming it prevents a second owner from being minted before the
// first one is released.
private affine view NetRxCanAcquire;

variant NetInitResult {
    Failed;
    Ready(NetRxCanAcquire);
}

variant NetRxAcquire {
    None(NetRxCanAcquire);
    Acquired(exists desc: usize. NetRxCpuOwned[desc]);
}

fn net_rx_owned(index: {0..<8 as usize} @ desc, len: i32)
        -> NetRxCpuOwned[desc] {
    let mut frame: NetRxCpuOwned[desc] = { index, len };
    return frame;
}

struct packed VirtqDesc {
    addr: usize;
    len: u32;
    flags: u16;
    next: u16;
}

struct packed VirtqAvail {
    flags: u16;
    idx: u16;
    ring: [u16; QNUM];
}

struct packed VirtqUsedElem {
    id: u32;
    len: u32;
}

struct packed VirtqUsed {
    flags: u16;
    idx: u16;
    ring: [VirtqUsedElem; QNUM];
}

// Descriptor flags (virtio spec).
const VIRTQ_DESC_F_WRITE: i32 = 2; // device writes into this buffer (RX only)

const VIRTIO_NET_F_MAC: i32 = 32; // bit 5: device exposes its MAC in Config space
const VIRTIO_CONFIG_MAC_OFFSET: i32 = 0x100; // Config space starts right after the transport registers

// Discovered at runtime: the slot base address is NOT fixed by the
// compiler, because QEMU does not always attach a lone virtio-net-device
// to slot 0 -- empirically, under this devcontainer's QEMU 8.2.2 with a
// single virtio-net-device on the command line, the device landed on slot
// 31 (base 0x0a003e00). Rather than hardcode that (fragile across QEMU
// versions/command lines), net_init() scans all 32 slots at boot and
// derives the base address from whichever slot actually reports
// DeviceID == 1 (network).
let mut virtio_base: i32 = 0;
let mut virtio_gic_irq: i32 = 0;
// Establishes the one initial NetRxCanAcquire mint on the current single-
// threaded boot path. Failed discovery may be retried; success is permanent.
private let mut net_rx_initialized: i32 = 0;
let mut virtio_rx_irq_flag: io u32;
let mut virtio_tx_irq_flag: io u32;

// RX_BUF_SIZE and every buffer/ring-index below are internal to this
// driver (matching eth.tkb's encapsulation) -- the app never needs to know
// about queue depth, PAGE_SIZE, or descriptor rings.
const RX_BUF_SIZE: isize = 1536; // 10-byte virtio_net_hdr + max 1514-byte Ethernet frame, rounded up
const RX_BUF_SIZE_USIZE: usize = 1536; // memory indexing counterpart

let mut rx_queue_mem: [u8; 2 * PAGE_SIZE] align(4096);
let mut tx_queue_mem: [u8; 2 * PAGE_SIZE] align(4096);

// QNUM (8) RX packet buffers, posted once at init and re-posted after
// each completion.
let mut rx_bufs: [u8; QNUM * RX_BUF_SIZE];

let mut rx_used_seen:        isize = 0;
let mut tx_used_seen:        isize = 0;
let mut rx_avail_idx:        isize = 0;
let mut tx_avail_idx:        isize = 0;

fn vreg(offset: i32) -> *io i32 {
    return (virtio_base + offset) as *io i32;
}

fn virtio_net_find() -> bool {
    for i in 0..<VIRTIO_MMIO_SLOT_COUNT {
        let base: i32 = VIRTIO_MMIO_FIRST_SLOT + i * VIRTIO_MMIO_SLOT_STRIDE;
        let magic_p: *io u32 = base as *io u32;
        if (*magic_p == VIRTIO_MAGIC_VALUE) {
            let devid_p: *io u32 = (base + VIRTIO_DEVICE_ID) as *io u32;
            if (*devid_p == VIRTIO_DEVICE_ID_NET) {
                virtio_base = base;
                virtio_gic_irq = VIRTIO_MMIO_FIRST_SPI + i;
                return true;
            }
        }
    }
    return false;
}

fn gic_enable_virtio_irq() {
    let isenabler_n: i32 = virtio_gic_irq / 32;
    let bit: i32 = virtio_gic_irq - isenabler_n * 32;
    let isenabler: *io u32 = (0x08000100 + isenabler_n * 4) as *io u32;
    *isenabler = 1 << (bit as u32);

    let itargetsr: *io u8 = (0x08000800 + virtio_gic_irq) as *io u8;
    *itargetsr = 1 as u8;
}

fn virtio_irq_handler() !{interrupt} {
    let status: i32 = *(vreg(VIRTIO_INTERRUPT_STATUS));
    *(vreg(VIRTIO_INTERRUPT_ACK)) = status;
    // Legacy virtio-mmio reports a queue-wide notification, not which queue
    // changed. Normal context re-checks each used ring before acting.
    virtio_rx_irq_flag = 1;
    virtio_tx_irq_flag = 1;
    interrupt_notify(); // retained event closes the flag-check/sleep race
}

fn irq_dispatch(frame_sp: usize) -> usize !{interrupt} {
    let id: u32 = *(gic.cpu_iar);
    if (id == (virtio_gic_irq as u32)) {
        virtio_irq_handler();
    }
    *(gic.cpu_eoir) = id;
    return frame_sp;
}

// Device bring-up through feature negotiation. VIRTIO_NET_F_MAC is always
// acked (unconditionally, regardless of whether the caller ever calls
// net_read_mac()) since it's part of the shared driver API surface now --
// harmless for callers that don't use it.
fn virtio_negotiate(features: i32) {
    *(vreg(VIRTIO_STATUS)) = 0; // reset
    *(vreg(VIRTIO_STATUS)) = STATUS_ACKNOWLEDGE;
    *(vreg(VIRTIO_STATUS)) = STATUS_ACKNOWLEDGE | STATUS_DRIVER;

    *(vreg(VIRTIO_GUEST_FEATURES)) = features;
    *(vreg(VIRTIO_GUEST_PAGE_SIZE)) = PAGE_SIZE as i32;
}

fn virtio_queue_setup(queue_idx: i32, queue_mem: *u8) {
    *(vreg(VIRTIO_QUEUE_SEL)) = queue_idx;
    *(vreg(VIRTIO_QUEUE_NUM)) = QNUM as i32;
    *(vreg(VIRTIO_QUEUE_ALIGN)) = PAGE_SIZE as i32;
    let addr: usize = queue_mem as usize;
    let pfn: i32 = (addr / (PAGE_SIZE as usize)) as i32;
    *(vreg(VIRTIO_QUEUE_PFN)) = pfn;
}

fn virtio_driver_ok() {
    *(vreg(VIRTIO_STATUS)) = STATUS_ACKNOWLEDGE | STATUS_DRIVER | STATUS_DRIVER_OK;
}

// Reads the device's 6-byte MAC out of Config space. VIRTIO_NET_F_MAC is
// always acked in virtio_negotiate() now, so this is always meaningful.
fn virtio_net_read_mac(mac_out: *u8) {
    for i: isize in 0..<6 {
        let p: *io u8 = (virtio_base + VIRTIO_CONFIG_MAC_OFFSET
            + (i as i32)) as *io u8;
        mac_out[i] = *p;
    }
}

fn virtio_notify(queue_idx: i32) {
    *(vreg(VIRTIO_QUEUE_NOTIFY)) = queue_idx;
}

// -- Vring accessors ----------------------------------------------------
// The three regions still share one page-aligned backing allocation, but each
// region is viewed through its specification-defined struct layout. Layout per
// queue_mem (matches virtio_queue_setup's PAGE_SIZE QueueAlign): descriptor
// table, immediately followed by the avail ring, then the used ring starting
// at the next page (offset PAGE_SIZE).

fn desc_set(queue_mem: *u8, i: isize, addr: usize, len: isize, flags: i32) {
    let descs: *VirtqDesc = queue_mem as *VirtqDesc;
    descs[i].addr = addr;
    descs[i].len = len as u32;
    descs[i].flags = flags as u16;
    // `next` field (offset 14) is left at 0 (BSS-zeroed at boot): we never
    // chain descriptors, so VIRTQ_DESC_F_NEXT is never set and it's unused.
}

fn avail_ring_set(queue_mem: *u8, slot: isize, desc_idx: isize) {
    let avail_off: isize = QNUM * (sizeof(VirtqDesc) as isize);
    let ring: *u16 = (queue_mem + avail_off
        + (offsetof(VirtqAvail, ring) as isize)) as *u16;
    ring[slot] = desc_idx as u16;
}

fn avail_publish(queue_mem: *u8, new_idx: isize) {
    let avail_off: isize = QNUM * (sizeof(VirtqDesc) as isize);
    let avail: *VirtqAvail = (queue_mem + avail_off) as *VirtqAvail;
    avail.idx = new_idx as u16;
    dma_publish(); // descriptors, ring entries, and idx before MMIO notify
}

// These three read memory the device writes asynchronously via DMA, and
// used_idx_get() in particular is polled directly in net_rx_acquire()'s
// per-call check. A non-volatile load here is exactly the "LLVM may hoist
// a global/memory load out of a tight loop" hazard called out in
// CLAUDE.md's "Volatile Reads of Global Variables" section (the compiler
// has no way to know DMA writes are coming) -- so these must be `io`.
fn used_idx_get(queue_mem: *u8) -> isize {
    let used: *io VirtqUsed = (queue_mem + PAGE_SIZE) as *io VirtqUsed;
    return used.idx as isize;
}

fn used_ring_get_id(queue_mem: *u8, slot: isize) -> isize {
    let ring: *io VirtqUsedElem = (queue_mem + PAGE_SIZE
        + (offsetof(VirtqUsed, ring) as isize)) as *io VirtqUsedElem;
    return ring[slot].id as isize;
}

fn used_ring_get_len(queue_mem: *u8, slot: isize) -> i32 {
    let ring: *io VirtqUsedElem = (queue_mem + PAGE_SIZE
        + (offsetof(VirtqUsed, ring) as isize)) as *io VirtqUsedElem;
    return ring[slot].len as i32; // same reasoning as used_ring_get_id.
}

// -- Shared driver API (matches examples/common_stm32/eth.tkb) --------------

// Finds the virtio-net device, negotiates features, sets up both queues,
// and posts all RX descriptors. Successful initialization creates the sole
// erased permission from which an RX owner may be acquired.
fn net_init() -> NetInitResult {
    if (net_rx_initialized != 0) {
        return NetInitResult::Failed;
    }
    if (virtio_net_find() == false) {
        return NetInitResult::Failed;
    }
    net_rx_initialized = 1;

    virtio_rx_irq_flag = 0;
    virtio_tx_irq_flag = 0;
    gic_init();
    gic_enable_virtio_irq();

    virtio_negotiate(VIRTIO_NET_F_MAC);
    virtio_queue_setup(0, rx_queue_mem as *u8); // RX
    virtio_queue_setup(1, tx_queue_mem as *u8); // TX
    virtio_driver_ok();

    for i in 0..<QNUM {
        let buf_off: isize = i * RX_BUF_SIZE;
        let buf: *u8 = rx_bufs + buf_off;
        desc_set(rx_queue_mem as *u8, i, buf as usize, RX_BUF_SIZE, VIRTQ_DESC_F_WRITE);
        avail_ring_set(rx_queue_mem as *u8, i, i);
    }
    rx_avail_idx = QNUM;
    avail_publish(rx_queue_mem as *u8, rx_avail_idx);
    virtio_notify(0);

    return NetInitResult::Ready(view NetRxCanAcquire);
}

// Consumes the one acquisition permit. None returns it unchanged; Acquired
// replaces it with the descriptor owner until net_rx_release() restores it.
fn net_rx_acquire(ready: sink NetRxCanAcquire) -> NetRxAcquire {
    if (virtio_rx_irq_flag == 0) {
        return NetRxAcquire::None(view NetRxCanAcquire);
    }
    virtio_rx_irq_flag = 0;
    if (rx_used_seen == used_idx_get(rx_queue_mem as *u8)) {
        return NetRxAcquire::None(view NetRxCanAcquire);
    }
    virtio_rx_irq_flag = 1; // drain coalesced used-ring entries
    dma_consume(); // used-ring entry and RX payload now belong to the CPU
    let slot: isize = rx_used_seen % QNUM;
    // A corrupt device-reported id is clamped before it becomes the owner's
    // singleton index, so every later buffer access is statically in bounds.
    let index: {0..<8 as usize} =
        max(min(used_ring_get_id(rx_queue_mem as *u8, slot), 7), 0) as usize;
    let frame_total_len: i32 = used_ring_get_len(rx_queue_mem as *u8, slot);
    return NetRxAcquire::Acquired(net_rx_owned(index, frame_total_len - 10));
}

fn net_rx_wait() !{may_block} {
    while (virtio_rx_irq_flag == 0) {
        interrupt_wait();
    }
}

fn net_rx_len(frame: borrow NetRxCpuOwned[desc]) -> i32 {
    return frame.len;
}

// Capacity view of the current RX buffer as a slice: 1514 bytes = the
// maximum Ethernet frame this stack handles (the physical buffer is
// larger, so the assertion below is true by construction -- that evidence
// closes the "device reports a bogus length" hole: a length outside
// 0..1514 fails the narrowing check and the frame is dropped.
//
// The descriptor singleton carried by frame preserves the range proven at
// acquisition, so no shared global or repeated clamp is needed here.
//
// `@ desc` ties the returned slice to the borrowed owner (issue #106): a
// caller keeping this slice (or a subslice of it) past net_rx_release or
// net_transmit is reading a buffer DMA owns, and is now a compile error.
fn net_rx_frame(frame: borrow NetRxCpuOwned[desc]) -> [u8; 1514..] @ desc {
    let idx: {0..<8 as usize} = frame.index;
    let offset: usize = idx * RX_BUF_SIZE_USIZE + 10;
    return rx_bufs[offset..<offset + 1514];
}


fn net_rx_repost(index: {0..<8 as usize} @ desc) -> NetRxCanAcquire {
    let rx_slot: isize = rx_avail_idx % QNUM;
    avail_ring_set(rx_queue_mem as *u8, rx_slot, index as isize);
    rx_avail_idx = rx_avail_idx + 1;
    avail_publish(rx_queue_mem as *u8, rx_avail_idx);
    virtio_notify(0);

    rx_used_seen = rx_used_seen + 1;
    return view NetRxCanAcquire;
}

// Hands the current RX descriptor back to the device and advances the
// ring. Consuming the CPU-owned handle restores the sole acquisition permit.
fn net_rx_release(frame: sink NetRxCpuOwned[desc]) -> NetRxCanAcquire {
    return net_rx_repost(frame.index);
}

// Starts transmitting len bytes from this owned RX descriptor. Deriving buf
// here makes the in-place-reply requirement structural rather than a raw-
// pointer calling convention. `buf - 10` lands back on the true DMA buffer
// start where the virtio_net_hdr the device expects on TX too still sits.
// Returning the linear in-flight owner records that the device may continue
// reading the buffer after this call returns.
fn net_transmit(frame: sink NetRxCpuOwned[desc], len: i32)
        -> NetTxInFlight[desc] {
    let buf: *u8 = net_rx_frame(frame) as *u8;
    desc_set(tx_queue_mem as *u8, 0, (buf - 10) as usize, (len + 10) as isize, 0);
    avail_ring_set(tx_queue_mem as *u8, 0, 0);
    tx_avail_idx = tx_avail_idx + 1;
    avail_publish(tx_queue_mem as *u8, tx_avail_idx);
    virtio_tx_irq_flag = 0;
    virtio_notify(1);

    let mut in_flight: NetTxInFlight[desc] = { frame.index };
    return in_flight;
}

// Waits until the device no longer reads the in-place frame, then re-posts
// its RX descriptor. Consuming the in-flight owner is the only path back to
// the acquisition permit, so an early net_rx_release is structurally absent.
fn net_tx_complete(in_flight: sink NetTxInFlight[desc])
        -> NetRxCanAcquire !{may_block} {
    while (tx_used_seen == used_idx_get(tx_queue_mem as *u8)) {
        virtio_tx_irq_flag = 0;
        if (tx_used_seen == used_idx_get(tx_queue_mem as *u8)) {
            while (virtio_tx_irq_flag == 0) {
                interrupt_wait();
            }
        }
    }
    dma_consume(); // device finished reading the transmitted buffer
    tx_used_seen = tx_used_seen + 1;
    return net_rx_repost(in_flight.index);
}

// One-frame poll disposition, decided by the application after inspecting
// the acquired frame: either transmit `Reply(len)` bytes in place, or hand
// the untouched descriptor back with `Release`. A plain unrestricted
// variant -- the linear owner itself stays a separate net_rx_finish
// argument, so the disposition can be built and overwritten freely inside
// nested protocol-dispatch code without ownership ceremony.
variant NetRxDisposal {
    Release;
    Reply(i32);
}

// Shared tail of every single-frame poll loop. Consuming the owner here
// keeps the transmit -> completion pairing (the "completion is our next
// network operation" policy, see net_tx_complete) inside the driver instead
// of copy-pasted into each protocol example.
fn net_rx_finish(frame: sink NetRxCpuOwned[desc], disposal: NetRxDisposal)
        -> NetRxCanAcquire !{may_block} {
    match disposal {
        NetRxDisposal::Reply(len) => {
            return net_tx_complete(net_transmit(frame, len));
        }
        NetRxDisposal::Release => {
            return net_rx_release(frame);
        }
    }
}

fn net_read_mac(mac_out: *u8) {
    virtio_net_read_mac(mac_out);
}
