// FAT12 filesystem core (GitHub issue #61, extracted for issue #98's real-SD-card
// combination). This is the backend-agnostic half of the driver originally written
// in examples/fatfs/fatfs.tkb: every function below reaches storage only through
// mem_block_read(sector: u32, buf: *u8) -> i32 /
// mem_block_write(sector: u32, buf: *u8) -> i32,
// which this file declares but never defines -- exactly the swappable interface
// boundary issue #61's own header comment anticipated. Two different consumers
// supply those two functions:
//   - examples/fatfs/fatfs.tkb: an in-memory `disk` array (QEMU + STM32-RAM,
//     verified via mtools three-way cross-check).
//   - examples/fatfs_sdcard/fatfs_sdcard.tkb: thin adapters over
//     examples/common_stm32/sdmmc.tkb's real disk_read/disk_write (STM32 only).
// Whole-program compilation means this works with no forward declaration at all --
// same shape as runtime.tkb calling platform_init/app_main, or eth.tkb/
// virtio_mmio.tkb both defining net_init for a shared caller.
//
// Public API: fat_format() (mkfs-equivalent) plus a FatFs-flavored
// (https://elm-chan.org/fsw/ff/) file-handle API -- fat_open/fat_read/
// fat_write/fat_close, plus fixed-position fat_read_at/fat_write_at
// helpers for HTTP range serving and KVS slot updates (fat_ prefix
// instead of FatFs's f_, matching this project's own naming). Originally
// scoped to exactly what the
// http_server_sdcard example (serving files from an SD card) needed: one
// flat root directory, no subdirectories, no seek/rename/unlink, no
// multiple simultaneously-open files. GitHub issue #135 (a key-value store
// persisting to the same file on every write) added one more real,
// present need on top of that: fat_open(FA_WRITE | FA_CREATE_ALWAYS) now
// overwrites an existing same-name file in place (fat_free_chain +
// fat_init_dir_entry, see fat_open's own comment) instead of only ever
// appending a fresh directory slot -- still no general rename/unlink, only
// this one create-or-truncate path. A later, separate, not-yet-scoped
// milestone (a Forth REPL over a web UI with free file/directory
// read-write) may need more; build that when it's an actual requirement,
// not now.
//
// fat_open/fat_read assume this file's OWN fixed layout constants below
// (RESERVED_SECTORS/NUM_FATS/FAT_SIZE_SECTORS/ROOT_ENTRY_COUNT) rather than
// parsing the on-disk BPB dynamically -- fine for a self-formatted image (both
// consumers above call fat_format() themselves rather than mounting an
// arbitrarily-formatted image), but would misread an arbitrarily-formatted real
// FAT image (e.g. a factory-formatted SD card). Dynamic BPB parsing ("mount")
// is deferred until an actual caller needs to read a foreign image.
//
// All disk-facing struct fields below are plain u16/u32 (not [u8;N] byte
// arrays with explicit endian helpers, unlike the network protocol structs
// in examples/common/netutil.tkb): FAT12 fields are little-endian on disk,
// this target is little-endian, so a plain scalar field's native store
// already produces the correct on-disk bytes -- same reasoning already
// applied to examples/common_qemu/virtio_mmio.tkb's VirtqDesc/VirtqAvail
// (virtio's legacy layout is native-endian by the same argument).
//
// Development process note: --forbid-trap is enabled. This file was first
// written without it -- disk/FAT/root-dir access uses plain checked array/
// struct-array indexing (sector*SECTOR_SIZE+i into a caller's buffer,
// cluster-derived offsets into fat_buf, next_free_root_entry into
// root_dir_buf) rather than reaching for raw-pointer arithmetic just to
// dodge bounds checks (see CLAUDE.md's "Development Process" section) --
// then --forbid-trap was turned on across this file, fatfs.tkb, sdmmc.tkb,
// and fatfs_sdcard.tkb together, in one pass, once the whole milestone
// (FAT12 on a real SD card) was demonstrated working end to end. The later
// `http_server_sdcard`/`FatFile` ownership-handle work (see HISTORY.md) kept
// this file --forbid-trap clean throughout.

use "examples/common/fat12_geometry.tkb";
use "examples/common/netutil.tkb";

// -- Disk geometry (this small 64KB volume is what both fatfs.tkb's in-memory
// backend and fatfs_sdcard.tkb's real-SD-card backend format and use) --------
const NUM_FATS: usize = 2;
const FAT_SIZE_SECTORS: usize = 1; // 512 bytes holds ~341 FAT12 entries; ample for TOTAL_SECTORS this small
const RESERVED_SECTORS: usize = 1; // boot sector only
const ROOT_ENTRY_COUNT: usize = 16;
const ROOT_DIR_SECTORS: usize = 1; // 16 * 32 bytes == 512 bytes == 1 sector

// Only `const` feeds the parser's compile-time-constant table (needed for
// [u8; SECTOR_SIZE * TOTAL_SECTORS]-style array sizes in consumers); the
// disk layout offsets are formulas over those constants, so they're plain
// functions computed at each call site instead of derived globals (a global
// `let` whose own initializer is a formula isn't supported as an LLVM
// constant initializer).
fn first_fat_sector() -> usize { return RESERVED_SECTORS; }
fn first_root_dir_sector() -> usize { return first_fat_sector() + NUM_FATS * FAT_SIZE_SECTORS; }
fn first_data_sector() -> usize { return first_root_dir_sector() + ROOT_DIR_SECTORS; }

// -- On-disk layouts (FAT12/16 BPB + EBPB, and the standard 32-byte
// directory entry) -----------------------------------------------------------
struct packed Fat12BootSector {
    jmp_boot: [u8; 3];
    oem_name: [u8; 8];
    bytes_per_sector: u16;
    sectors_per_cluster: u8;
    reserved_sector_count: u16;
    num_fats: u8;
    root_entry_count: u16;
    total_sectors_16: u16;
    media: u8;
    fat_size_16: u16;
    sectors_per_track: u16;
    num_heads: u16;
    hidden_sectors: u32;
    total_sectors_32: u32;
    drive_number: u8;
    reserved1: u8;
    boot_signature: u8;
    volume_id: u32;
    volume_label: [u8; 11];
    fs_type: [u8; 8];
    boot_code: [u8; 448];
    signature: u16; // 0xAA55 stored LE -> on-disk bytes 0x55, 0xAA
}

struct packed DirEntry {
    name: [u8; 11];
    attr: u8;
    nt_reserved: u8;
    create_time_tenth: u8;
    create_time: u16;
    create_date: u16;
    last_access_date: u16;
    first_cluster_hi: u16; // always 0 for FAT12
    write_time: u16;
    write_date: u16;
    first_cluster_lo: u16;
    file_size: u32;
}

// -- In-memory mirrors of the (single-sector each) FAT table and root
// directory. Both fit in exactly one sector at this disk size, so keeping
// them resident avoids any multi-sector random-access bookkeeping; flushed
// to disk by fat_flush(). -----------------------------------------------------
// align(32): mem_block_read/mem_block_write (GitHub issue #102 Stage 2)
// now require a PROVEN *align(32) u8 pointer, since examples/fatfs_sdcard's
// real adapter forwards straight into sdmmc.tkb's disk_read/disk_write,
// which no longer stage through a bounce buffer -- see that file's own
// comment for the cache-invalidate hazard this closes.
let mut fat_buf: [u8; SECTOR_SIZE] align(32);
// A checked array of DirEntry (not [u8; SECTOR_SIZE] + a *DirEntry overlay
// cast) -- DirEntry is 32 bytes and ROOT_ENTRY_COUNT is 16, so this is
// still exactly one SECTOR_SIZE sector; indexing an entry by slot number
// stays a genuine checked array access, only reinterpreted as raw bytes at
// the mem_block_write boundary below (`as *align(32) u8`), the same
// byte-oriented interface mem_block_write always needed regardless of
// this type. align(32): same reason as fat_buf above.
let mut root_dir_buf: [DirEntry; ROOT_ENTRY_COUNT] align(32);
let mut next_free_cluster: u32;
let mut next_free_root_entry: u32;

// Status of a FAT12 I/O operation. Replaces the plain `i32` 0/-1 sentinel
// this file used to return: a `match` on this type must name both the
// success and failure arm, so a call site can no longer confuse this
// return value with an unrelated integer (a byte count, a directory index)
// the way a bare `i32` could. `fat_io_ok` below is a convenience for
// callers that just want to fold several of these into one boolean
// condition, the same role `Result::is_ok()` plays in Rust.
variant FatIoResult {
    Ok;
    Err(i32);
}

fn fat_io_ok(r: FatIoResult) -> bool {
    match r {
        FatIoResult::Ok => { return true; }
        FatIoResult::Err(err) => { return false; }
    }
}

fn fat_flush() -> FatIoResult {
    let ffs: usize = first_fat_sector();
    if (mem_block_write(ffs as u32, fat_buf) != 0) { return FatIoResult::Err(-1); }
    if (mem_block_write((ffs + FAT_SIZE_SECTORS) as u32, fat_buf) != 0) { return FatIoResult::Err(-1); }
    if (mem_block_write(first_root_dir_sector() as u32,
                        root_dir_buf as *align(32) u8) != 0) { return FatIoResult::Err(-1); }
    return FatIoResult::Ok;
}

// Syncs the in-memory fat_buf/root_dir_buf mirrors FROM disk -- the
// counterpart to fat_flush(). fat_format() leaves both mirrors correct in
// memory already (it just built them), so it doesn't need this; it's
// needed whenever storage was populated some other way (e.g.
// load_seed_from_host() loading a foreign image) before fat_open(FA_READ)
// can see its directory.
fn fat_mount() -> FatIoResult {
    if (mem_block_read(first_fat_sector() as u32, fat_buf) != 0) { return FatIoResult::Err(-1); }
    if (mem_block_read(first_root_dir_sector() as u32,
                       root_dir_buf as *align(32) u8) != 0) { return FatIoResult::Err(-1); }
    return FatIoResult::Ok;
}

// FAT12 packs two 12-bit entries into 3 bytes. For an even cluster N, its
// entry occupies the low 12 bits of the 3-byte group at byte offset
// N + N/2; for an odd cluster, the high 12 bits. This is the one genuinely
// fiddly piece of FAT12 -- everything else in this file is byte-aligned.
// cluster's real invariant (a valid FAT12 cluster number for this small,
// self-formatted volume) is bookkeeping the type system cannot see across
// this function's callers (next_free_cluster, an on-disk stored field, or
// a previous fat_get_entry result) -- explicit if-narrowing on `off`
// itself right at the point of use, per this project's established
// pattern for exactly this class of bound, closes the trap without
// weakening cluster's own parameter type. `off` is `usize`, so a single
// hi-only condition (`off < 511`, no `off >= 0`) is enough to narrow
// (GitHub issue #99 -- an unsigned value is trivially >= 0).
fn fat_get_entry(cluster: u32) -> u16 {
    let off: usize = (cluster + cluster / 2) as usize;
    if (off < 511) {
        let b0: u16 = fat_buf[off] as u16;
        let b1: u16 = fat_buf[off + 1] as u16;
        if (cluster % 2 == 0) {
            return b0 | ((b1 & 0x0F) << 8);
        } else {
            return (b0 >> 4) | (b1 << 4);
        }
    }
    return 0x0FFF; // out of range should not happen in correct operation; treat as EOC
}

fn fat_set_entry(cluster: u32, val: u16) {
    let off: usize = (cluster + cluster / 2) as usize;
    if (off < 511) {
        if (cluster % 2 == 0) {
            fat_buf[off] = val as u8;
            let hi: u8 = fat_buf[off + 1];
            fat_buf[off + 1] = (hi & 0xF0) | (((val >> 8) as u8) & 0x0F);
        } else {
            let lo: u8 = fat_buf[off];
            fat_buf[off] = (lo & 0x0F) | (((val << 4) as u8) & 0xF0);
            fat_buf[off + 1] = (val >> 4) as u8;
        }
    }
}

fn fat_format() -> FatIoResult {
    let mut sector_buf: [u8; SECTOR_SIZE] align(32);
    for i: usize in 0..<SECTOR_SIZE {
        sector_buf[i] = 0;
    }
    // jmp_boot is at offset 0, so it's simplest to write it directly into
    // sector_buf (a plain array with literal indices) rather than through
    // bs -- the grammar doesn't support assigning into an indexed array
    // FIELD reached through a struct pointer (`bs.jmp_boot[i] = v`), only
    // whole-field assignment or reading a field to pass elsewhere.
    sector_buf[0] = 0xEB;
    sector_buf[1] = 0x3C;
    sector_buf[2] = 0x90;
    let bs: *Fat12BootSector = sector_buf as *Fat12BootSector;
    bytes_copy(bs.oem_name, "TAKIBI  ", 8);
    bs.bytes_per_sector = SECTOR_SIZE as u16;
    bs.sectors_per_cluster = 1;
    bs.reserved_sector_count = RESERVED_SECTORS as u16;
    bs.num_fats = NUM_FATS as u8;
    bs.root_entry_count = ROOT_ENTRY_COUNT as u16;
    bs.total_sectors_16 = TOTAL_SECTORS as u16;
    bs.media = 0xF8;
    bs.fat_size_16 = FAT_SIZE_SECTORS as u16;
    bs.sectors_per_track = 32;
    bs.num_heads = 2;
    bs.hidden_sectors = 0;
    bs.total_sectors_32 = 0;
    bs.drive_number = 0x80;
    bs.reserved1 = 0;
    bs.boot_signature = 0x29;
    bs.volume_id = 0x12345678;
    bytes_copy(bs.volume_label, "TAKIBIFAT12", 11);
    bytes_copy(bs.fs_type, "FAT12   ", 8);
    bs.signature = 0xAA55;

    for i: usize in 0..<SECTOR_SIZE {
        fat_buf[i] = 0;
    }
    fat_buf[0] = 0xF8; // cluster 0: media descriptor low byte
    fat_buf[1] = 0xFF; // shared nibble: cluster 0 high nibble (0xF) | cluster 1 low nibble (0xF)
    fat_buf[2] = 0xFF; // cluster 1: EOC marker high byte

    // root_dir_buf needs no explicit zero-fill: uninitialized `let mut`
    // globals are BSS-zeroed at boot, and every DirEntry field defaulting
    // to 0 (including name[0] == 0x00) is exactly FAT's own "never used"
    // marker for a free directory entry.

    match fat_flush() {
        FatIoResult::Ok => {}
        FatIoResult::Err(err) => { return FatIoResult::Err(err); }
    }

    let mut zero_buf: [u8; SECTOR_SIZE] align(32);
    for i: usize in 0..<SECTOR_SIZE {
        zero_buf[i] = 0;
    }
    for s: usize in first_data_sector()..<TOTAL_SECTORS {
        if (mem_block_write(s as u32, zero_buf) != 0) { return FatIoResult::Err(-1); }
    }

    // Sector 0 carries fat_format_status()'s completion signature, so commit
    // it last.  If any earlier FAT/root/data write fails, the next boot must
    // not mistake a partially formatted volume for a complete one.
    if (mem_block_write(0, sector_buf) != 0) { return FatIoResult::Err(-1); }

    next_free_cluster = 2;
    next_free_root_entry = 0;
    return FatIoResult::Ok;
}

// Allocates num_clusters clusters as one chain, terminated with the FAT12
// EOC marker. Returns the first cluster number, or 0 if not enough free
// clusters remain. Scans the FAT for entries equal to 0 (free) rather than
// bumping a monotonic next_free_cluster counter forever -- this is what
// lets fat_free_chain's freed clusters actually get reused, needed once
// fat_open(FA_CREATE_ALWAYS) started overwriting existing files in place
// (see that function's own comment). Every call site in this codebase
// passes num_clusters == 1, so the scan never needs to roll back a
// partially-built chain on running out of free clusters mid-loop; a future
// caller needing an atomic multi-cluster allocation would need that added
// here first.
fn fat_alloc_chain(num_clusters: u32) -> u32 {
    let data_clusters: u32 = (TOTAL_SECTORS - first_data_sector()) as u32;
    let mut first: u32 = 0;
    let mut prev: u32 = 0;
    let mut found: u32 = 0;
    let mut c: u32 = 2;
    while (c < 2 + data_clusters && found < num_clusters) {
        if (fat_get_entry(c) == 0) {
            if (first == 0) {
                first = c;
            } else {
                fat_set_entry(prev, c as u16);
            }
            prev = c;
            found = found + 1;
        }
        c = c + 1;
    }
    if (found < num_clusters) {
        return 0;
    }
    fat_set_entry(prev, 0x0FFF);
    return first;
}

// Frees every cluster in a chain (sets each FAT entry back to 0) so
// fat_alloc_chain can reuse them. start_cluster == 0 (a file that was
// created but never written) is a no-op. Used by fat_open(FA_CREATE_ALWAYS)
// when overwriting an existing file.
fn fat_free_chain(start_cluster: u32) {
    let mut cluster: u32 = start_cluster;
    while (cluster >= 2 && cluster < 0x0FF0) {
        let next: u32 = fat_get_entry(cluster) as u32;
        fat_set_entry(cluster, 0);
        cluster = next;
    }
}

// Checks whether sector 0 ends in the standard boot-sector signature
// (0x55, 0xAA) that fat_format() writes last -- a lightweight way for a
// caller to tell "this card was already formatted by this code" apart from
// a blank/foreign card, without parsing the rest of the BPB. Not a general
// "is this a valid FAT filesystem" check (see this file's header comment
// on why dynamic BPB parsing/mounting a foreign image stays out of scope).
// Reports Formatted/NotFormatted/IoError as three distinct cases (rather
// than folding them into 1/0/-1) so a caller's `match` cannot conflate a
// transient read failure with a genuinely unformatted disk -- treating the
// former as the latter would make callers format media that may contain
// valid data.
variant FatFormatStatus {
    IoError(i32);
    NotFormatted;
    Formatted;
}

fn fat_format_status() -> FatFormatStatus {
    let mut sector_buf: [u8; SECTOR_SIZE] align(32);
    if (mem_block_read(0, sector_buf) != 0) { return FatFormatStatus::IoError(-1); }
    if (sector_buf[510] == 0x55 && sector_buf[511] == 0xAA) { return FatFormatStatus::Formatted; }
    return FatFormatStatus::NotFormatted;
}

// -- File-handle API (fat_open/fat_read/fat_write/fat_close), FatFs-flavored ---
// name83 arguments must point to exactly 11 bytes (8.3 short name,
// space-padded, no dot) -- no LFN, no subdirectories: not needed for the
// flat, single-directory root_dir_buf this driver has.

// FatFile is both the mandatory-close capability and the runtime file state.
// The erased `file` index is tied to the range-proven directory index stored
// in this value; independent opens therefore own independent cursors without
// a singleton global-state guard. Open failure is represented by Error, never
// by a null ownership-bearing value.
private linear struct FatFile[file: usize] {
    private dir_index: {0..<16 as usize} @ file;
    private start_cluster: u32;
    private cur_cluster: u32;
    private pos_in_cluster: u32;
    private fptr: u32;
    private fsize: u32;
    private writing: bool;
}

variant FatOpenResult {
    Error(i32);
    Opened(exists file: usize. FatFile[file]);
}

const FA_READ: i32 = 0x01;
const FA_WRITE: i32 = 0x02;
const FA_CREATE_ALWAYS: i32 = 0x08;

fn fat_file_opened(dir_index: {0..<16 as usize} @ file,
                   start_cluster: u32, fsize: u32,
                   writing: bool) -> FatFile[file] {
    let mut fp: FatFile[file] = {
        dir_index,
        start_cluster,
        start_cluster,
        0,
        0,
        fsize,
        writing
    };
    return fp;
}

// Linear scan of root_dir_buf (checked array access) for a matching 8.3
// name, skipping free slots (name[0] == 0, FAT's own "never used" marker).
// Returns the slot index, or -1 if not found.
fn fat_find_entry(name83: *u8) -> i32 {
    for i: usize in 0..<ROOT_ENTRY_COUNT {
        let name_p: *u8 = root_dir_buf[i].name;
        if (name_p[0] != 0) {
            if (bytes_eq(name_p, name83, 11)) {
                return i as i32;
            }
        }
    }
    return -1;
}

fn fat_file_exists(name83: *u8) -> bool {
    return fat_find_entry(name83) >= 0;
}

fn fat_file_size(name83: *u8) -> u32 {
    let found: i32 = fat_find_entry(name83);
    if ((found >= 0) && (found < 16)) {
        let idx: usize = found as usize;
        return root_dir_buf[idx].file_size;
    }
    return 0;
}

// Random-position read helper for HTTP multi-segment serving. This keeps
// the normal FatFile linear API sequential, while avoiding an O(n^2)
// "reopen and read-discard from byte 0" loop when a large response is sent
// one TCP segment at a time.
fn fat_read_at(name83: *u8, off: u32, buf: borrow *u8, btr: u32,
        br: *u32) -> FatIoResult {
    let found: i32 = fat_find_entry(name83);
    if ((found >= 0) && (found < 16)) {
        let idx: usize = found as usize;
        let fsize: u32 = root_dir_buf[idx].file_size;
        if (off >= fsize) {
            *br = 0;
            return FatIoResult::Ok;
        }

        let mut remaining: u32 = btr;
        let avail: u32 = fsize - off;
        if (remaining > avail) {
            remaining = avail;
        }

        let mut cluster: u32 = root_dir_buf[idx].first_cluster_lo as u32;
        let skip_clusters: u32 = off / (SECTOR_SIZE as u32);
        for i: u32 in 0..<skip_clusters {
            cluster = fat_get_entry(cluster) as u32;
        }

        let mut pos_in_cluster: u32 = off - skip_clusters * (SECTOR_SIZE as u32);
        let mut total: u32 = 0;
        let mut dst: *u8 = buf;
        while (remaining > 0) {
            let mut sector_buf: [u8; SECTOR_SIZE] align(32);
            let sector_num: u32 = (first_data_sector() as u32) + (cluster - 2);
            if (mem_block_read(sector_num, sector_buf) != 0) {
                *br = total;
                return FatIoResult::Err(-1);
            }

            let space_in_cluster: u32 = (SECTOR_SIZE as u32) - pos_in_cluster;
            let mut chunk: u32 = remaining;
            if (chunk > space_in_cluster) {
                chunk = space_in_cluster;
            }

            let src_p: *u8 = sector_buf;
            bytes_copy(dst, src_p + (pos_in_cluster as isize), chunk as isize);
            dst = dst + (chunk as isize);
            total = total + chunk;
            remaining = remaining - chunk;
            pos_in_cluster = pos_in_cluster + chunk;
            if (pos_in_cluster >= SECTOR_SIZE as u32) {
                pos_in_cluster = 0;
                cluster = fat_get_entry(cluster) as u32;
            }
        }
        *br = total;
        return FatIoResult::Ok;
    }
    *br = 0;
    return FatIoResult::Err(-1);
}

// Existing-file, fixed-position overwrite helper. This deliberately does
// not append or grow files: callers that need a file of a known size should
// create it with fat_open(FA_WRITE | FA_CREATE_ALWAYS) first, then use this
// to replace bytes in place.
fn fat_write_at(name83: *u8, off: u32, buf: borrow *u8, btw: u32,
        bw: *u32) -> FatIoResult {
    let found: i32 = fat_find_entry(name83);
    if ((found >= 0) && (found < 16)) {
        let idx: usize = found as usize;
        let fsize: u32 = root_dir_buf[idx].file_size;
        if (off >= fsize) {
            *bw = 0;
            return FatIoResult::Err(-1);
        }

        let mut remaining: u32 = btw;
        let avail: u32 = fsize - off;
        if (remaining > avail) {
            remaining = avail;
        }

        let mut cluster: u32 = root_dir_buf[idx].first_cluster_lo as u32;
        let skip_clusters: u32 = off / (SECTOR_SIZE as u32);
        for i: u32 in 0..<skip_clusters {
            cluster = fat_get_entry(cluster) as u32;
        }

        let mut pos_in_cluster: u32 = off - skip_clusters * (SECTOR_SIZE as u32);
        let mut total: u32 = 0;
        let mut src: *u8 = buf;
        while (remaining > 0) {
            let mut sector_buf: [u8; SECTOR_SIZE] align(32);
            let sector_num: u32 = (first_data_sector() as u32) + (cluster - 2);
            if (mem_block_read(sector_num, sector_buf) != 0) {
                *bw = total;
                return FatIoResult::Err(-1);
            }

            let space_in_cluster: u32 = (SECTOR_SIZE as u32) - pos_in_cluster;
            let mut chunk: u32 = remaining;
            if (chunk > space_in_cluster) {
                chunk = space_in_cluster;
            }

            let dst_p: *u8 = sector_buf;
            bytes_copy(dst_p + (pos_in_cluster as isize), src, chunk as isize);
            if (mem_block_write(sector_num, sector_buf) != 0) {
                *bw = total;
                return FatIoResult::Err(-1);
            }
            src = src + (chunk as isize);
            total = total + chunk;
            remaining = remaining - chunk;
            pos_in_cluster = pos_in_cluster + chunk;
            if (pos_in_cluster >= SECTOR_SIZE as u32) {
                pos_in_cluster = 0;
                cluster = fat_get_entry(cluster) as u32;
            }
        }
        *bw = total;
        if (total == btw) {
            return FatIoResult::Ok;
        }
        return FatIoResult::Err(-1);
    }
    *bw = 0;
    return FatIoResult::Err(-1);
}

// Resets directory slot idx to a fresh, empty entry for name83. Shared by
// both fat_open(FA_CREATE_ALWAYS) paths below (a brand new name, and an
// existing name being overwritten) so the field list is written once.
fn fat_init_dir_entry(idx: {0..<16 as usize}, name83: *u8) {
    bytes_copy(root_dir_buf[idx].name, name83, 11);
    root_dir_buf[idx].attr = 0x20; // ARCHIVE
    root_dir_buf[idx].nt_reserved = 0;
    root_dir_buf[idx].create_time_tenth = 0;
    root_dir_buf[idx].create_time = 0;
    root_dir_buf[idx].create_date = 0x21; // 1980-01-01 placeholder (no RTC in this demo)
    root_dir_buf[idx].last_access_date = 0;
    root_dir_buf[idx].first_cluster_hi = 0;
    root_dir_buf[idx].write_time = 0;
    root_dir_buf[idx].write_date = 0x21;
    root_dir_buf[idx].first_cluster_lo = 0; // filled in by fat_close once known
    root_dir_buf[idx].file_size = 0;
}

// mode is FA_READ, or (FA_WRITE | FA_CREATE_ALWAYS) -- no other combination
// is supported (no FA_OPEN_ALWAYS/FA_OPEN_APPEND -- always create-and-
// truncate for writing, matching what this demo's two call sites need).
// FA_CREATE_ALWAYS overwrites an existing same-name entry in place (frees
// its old cluster chain via fat_free_chain and reuses its directory slot)
// rather than appending a fresh root_dir_buf slot every time -- needed once
// a caller (the KVS example, GitHub issue #135) started re-creating the
// same file on every write; the old "always append" behavior exhausted the
// 16-entry root directory in 16 writes and never freed a single cluster.
// Still no general rename/unlink -- only fat_open(FA_CREATE_ALWAYS) itself
// triggers this reuse, and only for its own exact filename match.
fn fat_open(name83: *u8, mode: i32) -> FatOpenResult {
    if ((mode & FA_CREATE_ALWAYS) != 0) {
        let existing: i32 = fat_find_entry(name83);
        // Two-sided narrow, same reasoning as the FA_READ
        // branch below: fat_find_entry's own proof doesn't cross the
        // function-call boundary through its unrefined `-> i32` return.
        if ((existing >= 0) && (existing < 16)) {
            let idx: {0..<ROOT_ENTRY_COUNT as usize} = existing as usize;
            fat_free_chain(root_dir_buf[idx].first_cluster_lo as u32);
            fat_init_dir_entry(idx, name83);
            return FatOpenResult::Opened(fat_file_opened(idx, 0, 0, true));
        }
        // If-narrowing must wrap the actual use, not a negated early-return
        // guard (SPEC.md "If-condition narrowing") -- and compared against
        // literal 16, because next_free_root_entry is u32 and
        // ROOT_ENTRY_COUNT is usize for array sizes.
        // next_free_root_entry is u32, so a hi-only condition is enough to
        // narrow (GitHub issue #99).
        if (next_free_root_entry < 16) {
            let idx: {0..<16 as usize} =
                min(next_free_root_entry, 15) as usize;
            fat_init_dir_entry(idx, name83);
            next_free_root_entry = next_free_root_entry + 1;

            return FatOpenResult::Opened(fat_file_opened(idx, 0, 0, true));
        }
        return FatOpenResult::Error(-1);
    }
    if ((mode & FA_READ) != 0) {
        let found: i32 = fat_find_entry(name83);
        // fat_find_entry's own body proves its for-loop counter is
        // {0..<ROOT_ENTRY_COUNT}, but that proof does not cross the function-call
        // boundary through a plain (unrefined) `-> i32` return -- so
        // narrow explicitly here (two-sided form, same
        // reasoning as the FA_CREATE_ALWAYS branch above) rather than
        // widen the return type.
        if ((found >= 0) && (found < 16)) {
            let idx: {0..<ROOT_ENTRY_COUNT as usize} = found as usize;
            let start_cluster: u32 = root_dir_buf[idx].first_cluster_lo as u32;
            let fsize: u32 = root_dir_buf[idx].file_size;
            return FatOpenResult::Opened(
                fat_file_opened(idx, start_cluster, fsize, false));
        }
        return FatOpenResult::Error(-1);
    }
    return FatOpenResult::Error(-1); // unsupported mode
}

// Reads up to btr bytes into buf, following the cluster chain as needed.
// *br is set to the actual number of bytes read (less than btr at EOF --
// that is normal, not an error).
fn fat_read(fp: borrow mut FatFile[file], buf: *u8, btr: u32, br: *u32) -> FatIoResult {
    let avail: u32 = fp.fsize - fp.fptr;
    let mut remaining: u32 = btr;
    if (remaining > avail) {
        remaining = avail;
    }
    let mut total: u32 = 0;
    let mut dst: *u8 = buf;
    while (remaining > 0) {
        let mut sector_buf: [u8; SECTOR_SIZE] align(32);
        let sector_num: u32 = (first_data_sector() as u32) + (fp.cur_cluster - 2);
        if (mem_block_read(sector_num, sector_buf) != 0) {
            *br = total;
            return FatIoResult::Err(-1);
        }
        let space_in_cluster: u32 = (SECTOR_SIZE as u32) - fp.pos_in_cluster;
        let mut chunk: u32 = remaining;
        if (chunk > space_in_cluster) {
            chunk = space_in_cluster;
        }
        let src_p: *u8 = sector_buf;
        bytes_copy(dst, src_p + (fp.pos_in_cluster as isize), chunk as isize);
        dst = dst + (chunk as isize);
        fp.pos_in_cluster = fp.pos_in_cluster + chunk;
        fp.fptr = fp.fptr + chunk;
        total = total + chunk;
        remaining = remaining - chunk;
        if (fp.pos_in_cluster >= SECTOR_SIZE as u32) {
            fp.pos_in_cluster = 0;
            fp.cur_cluster = fat_get_entry(fp.cur_cluster) as u32;
        }
    }
    *br = total;
    return FatIoResult::Ok;
}

// Writes btw bytes from buf, growing the file (sequential append only, no
// seek). Allocates the first cluster lazily on the first call, and a fresh
// one whenever the current cluster fills and more data remains. Each
// cluster's sector is read-modify-written so multiple fat_write calls into
// the same (still-open) cluster don't clobber each other's bytes.
fn fat_write(fp: borrow mut FatFile[file], buf: *u8, btw: u32, bw: *u32) -> FatIoResult {
    let mut remaining: u32 = btw;
    let mut src: *u8 = buf;
    while (remaining > 0) {
        if (fp.start_cluster == 0) {
            let c: u32 = fat_alloc_chain(1);
            if (c == 0) {
                *bw = btw - remaining;
                return FatIoResult::Err(-1);
            }
            fp.start_cluster = c;
            fp.cur_cluster = c;
            fp.pos_in_cluster = 0;
        }
        let mut sector_buf: [u8; SECTOR_SIZE] align(32);
        let sector_num: u32 = (first_data_sector() as u32) + (fp.cur_cluster - 2);
        if (fp.pos_in_cluster > 0) {
            // Preserve earlier bytes in this cluster before modifying it.
            if (mem_block_read(sector_num, sector_buf) != 0) {
                *bw = btw - remaining;
                return FatIoResult::Err(-1);
            }
        }
        let space_in_cluster: u32 = (SECTOR_SIZE as u32) - fp.pos_in_cluster;
        let mut chunk: u32 = remaining;
        if (chunk > space_in_cluster) {
            chunk = space_in_cluster;
        }
        let dst_p: *u8 = sector_buf;
        bytes_copy(dst_p + (fp.pos_in_cluster as isize), src, chunk as isize);
        if (mem_block_write(sector_num, sector_buf) != 0) {
            *bw = btw - remaining;
            return FatIoResult::Err(-1);
        }
        src = src + (chunk as isize);
        fp.pos_in_cluster = fp.pos_in_cluster + chunk;
        fp.fptr = fp.fptr + chunk;
        remaining = remaining - chunk;
        if (fp.fptr > fp.fsize) {
            fp.fsize = fp.fptr;
        }
        if ((fp.pos_in_cluster >= SECTOR_SIZE as u32) && (remaining > 0)) {
            let next: u32 = fat_alloc_chain(1);
            if (next == 0) {
                *bw = btw - remaining;
                return FatIoResult::Err(-1);
            }
            fat_set_entry(fp.cur_cluster, next as u16);
            fp.cur_cluster = next;
            fp.pos_in_cluster = 0;
        }
    }
    *bw = btw;
    return FatIoResult::Ok;
}

fn fat_close(fp: sink FatFile[file]) -> FatIoResult {
    // dir_index retains the range proof established by fat_open, so closing
    // needs neither a repeated runtime range guard nor a global index copy.
    if (fp.writing) {
        root_dir_buf[fp.dir_index].first_cluster_lo = fp.start_cluster as u16;
        root_dir_buf[fp.dir_index].file_size = fp.fsize;
        match fat_flush() {
            FatIoResult::Ok => {}
            FatIoResult::Err(err) => { return FatIoResult::Err(err); }
        }
    }
    return FatIoResult::Ok;
}

fn cstr_len(s: *u8) -> u32 {
    let mut n: u32 = 0;
    while (s[n as isize] != 0) {
        n = n + 1;
    }
    return n;
}

// Prints n raw (not necessarily NUL-terminated) bytes via UART -- for
// printing a fat_read()'d buffer.
fn uart_print_bytes(buf: *u8, n: u32) {
    for i: u32 in 0..<n {
        uart_putc(buf[i as isize]);
    }
}

// Creates name83 with the NUL-terminated content string, via
// fat_open(create)+fat_write+fat_close -- callers share this instead of
// repeating the three-call sequence themselves.
fn create_demo_file(name83: *u8, content: *u8) -> FatIoResult {
    match fat_open(name83, FA_WRITE | FA_CREATE_ALWAYS) {
        FatOpenResult::Error(err) => { return FatIoResult::Err(err); }
        FatOpenResult::Opened(mut fp) => {
            let len: u32 = cstr_len(content);
            let mut bw: u32 = 0;
            match fat_write(fp, content, len, &bw) {
                FatIoResult::Ok => {}
                FatIoResult::Err(err) => {
                    fat_close(fp);
                    return FatIoResult::Err(err);
                }
            }
            return fat_close(fp);
        }
    }
}
