// Minimal legacy virtio-mmio transport driver (QEMU "virt" machine only).
//
// Register offsets and the vring layout follow the virtio 1.x spec's
// "legacy interface" (Version register reads 1, no FEATURES_OK handshake --
// that round-trip is a virtio 1.0/"modern" addition; a legacy device only
// expects ACKNOWLEDGE -> DRIVER -> (features) -> queue setup -> DRIVER_OK).
// We deliberately force legacy mode on the QEMU command line
// (-global virtio-mmio.force-legacy=on) because it avoids the split
// 64-bit feature-select / queue-address registers of modern (v2)
// virtio-mmio, at the cost of depending on a QEMU compatibility knob that
// could be removed in a future release -- see CLAUDE.md's virtio-net
// section for the tradeoff.
//
// Exposes the same net_init/net_poll_rx/net_rx_buf/net_transmit/
// net_rx_release/net_read_mac API as examples/common_stm32/eth.tkb, so
// application-level examples (net_echo.tkb, etc.) are a single shared
// .tkb file for both the QEMU/virtio-net and STM32/real-MAC targets --
// mirroring how uart.tkb/print.tkb already share identical signatures
// across examples/common/ and examples/common_stm32/. Descriptor rings,
// RX/TX buffers, and the virtio_net_hdr framing detail are all internal to
// this file; the app only ever sees a plain Ethernet frame.
//
// Polling-only, matching eth.tkb: net_poll_rx() checks the used ring
// directly instead of waiting on a GIC-routed interrupt. QEMU's
// virtio-mmio device works identically either way (the interrupt is a
// notification convenience, not a requirement -- the driver polling
// used_idx_get() directly is a spec-legal alternative), and
// examples/common/startup.S already safely no-ops when the GIC is never
// initialized (relied on today by every non-IRQ example). This removes
// the GIC/IRQ wiring (gic_init/gic_enable_virtio_irq/irq_dispatch/
// virtio_irq_flag) every consumer used to have to set up by hand.

let VIRTIO_DEVICE_ID:        i32 = 0x08;
let VIRTIO_HOST_FEATURES:    i32 = 0x10;
let VIRTIO_GUEST_FEATURES:   i32 = 0x20;
let VIRTIO_GUEST_PAGE_SIZE:  i32 = 0x28;
let VIRTIO_QUEUE_SEL:        i32 = 0x30;
let VIRTIO_QUEUE_NUM_MAX:    i32 = 0x34;
let VIRTIO_QUEUE_NUM:        i32 = 0x38;
let VIRTIO_QUEUE_ALIGN:      i32 = 0x3c;
let VIRTIO_QUEUE_PFN:        i32 = 0x40;
let VIRTIO_QUEUE_NOTIFY:     i32 = 0x50;
let VIRTIO_STATUS:           i32 = 0x70;

let VIRTIO_MAGIC_VALUE:   u32 = 0x74726976;
let VIRTIO_DEVICE_ID_NET: u32 = 1;

let STATUS_ACKNOWLEDGE: i32 = 1;
let STATUS_DRIVER:      i32 = 2;
let STATUS_DRIVER_OK:   i32 = 4;

let PAGE_SIZE: isize = 4096;

let VIRTIO_MMIO_FIRST_SLOT: i32 = 0x0a000000;
let VIRTIO_MMIO_SLOT_STRIDE: i32 = 0x200;
let VIRTIO_MMIO_SLOT_COUNT: i32 = 32;

let QNUM: isize = 8; // virtqueue depth for both the RX and TX queues

struct packed VirtqDesc {
    addr: usize;
    len: u32;
    flags: u16;
    next: u16;
}

struct packed VirtqAvail {
    flags: u16;
    idx: u16;
    ring: [u16; QNUM];
}

struct packed VirtqUsedElem {
    id: u32;
    len: u32;
}

struct packed VirtqUsed {
    flags: u16;
    idx: u16;
    ring: [VirtqUsedElem; QNUM];
}

// Descriptor flags (virtio spec).
let VIRTQ_DESC_F_WRITE: i32 = 2; // device writes into this buffer (RX only)

let VIRTIO_NET_F_MAC: i32 = 32; // bit 5: device exposes its MAC in Config space
let VIRTIO_CONFIG_MAC_OFFSET: i32 = 0x100; // Config space starts right after the transport registers

// Discovered at runtime: the slot base address is NOT fixed by the
// compiler, because QEMU does not always attach a lone virtio-net-device
// to slot 0 -- empirically, under this devcontainer's QEMU 8.2.2 with a
// single virtio-net-device on the command line, the device landed on slot
// 31 (base 0x0a003e00). Rather than hardcode that (fragile across QEMU
// versions/command lines), net_init() scans all 32 slots at boot and
// derives the base address from whichever slot actually reports
// DeviceID == 1 (network).
let mut virtio_base: i32 = 0;

// RX_BUF_SIZE and every buffer/ring-index below are internal to this
// driver (matching eth.tkb's encapsulation) -- the app never needs to know
// about queue depth, PAGE_SIZE, or descriptor rings.
let RX_BUF_SIZE: isize = 1536; // 10-byte virtio_net_hdr + max 1514-byte Ethernet frame, rounded up
let RX_BUF_SIZE_USIZE: usize = 1536; // memory indexing counterpart

let mut rx_queue_mem: [u8; 2 * PAGE_SIZE] align(4096);
let mut tx_queue_mem: [u8; 2 * PAGE_SIZE] align(4096);

// QNUM (8) RX packet buffers, posted once at init and re-posted after
// each completion.
let mut rx_bufs: [u8; QNUM * RX_BUF_SIZE];

let mut rx_used_seen:        isize = 0;
let mut tx_used_seen:        isize = 0;
let mut rx_avail_idx:        isize = 0;
let mut tx_avail_idx:        isize = 0;
let mut net_last_rx_desc_idx: isize = 0;

fn vreg(offset: i32) -> *io i32 {
    return (virtio_base + offset) as *io i32;
}

fn virtio_net_find() -> i32 {
    for i in 0..<VIRTIO_MMIO_SLOT_COUNT {
        let base: i32 = VIRTIO_MMIO_FIRST_SLOT + i * VIRTIO_MMIO_SLOT_STRIDE;
        let magic_p: *io u32 = base as *io u32;
        if (*magic_p == VIRTIO_MAGIC_VALUE) {
            let devid_p: *io u32 = (base + VIRTIO_DEVICE_ID) as *io u32;
            if (*devid_p == VIRTIO_DEVICE_ID_NET) {
                virtio_base = base;
                return 1;
            }
        }
    }
    return 0;
}

// Device bring-up through feature negotiation. VIRTIO_NET_F_MAC is always
// acked (unconditionally, regardless of whether the caller ever calls
// net_read_mac()) since it's part of the shared driver API surface now --
// harmless for callers that don't use it.
fn virtio_negotiate(features: i32) {
    *(vreg(VIRTIO_STATUS)) = 0; // reset
    *(vreg(VIRTIO_STATUS)) = STATUS_ACKNOWLEDGE;
    *(vreg(VIRTIO_STATUS)) = STATUS_ACKNOWLEDGE | STATUS_DRIVER;

    *(vreg(VIRTIO_GUEST_FEATURES)) = features;
    *(vreg(VIRTIO_GUEST_PAGE_SIZE)) = PAGE_SIZE as i32;
}

fn virtio_queue_setup(queue_idx: i32, queue_mem: *u8) {
    *(vreg(VIRTIO_QUEUE_SEL)) = queue_idx;
    *(vreg(VIRTIO_QUEUE_NUM)) = QNUM as i32;
    *(vreg(VIRTIO_QUEUE_ALIGN)) = PAGE_SIZE as i32;
    let addr: usize = queue_mem as usize;
    let pfn: i32 = (addr / (PAGE_SIZE as usize)) as i32;
    *(vreg(VIRTIO_QUEUE_PFN)) = pfn;
}

fn virtio_driver_ok() {
    *(vreg(VIRTIO_STATUS)) = STATUS_ACKNOWLEDGE | STATUS_DRIVER | STATUS_DRIVER_OK;
}

// Reads the device's 6-byte MAC out of Config space. VIRTIO_NET_F_MAC is
// always acked in virtio_negotiate() now, so this is always meaningful.
fn virtio_net_read_mac(mac_out: *u8) {
    for i in 0..<6 {
        let p: *io u8 = (virtio_base + VIRTIO_CONFIG_MAC_OFFSET + i) as *io u8;
        mac_out[i] = *p;
    }
}

fn virtio_notify(queue_idx: i32) {
    *(vreg(VIRTIO_QUEUE_NOTIFY)) = queue_idx;
}

// -- Vring accessors ----------------------------------------------------
// The three regions still share one page-aligned backing allocation, but each
// region is viewed through its specification-defined struct layout. Layout per
// queue_mem (matches virtio_queue_setup's PAGE_SIZE QueueAlign): descriptor
// table, immediately followed by the avail ring, then the used ring starting
// at the next page (offset PAGE_SIZE).

fn desc_set(queue_mem: *u8, i: isize, addr: usize, len: isize, flags: i32) {
    let descs: *VirtqDesc = queue_mem as *VirtqDesc;
    descs[i].addr = addr;
    descs[i].len = len as u32;
    descs[i].flags = flags as u16;
    // `next` field (offset 14) is left at 0 (BSS-zeroed at boot): we never
    // chain descriptors, so VIRTQ_DESC_F_NEXT is never set and it's unused.
}

fn avail_ring_set(queue_mem: *u8, slot: isize, desc_idx: isize) {
    let avail_off: isize = QNUM * (sizeof(VirtqDesc) as isize);
    let ring: *u16 = (queue_mem + avail_off
        + (offsetof(VirtqAvail, ring) as isize)) as *u16;
    ring[slot] = desc_idx as u16;
}

fn avail_publish(queue_mem: *u8, new_idx: isize) {
    let avail_off: isize = QNUM * (sizeof(VirtqDesc) as isize);
    let avail: *VirtqAvail = (queue_mem + avail_off) as *VirtqAvail;
    avail.idx = new_idx as u16;
}

// These three read memory the device writes asynchronously via DMA, and
// used_idx_get() in particular is polled directly in net_poll_rx()'s
// per-call check. A non-volatile load here is exactly the "LLVM may hoist
// a global/memory load out of a tight loop" hazard called out in
// CLAUDE.md's "Volatile Reads of Global Variables" section (the compiler
// has no way to know DMA writes are coming) -- so these must be `io`.
fn used_idx_get(queue_mem: *u8) -> isize {
    let used: *io VirtqUsed = (queue_mem + PAGE_SIZE) as *io VirtqUsed;
    return used.idx as isize;
}

fn used_ring_get_id(queue_mem: *u8, slot: isize) -> isize {
    let ring: *io VirtqUsedElem = (queue_mem + PAGE_SIZE
        + (offsetof(VirtqUsed, ring) as isize)) as *io VirtqUsedElem;
    return ring[slot].id as isize;
}

fn used_ring_get_len(queue_mem: *u8, slot: isize) -> i32 {
    let ring: *io VirtqUsedElem = (queue_mem + PAGE_SIZE
        + (offsetof(VirtqUsed, ring) as isize)) as *io VirtqUsedElem;
    return ring[slot].len as i32; // same reasoning as used_ring_get_id.
}

// -- Shared driver API (matches examples/common_stm32/eth.tkb) --------------

// Finds the virtio-net device, negotiates features, sets up both queues,
// and posts all RX descriptors. Returns 1 on success, 0 if no virtio-net
// device was found.
fn net_init() -> i32 {
    if (virtio_net_find() == 0) {
        return 0;
    }

    virtio_negotiate(VIRTIO_NET_F_MAC);
    virtio_queue_setup(0, rx_queue_mem as *u8); // RX
    virtio_queue_setup(1, tx_queue_mem as *u8); // TX
    virtio_driver_ok();

    for i in 0..<QNUM {
        let buf_off: isize = i * RX_BUF_SIZE;
        let buf: *u8 = rx_bufs + buf_off;
        desc_set(rx_queue_mem as *u8, i, buf as usize, RX_BUF_SIZE, VIRTQ_DESC_F_WRITE);
        avail_ring_set(rx_queue_mem as *u8, i, i);
    }
    rx_avail_idx = QNUM;
    avail_publish(rx_queue_mem as *u8, rx_avail_idx);
    virtio_notify(0);

    return 1;
}

// Returns the received frame length (virtio_net_hdr already excluded) if a
// frame is ready, 0 otherwise. Non-zero return must be followed by exactly
// one net_rx_release() call once the caller is done reading net_rx_buf().
fn net_poll_rx() -> i32 {
    if (rx_used_seen == used_idx_get(rx_queue_mem as *u8)) {
        return 0;
    }
    let slot: isize = rx_used_seen % QNUM;
    net_last_rx_desc_idx = used_ring_get_id(rx_queue_mem as *u8, slot);
    let frame_total_len: i32 = used_ring_get_len(rx_queue_mem as *u8, slot);
    return frame_total_len - 10; // hide the 10-byte virtio_net_hdr from the caller
}

fn net_rx_buf() -> *u8 {
    let buf_off: isize = net_last_rx_desc_idx * RX_BUF_SIZE;
    return rx_bufs + buf_off + 10;
}

// Capacity view of the current RX buffer as a slice: 1514 bytes = the
// maximum Ethernet frame this stack handles (the physical buffer is
// larger, so the assertion below is true by construction -- that evidence
// closes the "device reports a bogus length" hole: a length outside
// 0..1514 fails the narrowing check and the frame is dropped.
//
// net_last_rx_desc_idx is itself a DEVICE-REPORTED value
// (used_ring_get_id() in net_poll_rx(), never previously validated
// against QNUM) -- clamping it here closes that gap too, and lets the
// capacity view be constructed directly from rx_bufs (a real array) with
// no unsafe pointer assertion at all: min/max prove the clamped index is
// in [0, QNUM-1], Mul/Add propagation carry that through the byte offset
// computation, and the same-base rule (literal offset 1514) closes the
// subslice outright. A corrupted index degrades to reading the wrong
// (but always in-bounds) buffer slot instead of the raw pointer
// arithmetic construction this replaces, which had no such guarantee.
fn net_rx_frame() -> [u8; 1514..] {
    // 7 is QNUM-1 written as a literal, not a computed expression:
    // Const_env only resolves bare literals/names, not arithmetic on
    // them (see CLAUDE.md's "global let initializers can't constant-fold"
    // limitation), so `QNUM - 1` here would lose the range min() needs.
    // Update this literal if QNUM (declared above) ever changes.
    let idx: usize = max(min(net_last_rx_desc_idx, 7), 0) as {0..<8 as usize};
    let offset: usize = idx * RX_BUF_SIZE_USIZE + 10;
    return rx_bufs[offset..<offset + 1514];
}


// Hands the current RX descriptor back to the device and advances the
// ring. Must only be called after a non-zero net_poll_rx() and once the
// caller no longer needs net_rx_buf()'s contents.
fn net_rx_release() {
    let rx_slot: isize = rx_avail_idx % QNUM;
    avail_ring_set(rx_queue_mem as *u8, rx_slot, net_last_rx_desc_idx);
    rx_avail_idx = rx_avail_idx + 1;
    avail_publish(rx_queue_mem as *u8, rx_avail_idx);
    virtio_notify(0);

    rx_used_seen = rx_used_seen + 1;
}

// Transmits len bytes starting at buf (buf must be net_rx_buf()'s own
// pointer -- every example replies in place, reusing the RX buffer, so
// `buf - 10` always lands back on the true DMA buffer start where the
// virtio_net_hdr the device expects on TX too still sits, untouched since
// the device itself wrote it on receive). Synchronous: busy-waits for the
// device to finish reading buf before returning, so the caller can safely
// release buf (net_rx_release()) immediately afterward.
fn net_transmit(buf: *u8, len: i32) {
    desc_set(tx_queue_mem as *u8, 0, (buf - 10) as usize, (len + 10) as isize, 0);
    avail_ring_set(tx_queue_mem as *u8, 0, 0);
    tx_avail_idx = tx_avail_idx + 1;
    avail_publish(tx_queue_mem as *u8, tx_avail_idx);
    virtio_notify(1);

    while (tx_used_seen == used_idx_get(tx_queue_mem as *u8)) {}
    tx_used_seen = tx_used_seen + 1;
}

fn net_read_mac(mac_out: *u8) {
    virtio_net_read_mac(mac_out);
}
