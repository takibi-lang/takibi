// PL011 UART receive (QEMU virt board). Extracted from examples/echo/echo.tkb
// so examples/echo/echo.tkb can stay portable -- same signature as
// examples/common_stm32/uart_getc.tkb.

fn uart_getc() u8 {
    let fr: *io u32 = 0x09000018; // PL011 FR: bit4=RXFE (receive FIFO empty)
    while (*fr == 144) {} // 0x90 = TXFE|RXFE idle state; changes when data arrives
    let dr: *io u8 = 0x09000000; // PL011 UART DR
    return *dr;
}
