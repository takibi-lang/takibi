// Small byte-buffer helpers shared by the protocol examples (arp_reply,
// icmp_echo, tcp_parse, tcp_echo, http_server). MAC/IP addresses and
// multi-byte header fields are always handled as raw byte arrays rather
// than native multi-byte integers -- see the read_u16be/write_u16be
// comment below for why.
//
// SLICE MIGRATION (P4b): read/write_u16be/u32be now take slices (see
// their own comment below) -- every caller has migrated, so no
// transitional pointer wrapper remains here. bytes_eq/bytes_copy/
// copy_str/write_udec stay pointer-based: bytes_eq/bytes_copy are general
// -purpose (still used by netconfig.tkb / common_stm32/eth.tkb /
// http_server's response-body construction), and copy_str/write_udec's
// unbounded-append pattern is the one deliberately-deferred item (see
// CLAUDE.md's P4b section) -- use slice_copy/slice_eq (compiler builtins)
// directly wherever a slice view is already in hand instead of these.

fn bytes_eq(a: *u8, b: *u8, n: i32) -> i32 {
    for i in 0..<n {
        if (a[i] != b[i]) {
            return 0;
        }
    }
    return 1;
}

fn bytes_copy(dst: *u8, src: *u8, n: i32) {
    for i in 0..<n {
        dst[i] = src[i];
    }
}

// Manually composes/decomposes a big-endian 16-bit integer from individual
// byte reads/writes, rather than loading/storing 2 bytes at once through a
// cast pointer. Network fields are big-endian on the wire; this target is
// little-endian; a raw multi-byte load would silently byte-reverse the
// value. Doing it byte-by-byte sidesteps the issue regardless of target
// endianness.
//
// Slice signatures ([u8; 2..] / [u8; 4..]): the caller passes a view that
// PROVES the field fits -- e.g. read_u16be(ip[2..<4]) on an ip view of
// minimum length 20 is fully compile-time proven, so these bodies contain
// zero bounds checks and stay --forbid-trap clean.
fn read_u16be(s: [u8; 2..]) -> i32 {
    return (s[0] as i32) * 256 + (s[1] as i32);
}

fn write_u16be(s: [u8; 2..], v: i32) {
    s[0] = (v / 256) as u8;
    s[1] = (v - (v / 256) * 256) as u8;
}

// Same idea, for the 32-bit fields TCP needs (sequence/ack numbers).
fn read_u32be(s: [u8; 4..]) -> i32 {
    return ((s[0] as i32) << 24) | ((s[1] as i32) << 16) | ((s[2] as i32) << 8) | (s[3] as i32);
}

fn write_u32be(s: [u8; 4..], v: i32) {
    s[0] = (v >> 24) as u8;
    s[1] = (v >> 16) as u8;
    s[2] = (v >> 8) as u8;
    s[3] = v as u8;
}

// Copies a NUL-terminated string (as produced by a string literal) into
// dst and returns the number of bytes copied (the NUL itself is not
// copied) -- used to build a response body/headers into a buffer instead
// of streaming to UART like uart_puts does.
fn copy_str(dst: *u8, src: *u8) -> i32 {
    let mut n: i32 = 0;
    while (src[n] != 0) {
        dst[n] = src[n];
        n = n + 1;
    }
    return n;
}

// Writes the decimal digits of n (n must be >= 0) into buf, with no
// leading zeros, and returns the digit count. Same recursive-digit
// approach as print.tkb's uart_print_uint, just targeting a memory
// buffer instead of streaming to UART one byte at a time.
fn write_udec(buf: *u8, n: i32) -> i32 {
    if (n >= 10) {
        let hi_len: i32 = write_udec(buf, n / 10);
        buf[hi_len] = (n - (n / 10) * 10 + '0') as u8;
        return hi_len + 1;
    } else {
        buf[0] = (n + '0') as u8;
        return 1;
    }
}
