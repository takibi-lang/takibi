// Small byte-buffer helpers shared by the protocol examples (arp_reply,
// icmp_echo, tcp_parse, tcp_echo, http_server). MAC/IP addresses and
// multi-byte header fields are always handled as raw byte arrays rather
// than native multi-byte integers -- see the read_u16be/write_u16be
// comment below for why.
//
// SLICE MIGRATION (P4b): read/write_u16be/u32be now take slices (see
// their own comment below) -- every caller has migrated, so no
// transitional pointer wrapper remains here. bytes_eq/bytes_copy/
// copy_str/write_udec stay pointer-based: bytes_eq/bytes_copy are general
// -purpose (still used by netconfig.tkb / common_stm32/eth.tkb /
// http_server's response-body construction), and copy_str/write_udec's
// unbounded-append pattern is the one deliberately-deferred item (see
// CLAUDE.md's P4b section) -- use slice_copy/slice_eq (compiler builtins)
// directly wherever a slice view is already in hand instead of these.

// Shared protocol layouts. These packed structs exist so the examples can
// spell header lengths and field offsets with `sizeof(...)` / `offsetof(...)`
// instead of hand-maintaining duplicated byte constants in each protocol file.
// The payload bytes are still manipulated through byte slices; the structs are
// just a single source of truth for the wire layout.
struct packed EthHdr {
    dst: [u8; 6];
    src: [u8; 6];
    ethertype: [u8; 2];
}

struct packed ArpHdr {
    htype: [u8; 2];
    ptype: [u8; 2];
    hlen: u8;
    plen: u8;
    oper: [u8; 2];
    sha: [u8; 6];
    spa: [u8; 4];
    tha: [u8; 6];
    tpa: [u8; 4];
}

struct packed Ipv4Hdr {
    version_ihl: u8;
    dscp_ecn: u8;
    total_len: [u8; 2];
    ident: [u8; 2];
    flags_frag: [u8; 2];
    ttl: u8;
    protocol: u8;
    checksum: [u8; 2];
    src: [u8; 4];
    dst: [u8; 4];
}

struct packed TcpHdr {
    src_port: [u8; 2];
    dst_port: [u8; 2];
    seq: [u8; 4];
    ack: [u8; 4];
    data_offset: u8;
    flags: u8;
    window: [u8; 2];
    checksum: [u8; 2];
    urgent: [u8; 2];
}

struct packed IcmpHdr {
    ty: u8;
    code: u8;
    checksum: [u8; 2];
    rest: [u8; 4];
}

let ETH_HDR_LEN: isize = 14;
let ETH_MAC_LEN: isize = 6;
let ETH_DST_OFF: isize = 0;
let ETH_SRC_OFF: isize = 6;
let ETH_TYPE_OFF: isize = 12;
let ETH_DST: usize = 0;
let ETH_SRC: usize = 6;
let ETH_TYPE: usize = 12;

let ARP_HDR_LEN: isize = 28;
let ARP_HTYPE_OFF: isize = 0;
let ARP_PTYPE_OFF: isize = 2;
let ARP_HLEN_OFF: isize = 4;
let ARP_PLEN_OFF: isize = 5;
let ARP_OPER_OFF: isize = 6;
let ARP_SHA_OFF: isize = 8;
let ARP_SPA_OFF: isize = 14;
let ARP_THA_OFF: isize = 18;
let ARP_TPA_OFF: isize = 24;
let ARP_HTYPE: usize = 0;
let ARP_PTYPE: usize = 2;
let ARP_HLEN: usize = 4;
let ARP_PLEN: usize = 5;
let ARP_OPER: usize = 6;
let ARP_SHA: usize = 8;
let ARP_SPA: usize = 14;
let ARP_THA: usize = 18;
let ARP_TPA: usize = 24;

let IP_HDR_LEN: isize = 20;
let IP_ADDR_LEN: isize = 4;
let IP_VERSION_IHL_OFF: isize = 0;
let IP_TOTAL_LEN_OFF: isize = 2;
let IP_TTL_OFF: isize = 8;
let IP_PROTOCOL_OFF: isize = 9;
let IP_CHECKSUM_OFF: isize = 10;
let IP_SRC_OFF: isize = 12;
let IP_DST_OFF: isize = 16;
let IP_VERSION_IHL: usize = 0;
let IP_TOTAL_LEN: usize = 2;
let IP_TTL: usize = 8;
let IP_PROTOCOL: usize = 9;
let IP_CHECKSUM: usize = 10;
let IP_SRC: usize = 12;
let IP_DST: usize = 16;

let TCP_HDR_LEN: isize = 20;
let TCP_SRC_PORT_OFF: isize = 0;
let TCP_DST_PORT_OFF: isize = 2;
let TCP_SEQ_OFF: isize = 4;
let TCP_ACK_OFF: isize = 8;
let TCP_DATA_OFFSET_OFF: isize = 12;
let TCP_FLAGS_OFF: isize = 13;
let TCP_WINDOW_OFF: isize = 14;
let TCP_CHECKSUM_OFF: isize = 16;
let TCP_URGENT_OFF: isize = 18;
let TCP_SRC_PORT: usize = 0;
let TCP_DST_PORT: usize = 2;
let TCP_SEQ: usize = 4;
let TCP_ACK: usize = 8;
let TCP_DATA_OFFSET: usize = 12;
let TCP_FLAGS: usize = 13;
let TCP_WINDOW: usize = 14;
let TCP_CHECKSUM: usize = 16;
let TCP_URGENT: usize = 18;

let ICMP_HDR_LEN: isize = 8;
let ICMP_TYPE_OFF: isize = 0;
let ICMP_CODE_OFF: isize = 1;
let ICMP_CHECKSUM_OFF: isize = 2;
let ICMP_TYPE: usize = 0;
let ICMP_CODE: usize = 1;
let ICMP_CHECKSUM: usize = 2;

fn bytes_eq(a: *u8, b: *u8, n: i32) -> i32 {
    for i in 0..<n {
        if (a[i] != b[i]) {
            return 0;
        }
    }
    return 1;
}

fn bytes_copy(dst: *u8, src: *u8, n: i32) {
    for i in 0..<n {
        dst[i] = src[i];
    }
}

// Manually composes/decomposes a big-endian 16-bit integer from individual
// byte reads/writes, rather than loading/storing 2 bytes at once through a
// cast pointer. Network fields are big-endian on the wire; this target is
// little-endian; a raw multi-byte load would silently byte-reverse the
// value. Doing it byte-by-byte sidesteps the issue regardless of target
// endianness.
//
// Slice signatures ([u8; 2..] / [u8; 4..]): the caller passes a view that
// PROVES the field fits -- e.g. read_u16be(ip[2..<4]) on an ip view of
// minimum length 20 is fully compile-time proven, so these bodies contain
// zero bounds checks and stay --forbid-trap clean.
fn read_u16be(s: [u8; 2..]) -> i32 {
    return (s[0] as i32) * 256 + (s[1] as i32);
}

fn write_u16be(s: [u8; 2..], v: i32) {
    s[0] = (v / 256) as u8;
    s[1] = (v - (v / 256) * 256) as u8;
}

// Same idea, for the 32-bit fields TCP needs (sequence/ack numbers).
fn read_u32be(s: [u8; 4..]) -> i32 {
    return ((s[0] as i32) << 24) | ((s[1] as i32) << 16) | ((s[2] as i32) << 8) | (s[3] as i32);
}

fn write_u32be(s: [u8; 4..], v: i32) {
    s[0] = (v >> 24) as u8;
    s[1] = (v >> 16) as u8;
    s[2] = (v >> 8) as u8;
    s[3] = v as u8;
}

// Copies a NUL-terminated string (as produced by a string literal) into
// dst and returns the number of bytes copied (the NUL itself is not
// copied) -- used to build a response body/headers into a buffer instead
// of streaming to UART like uart_puts does.
fn copy_str(dst: *u8, src: *u8) -> isize {
    let mut n: isize = 0;
    while (src[n] != 0) {
        dst[n] = src[n];
        n = n + 1;
    }
    return n;
}

// Writes the decimal digits of n (n must be >= 0) into buf, with no
// leading zeros, and returns the digit count. Same recursive-digit
// approach as print.tkb's uart_print_uint, just targeting a memory
// buffer instead of streaming to UART one byte at a time.
fn write_udec(buf: *u8, n: i32) -> isize {
    if (n >= 10) {
        let hi_len: isize = write_udec(buf, n / 10);
        buf[hi_len] = (n - (n / 10) * 10 + '0') as u8;
        return hi_len + 1;
    } else {
        buf[0] = (n + '0') as u8;
        return 1;
    }
}
