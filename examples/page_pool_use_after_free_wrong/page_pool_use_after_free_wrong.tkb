// This file is expected to produce a compile error.
use "examples/page_pool/page_pool_core.tkb";

fn page_pool_use_after_free_bad() {
    page_pool_init();
    match page_alloc() {
        PageAllocResult::OutOfMemory => {}
        PageAllocResult::Allocated(page) => {
            let bytes = page_bytes(page);
            page_free(page);
            bytes[0] = 1;
        }
    }
}
