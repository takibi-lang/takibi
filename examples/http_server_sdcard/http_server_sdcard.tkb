// GitHub issue #97: serves the real content of a file stored on a real SD
// card over HTTP -- the payoff of combining two already-working pieces:
// examples/http_server's ARP/TCP/HTTP state machine (real Ethernet
// MAC/PHY/DMA, --forbid-trap clean) and examples/fatfs_sdcard's real FAT12
// access over SDMMC1 (also --forbid-trap clean). See CLAUDE.md's decision
// log for why this milestone was picked over Simple RTOS (issue #66): both
// UART and Ethernet and SD card are already interrupt/DMA-driven
// individually, so no scheduler is needed to combine them safely -- this
// file's app_main() is a single flat loop, exactly like http_server.tkb's
// own.
//
// STAGE 2 SCOPE: GET / maps to INDEX.HTM, and simple single-component
// 8.3 paths such as /ABOUT.HTM map to their corresponding FAT12 names.
// Directory listings, long filenames, and nested paths remain out of
// scope. Larger files are sent as multiple TCP segments, one chunk per
// client ACK, still with one connection at a time and Connection: close.
//
// Multi-segment scope: still one TCP connection at a time and still
// HTTP/1.1 Connection: close, but a response body may span multiple TCP
// segments. The server sends headers plus the first chunk immediately,
// then sends each later chunk only after the previous segment is ACKed.
// FIN is attached to the final chunk.
//
// SD card provisioning is fully automated, no human touches the card:
// examples/http_server_sdcard_install/http_server_sdcard_install.tkb
// writes a real mtools-built FAT12 image onto the card via disk_write,
// run by scripts/provision_http_server_sdcard.sh -- shared by both
// `make hwcheck-net` (scripts/run_hwtest_net_ram.sh) and
// `make stm32-http-server-sdcard` (Makefile), see that script's header
// comment. This file's own app_main() only ever fat_mount()s -- it
// deliberately does NOT fat_format() the card (unlike fatfs_sdcard.tkb),
// since the whole point is showing the card's real, externally
// -provisioned content.
//
// --forbid-trap clean: this file was first written and verified against
// real hardware WITHOUT --forbid-trap, per CLAUDE.md's Development
// Process section (new milestone work -- combining fatfs_sdcard's
// real-SD access with http_server's proven TCP/HTTP layer in a genuinely
// new way, reading file bytes into the reply instead of the static
// html_body). Once the whole milestone (this file + the installer) was
// demonstrated working end to end -- verified over real HTTP via a real
// browser, and by physically removing the card and confirming INDEX.HTM
// with a normal PC file manager -- --forbid-trap was turned on in one
// pass; no sites needed fixing here. Later multi-segment support moved SD
// response generation into shared helpers, and file data is now streamed
// through caller-owned response buffers. See http_server_sdcard_install.tkb,
// part of the same milestone, for the one file that DID need a fix during
// the original issue #97 work.
//
// STM32-only: there is no virtual SD controller in this project's QEMU
// setup (matches examples/fatfs_sdcard and examples/sdcard's own
// no-QEMU status).

use "examples/common/inet_checksum.tkb";
use "examples/common/netutil.tkb";
use "examples/common/http_sdcard_server.tkb";
use "examples/common_stm32/fat12_sdmmc.tkb";

let mut our_mac: [u8; 6];
let mut our_ip:  [u8; 4];

// ARP/IPv4/TCP field offsets (ARP_HTYPE, ..., ARP_TPA, IP_TOTAL_LEN, ...,
// TCP_URGENT) come from examples/common/netutil.tkb's `use` above --
// offsetof(ArpHdr/Ipv4Hdr/TcpHdr, field)-based, matching http_server.tkb.

fn http_file_size(name83: *u8) -> i32 {
    if (fat_file_exists(name83)) {
        return fat_file_size(name83) as i32;
    }
    return -1;
}

fn http_read_chunk(name83: *u8, off: u32, dst: borrow *u8,
        want: u32) -> u32 {
    let mut got: u32 = 0;
    fat_read_at(name83, off, dst, want, &got);
    return got;
}

fn app_main() {
    uart_puts("http_server_sdcard: init\r\n");

    match net_init() {
        NetInitResult::Failed => {
            uart_puts("http_server_sdcard: device/link not found\r\n");
        }
        NetInitResult::Ready(mut ready) => {
            net_read_mac(our_mac as *u8);
            slice_copy(our_ip as []u8, HTTP_SERVER_IP as []u8);

            if (disk_initialize() != 0) {
                uart_puts("http_server_sdcard: disk_initialize FAIL\r\n");
            }
            // Mount only -- never format. This card's real, externally
            // provisioned content is the whole point (see this file's header
            // comment); a fat_open() below simply fails if the card is
            // missing/blank/unmounted, and build_body_from_sdcard() falls
            // back to a short error message rather than the server refusing
            // to answer.
            fat_mount();

            uart_puts("http_server_sdcard: ready\r\n");

            while (true) {
                ready = http_server_poll_once(ready);
            }
        }
    }
}
