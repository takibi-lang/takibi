fn uart_putc(c: char) {
    let dr: *char = 0x09000000;
    *dr = c;
}

fn uart_puts(s: *char) {
    while (*s != 0) {
        uart_putc(*s);
        s = s + 1;
    }
}

fn print_c() {
    uart_puts("C\r\n");
}

fn print_b() {
    uart_puts("B\r\n");
    print_c();
}

fn print_a() {
    uart_puts("A\r\n");
    print_b();
}

fn main() {
    print_a();
    uart_puts("done\r\n");
}
