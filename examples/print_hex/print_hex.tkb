// Demo of hex display for 32-bit integers. Extracts nibbles (4 bits) using >> and &.
fn uart_putc(c: char) {
    let dr: *io char = 0x09000000; // PL011 UART DR
    *dr = c;
}

fn uart_puts(s: *char) {
    while (*s != 0) {
        uart_putc(*s);
        s = s + 1;
    }
}

fn uart_print_hex_digit(n: int) {
    if (n < 10) {
        uart_putc((n + '0') as char);
    } else {
        uart_putc((n - 10 + 'a') as char);
    }
}

fn uart_print_hex(n: int) {
    uart_puts("0x");
    for i in 0..<8 {
        uart_print_hex_digit((n >> (28 - i * 4)) & 15);
    }
}

fn main() {
    uart_puts("=== uart_print_hex test ===\r\n");
    uart_print_hex(0);
    uart_putc('\r');
    uart_putc('\n');
    uart_print_hex(0x0000cafe);
    uart_putc('\r');
    uart_putc('\n');
    uart_print_hex(0x12345678);
    uart_putc('\r');
    uart_putc('\n');
    uart_puts("done\r\n");
}
