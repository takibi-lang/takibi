// Demo of hex display for 32-bit integers. Extracts nibbles (4 bits) using >> and &.

fn app_main() {
    uart_puts("=== uart_print_hex test ===\r\n");
    uart_print_hex(0);
    uart_putc('\r');
    uart_putc('\n');
    uart_print_hex(0x0000cafe);
    uart_putc('\r');
    uart_putc('\n');
    uart_print_hex(0x12345678);
    uart_putc('\r');
    uart_putc('\n');
    uart_puts("done\r\n");
}

