// This is a positive compile-only fixture despite its historical directory
// name. Standard affine weakening also applies to tracked field paths: the
// field may be dropped, while field_double_consume_wrong still proves that it
// cannot be consumed twice.
affine opaque struct Lease3;

fn acquire3() -> *Lease3 {
    return 0 as usize as *Lease3;
}

struct Holder3 {
    t: *Lease3;
}

fn app_main() -> i32 {
    let mut h: Holder3;
    h.t = acquire3();
    return 0;
}
