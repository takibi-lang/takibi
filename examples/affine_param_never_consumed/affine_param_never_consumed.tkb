// This is a positive compile-only fixture despite its historical directory
// name. A plain affine parameter may be dropped by its callee; passing it still
// consumes the caller's copy, so later reuse remains a compile error.
affine opaque struct Token;

fn make() -> *Token {
    return 0 as usize as *Token;
}

fn drop_silently(t: *Token) {
}

fn app_main() -> i32 {
    let t: *Token = make();
    drop_silently(t);
    return 0;
}
