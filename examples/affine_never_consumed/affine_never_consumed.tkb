// This is a positive compile-only fixture despite its historical directory
// name. Slice 3 adopts standard affine weakening: an affine value may be used
// at most once, but dropping it is legal. APIs that require cleanup now use a
// linear type instead (FatFile, NetRxCpuOwned, MutexGuard, and KGuard).
affine opaque struct Token;

fn make() -> *Token {
    return 0 as usize as *Token;
}

fn release(t: sink *Token) {
}

fn app_main() -> i32 {
    let t: *Token = make();
    return 0;
}
