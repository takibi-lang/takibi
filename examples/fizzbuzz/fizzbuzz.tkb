// FizzBuzz: demo of % modulo and if/else if chain. Prints 1 to 20.

fn main() {
    for i in 1..<21 {
        if (i % 15 == 0) {
            uart_puts("FizzBuzz\r\n");
        } else if (i % 3 == 0) {
            uart_puts("Fizz\r\n");
        } else if (i % 5 == 0) {
            uart_puts("Buzz\r\n");
        } else {
            uart_print_uint(i);
            uart_puts("\r\n");
        }
    }
}

