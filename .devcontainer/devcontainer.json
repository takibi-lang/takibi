{
  "image": "cuihtlauac/ocaml-devcontainer:latest",
  "features": {
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {},
    "ghcr.io/sliekens/devcontainer-features/codex:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ocamllabs.ocaml-platform",
        "ms-vscode.cpptools-extension-pack",
        "ms-vscode.makefile-tools"
      ]
    }
  },
  "mounts": [
    "source=${localEnv:HOME}/claude/dot.claude,target=/home/vscode/.claude,type=bind",
    "source=${localEnv:HOME}/claude/dot.claude.json,target=/home/vscode/.claude.json,type=bind"
  ],
  "runArgs": [
    "-v", "/dev:/dev-host:ro",
    "-v", "/dev/bus/usb:/dev/bus/usb",
    "--device-cgroup-rule=c 166:* rmw",
    "--device-cgroup-rule=c 189:* rmw",
    "--network=host"
  ],
  "postCreateCommand": "sudo chown -R vscode:vscode /home/vscode/.claude && sudo apt-get update && sudo apt-get install -y cmake llvm-19-dev libzstd-dev lld-19 qemu-system-arm gdb-multiarch openocd stlink-tools bubblewrap && sudo usermod -aG plugdev,dialout vscode && opam update && opam install -y ppx_deriving llvm",
  "containerEnv": {
    "LANG": "en_US.UTF-8",
    "LC_ALL": "en_US.UTF-8",
    "OPAMYES": "true"
  }
}
