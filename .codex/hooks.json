{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/gh-issue-ascii-only.sh\"",
            "statusMessage": "Checking GitHub issue text"
          }
        ]
      }
    ]
  }
}
