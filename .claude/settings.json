{
  "permissions": {
    "allow": [
      "Bash(gh issue comment:*)",
      "Bash(gh issue create:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/gh-issue-ascii-only.sh\"",
            "if": "Bash(gh issue *)"
          }
        ]
      }
    ]
  }
}
